# Gallery uploader credentials. Copy to .env at repo root and fill in real values.
# .env is gitignored.

# ImageKit (images) — https://imagekit.io/dashboard → Developer → API Keys
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxxxxxxxxxx=
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxxxxxxxxxx=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-imagekit-id>

# Cloudflare R2 (videos) — https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# Create an Account-level token with Object Read & Write permission, scoped to the
# specific bucket (least privilege). Endpoint format is shown in R2 → bucket → Settings.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bucket name (must exist in your R2 account). Recommend a dedicated one for videos.
R2_BUCKET=website-videos

# Public URL of the bucket. Get this by enabling Public Access on the bucket
# (Settings → Public Access → Allow Access on the r2.dev subdomain). Format:
#   https://pub-<32-char-hash>.r2.dev
# Or your own custom domain (e.g. https://videos.yourdomain.com).
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Source directories the manifest builder walks (recursive).
# Comma-separated absolute paths. Override per-machine for cross-OS portability.
# If unset, falls back to Windows defaults baked into the script.
# Example (Mac/Linux):
#   GALLERY_SOURCE_DIRS=/Users/me/Drive/Gallery,/Volumes/Shared/VIDEOS
# Example (Windows):
#   GALLERY_SOURCE_DIRS=H:\My Drive\Gallery,G:\Shared\VIDEOS
GALLERY_SOURCE_DIRS=
