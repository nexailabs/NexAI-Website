{
	"name": "@nexailabs/website",
	"type": "module",
	"version": "1.0.0",
	"description": "NexAI Labs website — Astro 6, Lenis. Hosted on Cloudflare Pages.",
	"author": "NexAI Labs",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nexailabs/NexAI-Website.git"
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"type-check": "astro check",
		"guard:fonts": "node scripts/guard-fonts.mjs",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:update": "playwright test --update-snapshots",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.astro": [
			"eslint --fix",
			"prettier --write --plugin=prettier-plugin-astro"
		],
		"*.{css,json,md,yml,yaml}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.2",
		"astro": "^6.1.7",
		"lenis": "^1.3.23"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"eslint": "^10.2.1",
		"eslint-plugin-astro": "^1.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"typescript-eslint": "^8.59.0"
	}
}
