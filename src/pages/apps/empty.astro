---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/brand/Eyebrow.astro';
import AccentRule from '../../components/vault/AccentRule.astro';
---

<Layout
	title="Nothing here yet | App Vault · NexAI Labs"
	description="An empty corner of the App Vault. Suggest a tool we should be running."
	noIndex
>
	<main class="empty-vault">
		<div class="empty-vault__back-row">
			<a href="/apps" class="empty-vault__back">
				<span aria-hidden="true">←</span> App Vault
			</a>
		</div>

		<div class="empty-vault__inner">
			<div class="empty-vault__eyebrow-row">
				<AccentRule width={24} />
				<Eyebrow tint="accent">Vault · 000</Eyebrow>
			</div>

			<h1 class="empty-vault__title">
				Nothing in this corner of the vault <em>yet</em>.
			</h1>

			<p class="empty-vault__sub">A note from the lab.</p>

			<p class="empty-vault__body">
				We only list tools we run ourselves — no affiliate links, no top-10 padding. If you think
				we're missing one we should try, tell us. We read every suggestion.
			</p>

			<a
				href="mailto:hello@nexailabs.com?subject=Suggest%20a%20tool%20for%20the%20Vault"
				class="empty-vault__cta"
			>
				Suggest a tool →
			</a>

			<div class="empty-vault__footnote">— Curating in progress</div>
		</div>
	</main>
</Layout>

<style>
	.empty-vault {
		max-width: var(--container-max, 1400px);
		margin: 0 auto;
		padding: calc(var(--header-height, 5.9rem) + 32px) var(--space-sm) 120px;
		min-height: 80vh;
	}

	.empty-vault__back-row {
		margin-bottom: 64px;
	}
	.empty-vault__back {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-main);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.empty-vault__back:hover {
		color: var(--color-text-main);
	}

	.empty-vault__inner {
		max-width: 600px;
	}
	.empty-vault__eyebrow-row {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 28px;
	}
	.empty-vault__title {
		font-family: var(--font-accent);
		font-weight: var(--fw-semibold);
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: var(--lh-heading);
		color: var(--color-text-main);
		margin: 0;
		letter-spacing: -0.01em;
		text-wrap: balance;
	}
	.empty-vault__title em {
		font-style: italic;
		font-weight: var(--fw-regular);
	}

	.empty-vault__sub {
		margin-top: 20px;
		margin-bottom: 10px;
		font-family: var(--font-accent);
		font-style: italic;
		font-weight: var(--fw-regular);
		font-size: 1.15rem;
		line-height: 1.5;
		color: var(--color-text-muted);
		letter-spacing: -0.005em;
		max-width: 460px;
	}

	.empty-vault__body {
		margin-top: 0;
		margin-bottom: 36px;
		font-family: var(--font-main);
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-subtle);
		max-width: 460px;
	}

	.empty-vault__cta {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 0.85rem 1.75rem;
		border-radius: var(--radius-full);
		background: var(--color-text-main);
		color: var(--color-bg);
		font-family: var(--font-main);
		font-size: var(--text-btn);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-decoration: none;
		transition:
			background 0.3s var(--ease-out-expo),
			transform 0.3s var(--ease-out-expo);
	}
	.empty-vault__cta:hover {
		background: rgba(255, 255, 255, 0.88);
		transform: translateY(-1px);
	}

	.empty-vault__footnote {
		margin-top: 72px;
		font-family: var(--font-main);
		font-size: 0.7rem;
		font-weight: var(--fw-semibold);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-text-dim);
	}

	@media (prefers-reduced-motion: reduce) {
		.empty-vault__cta:hover {
			transform: none;
		}
	}
	@media (max-width: 600px) {
		.empty-vault__inner {
			margin: 0 auto;
			text-align: center;
		}
		.empty-vault__eyebrow-row {
			justify-content: center;
			width: 100%;
		}
		.empty-vault__sub,
		.empty-vault__body {
			margin-left: auto;
			margin-right: auto;
		}
		.empty-vault__cta {
			margin-left: auto;
			margin-right: auto;
		}
	}
</style>
