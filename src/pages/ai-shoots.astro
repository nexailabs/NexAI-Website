            </div>
          </div>
          <!-- product -->
          <div class="sc3__panel" data-panel="product">
            <div class="sc3__mobile-stage">
              <div class="sc3__mobile-card sc3__mobile-card--before">
                <span class="sc3__mobile-bookmark sc3__mobile-bookmark--before">Before</span>
                <div class="sc3__mobile-card-frame">
                  <img src={productShowcaseInput} alt="Product raw garment input" loading="lazy" />
                </div>
              </div>
              <div class="sc3__mobile-card sc3__mobile-card--after">
                <span class="sc3__mobile-bookmark sc3__mobile-bookmark--after">After</span>
                <div class="sc3__mobile-card-frame sc3__mobile-card-frame--collage">
                  <div class="sc3__mobile-output-grid">
                    <div class="sc3__mobile-output sc3__mobile-output--tl"><img src={productShowcaseOutput[1]} alt="Product AI output 2" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--tr"><img src={productShowcaseOutput[2]} alt="Product AI output 3" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--bl"><img src={productShowcaseOutput[0]} alt="Product AI output 1" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--br"><img src={productShowcaseOutput[3]} alt="Product AI output 4" loading="lazy" /></div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Left Input Block -->
            <div class="sc3__col sc3__col--left">
              <span class="sc3__label">Raw Garments</span>
              <div class="sc3__input-group sc3__input-group--single">
                <div class="sc3__input-main">
                  <img src={productShowcaseInput} alt="Product raw garment input" loading="lazy" />
