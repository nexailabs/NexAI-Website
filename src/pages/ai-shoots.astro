<style>
  .shoots-page {
    min-height: 100svh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 50% 38%, rgba(34, 75, 66, 0.2), transparent 30%),
      linear-gradient(180deg, #0b1110 0%, #09100f 100%);
  }

  .showcase-services-scene {
    position: relative;
  }

  .showcase-services-scene__viewport {
    position: relative;
  }

  .shoots-cursor {
    position: fixed;
    left: 0;
    top: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.72);
    background: transparent;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(-50%, -50%, 0);
    transition: opacity 0.18s ease;
    z-index: 200;
    mix-blend-mode: screen;
  }

  .shoots-cursor-glow {
    position: fixed;
    left: 0;
    top: 0;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background:
      radial-gradient(circle,
        rgba(255, 255, 255, 0.11) 0%,
        rgba(166, 246, 231, 0.08) 22%,
        rgba(97, 219, 196, 0.045) 40%,
        rgba(97, 219, 196, 0.018) 58%,
        transparent 74%);
    pointer-events: none;
    opacity: 0;
    transform: translate3d(-50%, -50%, 0);
    transition: opacity 0.2s ease;
    z-index: 150;
    mix-blend-mode: screen;
    filter: blur(10px);
  }

  @media (pointer: fine) {
    .shoots-page,
    .shoots-page a,
    .shoots-page button,
    .shoots-page [role="button"] {
      cursor: none;
    }
  }

  @media (pointer: coarse) {
    .shoots-cursor-glow,
    .shoots-cursor {
      display: none;
    }
  }

  .shoots-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    /* Perfect vertical centering accounting for Navbar and Marquee */
    padding-top: calc(var(--header-height) + 1rem);
    padding-bottom: clamp(6.5rem, 9vw, 8.5rem);
    box-sizing: border-box;
    overflow: hidden;
  }

  .shoots-hero__shell {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .shoots-hero__copy {
    width: 100%;
    display: grid;
    justify-items: center;
  }

  .shoots-hero__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .shoots-hero__title-row {
    width: min(100%, 88rem);
    min-height: clamp(22rem, 40vh, 28rem);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.35rem, 2.2vw, 2rem);
  }

  .shoots-hero__title-word {
    display: block;
    color: #fff;
    font-size: clamp(3.6rem, 7vw, 7.4rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.88;
    transition: transform 0.82s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.34s ease;
    will-change: transform, opacity;
    white-space: nowrap;
  }
  .shoots-hero__title-word--left {
    text-align: right;
  }
  .shoots-hero__title-word--right {
    text-align: left;
  }

  .shoots-hero__visual {
    flex: none;
    display: grid;
    place-items: center;
  }

  .shoots-hero__stack-stage {
    position: relative;
    width: clamp(15rem, 24vw, 18.5rem);
    height: clamp(21rem, 33vw, 25.5rem);
    overflow: visible;
    pointer-events: none;
  }

  .shoots-hero__deck {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
  }

  .shoots-hero__card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(15rem, 24vw, 18.5rem);
    height: clamp(21rem, 33vw, 25.5rem);
    transform: translate(-50%, -50%);
    transform-origin: 50% 50%;
    border-radius: 1.2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    opacity: 0;
    will-change: transform, opacity;
  }

  .shoots-hero__card img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 1100px) {
