 <script is:inline>
  const initAiShootsHero = () => {
    const stage = document.querySelector('[data-hero-stack-stage]');
    if (!(stage instanceof HTMLElement)) return;
    const titleLeft = document.querySelector('[data-hero-title="left"]');
    const titleRight = document.querySelector('[data-hero-title="right"]');

    const cleanupKey = '__aiShootsHeroCleanup';
    if (typeof window[cleanupKey] === 'function') {
      window[cleanupKey]();
    }

    const decks = Array.from(stage.querySelectorAll('[data-hero-deck]'));
    if (!decks.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIndex = 0;
    let cycleTimer;
    let rafA;
    let rafB;
    const timers = [];

    const getCards = (deck) => Array.from(deck.querySelectorAll('[data-hero-card]'));

    const schedule = (fn, delay) => {
      const id = window.setTimeout(fn, delay);
      timers.push(id);
      return id;
    };

    const getTitleShift = () => {
      if (window.innerWidth <= 720) return -75;
      if (window.innerWidth <= 1100) return -120;
      return -160;
    };

    const setTitleState = ({ shift = 0, opacity = 1 }, animate = true) => {
      const transition = animate
        ? 'transform 0.82s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.34s ease'
        : 'none';

      if (titleLeft instanceof HTMLElement) {
        titleLeft.style.transition = transition;
        titleLeft.style.transform = `translate3d(${-shift}px, 0, 0)`;
        titleLeft.style.opacity = `${opacity}`;
      }

      if (titleRight instanceof HTMLElement) {
        titleRight.style.transition = transition;
        titleRight.style.transform = `translate3d(${shift}px, 0, 0)`;
        titleRight.style.opacity = `${opacity}`;
      }
    };

    const getTravelOffset = () => {
      const stageRect = stage.getBoundingClientRect();
      const sampleCard = stage.querySelector('[data-hero-card]');
      const cardRect = sampleCard instanceof HTMLElement ? sampleCard.getBoundingClientRect() : { height: stageRect.height };
      const cardHeight = cardRect.height || stageRect.height;
      const stageCenterY = stageRect.top + stageRect.height / 2;
      return -(stageCenterY + cardHeight / 2 + 48);
    };

    const getStackZIndex = (index, total) => total - index;

    const stackedState = (index, total, yOffset = 0) => {
      const behind = index;
      return {
        x: 0,
        y: yOffset + behind * 4,
        scale: 1 - behind * 0.012,
        opacity: 1,
        zIndex: getStackZIndex(index, total),
      };
    };

    const isMobile = () => window.innerWidth <= 720;

    const getSpreadUnit = (cards) => {
      if (!cards.length) return 0;
      const width = cards[cards.length - 1].getBoundingClientRect().width || 0;
      if (window.innerWidth <= 1100) return Math.max(width * 0.8, 130);
      return width + 34;
    };

    const spreadState = (index, total, unit) => {
      const middle = (total - 1) / 2;
      const distance = index - middle;
      return {
        x: distance * unit,
        y: 0,
        scale: 1,
        rotate: 0,
        opacity: 1,
        zIndex: getStackZIndex(index, total),
      };
    };

    const holdState = (index, total) => ({ ...stackedState(index, total, 0), rotate: 0 });

    const entryState = (index, total) => ({ ...stackedState(index, total, getTravelOffset()), rotate: 0 });

    const exitState = (index, total) => ({ ...stackedState(index, total, getTravelOffset()), rotate: 0 });

    const applyState = (card, state, animate = true) => {
      // Spring-like overshoot on mobile, smooth expo-out on desktop
      const ease = isMobile()
        ? 'transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease'
        : 'transform 0.88s cubic-bezier(0.16, 1, 0.3, 1)';
      card.style.transition = animate ? ease : 'none';
      const rotate = state.rotate ? `rotate(${state.rotate}deg)` : '';
      card.style.transform = `translate(-50%, -50%) translate3d(${state.x}px, ${state.y}px, 0) scale(${state.scale}) ${rotate}`;
      card.style.transformOrigin = '50% 50%';
      card.style.opacity = `${state.opacity}`;
      card.style.zIndex = `${state.zIndex}`;
    };

    const hideDeck = (deck, immediate = false) => {
      deck.style.transition = 'none';
      deck.style.opacity = '0';
      deck.style.visibility = 'hidden';
    };

    const showDeck = (deck) => {
      const cards = getCards(deck);
      deck.style.opacity = '1';
      deck.style.visibility = 'visible';

      cards.forEach((card, index) => {
        const state = entryState(index, cards.length);
        card.style.zIndex = `${state.zIndex}`;
        card.style.opacity = '1';
        card.style.transition = 'none';
        card.style.transform = `translate(-50%, -50%) translate3d(${state.x}px, ${state.y}px, 0) scale(${state.scale})`;
      });

      rafA = requestAnimationFrame(() => {
        rafB = requestAnimationFrame(() => {
          cards.forEach((card, index) => {
            applyState(card, holdState(index, cards.length), true);
          });
        });
      });

      return cards;
    };

    decks.forEach((deck) => hideDeck(deck, true));
    // Initial state: text together (mobile: tighter shift)
    setTitleState({ shift: isMobile() ? -120 : getTitleShift(), opacity: 1 }, false);

    if (prefersReducedMotion) {
      const activeDeck = decks[0];
      activeDeck.style.opacity = '1';
      activeDeck.style.visibility = 'visible';
      getCards(activeDeck).forEach((card, index, cards) => applyState(card, holdState(index, cards.length), false));
      setTitleState({ shift: 0, opacity: 1 }, false);
      window[cleanupKey] = () => {
        cancelAnimationFrame(rafA);
        cancelAnimationFrame(rafB);
        timers.forEach((timer) => clearTimeout(timer));
      };
      return;
    }

    const runCycle = () => {
      const isLoopRestart = activeIndex === 0;

      decks.forEach((deck, deckIndex) => {
        if (deckIndex !== activeIndex) hideDeck(deck);
      });

      const deck = decks[activeIndex];
      const titleShift = getTitleShift();
      const cycleStart = isLoopRestart ? 2000 : 0;
      let cards = getCards(deck);
      let spreadUnit = 0;

      const startDeck = () => {
        showDeck(deck);
        spreadUnit = getSpreadUnit(cards);
      };

      if (isMobile()) {
        // ── MOBILE: Self-contained deal cycle ──
        // Together: -120 (closes the visual gap → one word)
        // Split: +180 (flies off-screen both sides)
        const togetherShift = -120;
        const splitShift = 180;
        const dealInterval = 800;

        // 1. Start with text together
        setTitleState({ shift: togetherShift, opacity: 1 }, !isLoopRestart);

        // 2. Show deck (stack enters from above)
        if (isLoopRestart) {
          schedule(startDeck, cycleStart);
        } else {
          startDeck();
        }

        // 3. Split text off-screen as deck enters
        schedule(() => {
          setTitleState({ shift: splitShift, opacity: 1 }, true);
        }, cycleStart + 100);

        // 4. Deal each card one by one from above
        const dealStart = cycleStart + 800;
        cards.forEach((card, index) => {
          if (index === 0) return; // Skip image 1, it landed with the stack
          schedule(() => {
            card.style.transition = 'none';
            card.style.transform = 'translate(-50%, -50%) translate3d(0px, -60px, 0) scale(0.92) rotate(0deg)';
            card.style.opacity = '0';
            card.style.zIndex = `${50 + index}`;
            card.style.transformOrigin = '50% 50%';

            requestAnimationFrame(() => { requestAnimationFrame(() => {
              card.style.transition = 'transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease';
              card.style.transform = 'translate(-50%, -50%) translate3d(0px, 0px, 0) scale(1) rotate(0deg)';
              card.style.opacity = '1';
            }); });
          }, dealStart + ((index - 1) * dealInterval));
        });

        // 5. Exit: cards go back up
        const dealTotal = dealInterval * (cards.length - 1);
        const exitStart = dealStart + dealTotal;

        schedule(() => {
          cards.forEach((card, index) => {
            applyState(card, exitState(index, cards.length), true);
          });
        }, exitStart);

        // 6. Join text back together as cards exit
        schedule(() => {
          setTitleState({ shift: togetherShift, opacity: 1 }, true);
        }, exitStart + 100);

        schedule(() => { hideDeck(deck); }, exitStart + 840);

        activeIndex = (activeIndex + 1) % decks.length;
        cycleTimer = window.setTimeout(runCycle, exitStart + 1000);

      } else {
        // ── DESKTOP (unchanged) ──
        if (isLoopRestart) {
          setTitleState({ shift: titleShift, opacity: 1 }, true);
          schedule(startDeck, cycleStart);
        } else {
          setTitleState({ shift: 0, opacity: 1 }, false);
          startDeck();
        }

        schedule(() => {
          setTitleState({ shift: 0, opacity: 1 }, true);
        }, cycleStart + 80);
        // ── DESKTOP: horizontal spread (unchanged) ──
        schedule(() => {
          cards.forEach((card, index) => {
            applyState(card, spreadState(index, cards.length, spreadUnit), true);
          });
        }, cycleStart + 1540);

        schedule(() => {
          cards.forEach((card, index) => {
            applyState(card, holdState(index, cards.length), true);
          });
        }, cycleStart + 2860);

        schedule(() => {
          cards.forEach((card, index) => {
            applyState(card, exitState(index, cards.length), true);
          });
        }, cycleStart + 3840);

        schedule(() => { hideDeck(deck); }, cycleStart + 4680);

        if (activeIndex === decks.length - 1) {
          schedule(() => { setTitleState({ shift: titleShift, opacity: 1 }, true); }, cycleStart + 4920);
        } else {
          schedule(() => { setTitleState({ shift: 0, opacity: 1 }, false); }, cycleStart + 4920);
        }

        activeIndex = (activeIndex + 1) % decks.length;
        cycleTimer = window.setTimeout(runCycle, cycleStart + 5000);
      }
    };

    runCycle();

    window[cleanupKey] = () => {
      cancelAnimationFrame(rafA);
      cancelAnimationFrame(rafB);
      timers.forEach((timer) => clearTimeout(timer));
      clearTimeout(cycleTimer);
    };
  };

  initAiShootsHero();
  document.addEventListener('astro:after-swap', initAiShootsHero);

  // Showcase V3 Logic — Overlay Crossfade
  const initSc3 = () => {
    const navItems = document.querySelectorAll('.sc3__nav-item');
    const panels = document.querySelectorAll('.sc3__panel');
    let switching = false;

    navItems.forEach(item => {
      item.addEventListener('click', () => {
        if (switching) return;
        const target = item.getAttribute('data-category');
        const currentActive = document.querySelector('.sc3__panel.active');
        const nextPanel = document.querySelector(`.sc3__panel[data-panel="${target}"]`);

        if (!nextPanel || nextPanel === currentActive) return;
        switching = true;

        // Update nav
        navItems.forEach(n => n.classList.remove('active'));
        item.classList.add('active');

        // Crossfade: old panel fades out, new panel fades in
        if (currentActive) {
          currentActive.classList.add('leaving');
          currentActive.classList.remove('active');
        }

        // Small delay so the leaving animation starts, then bring in new
        requestAnimationFrame(() => {
          nextPanel.classList.add('active');

          // Clean up leaving class after transition
          setTimeout(() => {
            if (currentActive) currentActive.classList.remove('leaving');
            switching = false;

            // Restart mobile animation cycle instantly on new tab
            if (window.innerWidth <= 900 && typeof window.__initMobShowcaseCycle === 'function') {
              window.__initMobShowcaseCycle();
            }
          }, 550);
        });
      });
    });
  };

  initSc3();
  document.addEventListener('astro:after-swap', initSc3);

  // ── Mobile Pop-Down / Pop-Up Showcase Cycle ──
  const initMobShowcaseCycle = () => {
    const isMob = () => window.innerWidth <= 900;
    const cleanupKey = '__mobShowcaseCycleCleanup';
    if (typeof window[cleanupKey] === 'function') window[cleanupKey]();
    if (!isMob()) return;

    const PASSIVE_SCALE = 0.62;
    const PASSIVE_VISIBLE_RATIO = 0.24;
    const PAN_INTENT = 12;
    const IDLE_RESUME = 3000;
    const AUTO_INPUT_HOLD = 2000;
    const AUTO_OUTPUT_HOLD = 2400;
    const TRANSITION_BUFFER = 720;
    const ACTIVE_SHADOW = 0.34;
    const PASSIVE_SHADOW = 0.2;
    const ACTIVE_OVERLAY = 0.02;
    const PASSIVE_OVERLAY = 0.18;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const lerp = (start, end, progress) => start + (end - start) * progress;
    const slideToValue = (slide) => (slide === 'after' ? 1 : 0);

    const timers = new Set();
    const controllers = [];

    const schedule = (fn, delay) => {
      const id = window.setTimeout(() => {
        timers.delete(id);
        fn();
      }, delay);
      timers.add(id);
      return id;
    };

    const clearTimers = () => {
      timers.forEach((id) => clearTimeout(id));
      timers.clear();
    };

    const getPassiveOffset = (controller) => {
      const baseWidth = controller.beforeCard?.offsetWidth || controller.mobileStage.clientWidth * 0.76;
      return baseWidth * ((1 - PASSIVE_SCALE) + (2 * PASSIVE_VISIBLE_RATIO * PASSIVE_SCALE)) / 2;
    };

    const getVisualState = (controller, progress) => {
      const passiveOffset = getPassiveOffset(controller);
      return {
        before: {
          x: lerp(0, -passiveOffset, progress),
          scale: lerp(1, PASSIVE_SCALE, progress),
          shadow: lerp(ACTIVE_SHADOW, PASSIVE_SHADOW, progress),
          overlay: lerp(ACTIVE_OVERLAY, PASSIVE_OVERLAY, progress),
          z: progress >= 0.5 ? 2 : 4,
        },
        after: {
          x: lerp(passiveOffset, 0, progress),
          scale: lerp(PASSIVE_SCALE, 1, progress),
          shadow: lerp(PASSIVE_SHADOW, ACTIVE_SHADOW, progress),
          overlay: lerp(PASSIVE_OVERLAY, ACTIVE_OVERLAY, progress),
          z: progress >= 0.5 ? 4 : 2,
        },
      };
    };

    const applyVisualState = (controller, progress, dragging = false) => {
      const state = getVisualState(controller, progress);
      const beforeTagOpacity = progress < 0.5 ? 1 : 0;
      const afterTagOpacity = progress >= 0.5 ? 1 : 0;
      controller.progress = progress;
      controller.mobileStage.dataset.dragging = dragging ? 'true' : 'false';
      if (dragging) {
        controller.panel.dataset.dragging = 'true';
      } else {
        controller.panel.removeAttribute('data-dragging');
      }

      controller.mobileStage.style.setProperty('--sc3-before-x', `${state.before.x.toFixed(2)}px`);
      controller.mobileStage.style.setProperty('--sc3-after-x', `${state.after.x.toFixed(2)}px`);
      controller.mobileStage.style.setProperty('--sc3-before-scale', state.before.scale.toFixed(4));
      controller.mobileStage.style.setProperty('--sc3-after-scale', state.after.scale.toFixed(4));
      controller.mobileStage.style.setProperty('--sc3-before-shadow', state.before.shadow.toFixed(3));
      controller.mobileStage.style.setProperty('--sc3-after-shadow', state.after.shadow.toFixed(3));
      controller.mobileStage.style.setProperty('--sc3-before-overlay', state.before.overlay.toFixed(3));
      controller.mobileStage.style.setProperty('--sc3-after-overlay', state.after.overlay.toFixed(3));
      controller.mobileStage.style.setProperty('--sc3-before-z', `${state.before.z}`);
      controller.mobileStage.style.setProperty('--sc3-after-z', `${state.after.z}`);
      controller.mobileStage.style.setProperty('--sc3-before-tag-opacity', `${beforeTagOpacity}`);
      controller.mobileStage.style.setProperty('--sc3-after-tag-opacity', `${afterTagOpacity}`);
    };

    const getActiveController = () => controllers.find((controller) => controller.panel.classList.contains('active'));

    const pauseAutoCycle = () => {
      clearTimers();
    };

    const queueAutoCycle = (delay = IDLE_RESUME) => {
      pauseAutoCycle();
      schedule(runCycle, delay);
    };

    const settleSlide = (controller, slide, { restartAuto = true } = {}) => {
      controller.slide = slide;
      controller.panel.setAttribute('data-mobile-slide', slide);
      applyVisualState(controller, slideToValue(slide), false);
      if (restartAuto) queueAutoCycle();
    };

    const releasePointer = (controller) => {
      if (controller.pointerId === null) return;
      if (typeof controller.mobileStage.releasePointerCapture === 'function' && controller.mobileStage.hasPointerCapture?.(controller.pointerId)) {
        controller.mobileStage.releasePointerCapture(controller.pointerId);
      }
      controller.pointerId = null;
    };

    const finishInteraction = (controller, shouldSettle = true) => {
      if (controller.rafId) {
        cancelAnimationFrame(controller.rafId);
        controller.rafId = 0;
      }
      releasePointer(controller);
      controller.lockedAxis = null;
      controller.dragging = false;
      controller.startValue = slideToValue(controller.slide);
      const nextSlide = controller.progress >= 0.5 ? 'after' : 'before';
      if (shouldSettle) {
        settleSlide(controller, nextSlide);
      } else {
        controller.mobileStage.dataset.dragging = 'false';
        controller.panel.removeAttribute('data-dragging');
      }
    };

    const runCycle = () => {
      const controller = getActiveController();
      if (!controller) {
        schedule(runCycle, 1000);
        return;
      }

      const startSlide = controller.slide;
      settleSlide(controller, startSlide, { restartAuto: false });

      if (startSlide === 'before') {
        schedule(() => {
          const activeController = getActiveController();
          if (!activeController || activeController !== controller || controller.dragging) return;
          settleSlide(controller, 'after', { restartAuto: false });
        }, AUTO_INPUT_HOLD);

        schedule(() => {
          const activeController = getActiveController();
          if (!activeController || activeController !== controller || controller.dragging) return;
          settleSlide(controller, 'before', { restartAuto: false });
        }, AUTO_INPUT_HOLD + AUTO_OUTPUT_HOLD);

        schedule(() => {
          runCycle();
        }, AUTO_INPUT_HOLD + AUTO_OUTPUT_HOLD + TRANSITION_BUFFER);
        return;
      }

      schedule(() => {
        const activeController = getActiveController();
        if (!activeController || activeController !== controller || controller.dragging) return;
        settleSlide(controller, 'before', { restartAuto: false });
      }, AUTO_OUTPUT_HOLD);

      schedule(() => {
        runCycle();
      }, AUTO_OUTPUT_HOLD + TRANSITION_BUFFER);
    };

    document.querySelectorAll('.sc3__panel').forEach((panel) => {
      const mobileStage = panel.querySelector('.sc3__mobile-stage');
      const beforeCard = panel.querySelector('.sc3__mobile-card--before');
      if (!mobileStage || !beforeCard) return;

      const controller = {
        panel,
        mobileStage,
        beforeCard,
        slide: panel.getAttribute('data-mobile-slide') === 'after' ? 'after' : 'before',
        progress: 0,
        startValue: 0,
        pointerId: null,
        lockedAxis: null,
        dragging: false,
        startX: 0,
        startY: 0,
        rafId: 0,
        pendingProgress: null,
      };

      const renderDrag = () => {
        controller.rafId = 0;
        if (controller.pendingProgress === null) return;
        applyVisualState(controller, controller.pendingProgress, true);
      };

      const requestRender = (progress) => {
        controller.pendingProgress = progress;
        if (!controller.rafId) {
          controller.rafId = requestAnimationFrame(renderDrag);
        }
      };

      const onPointerDown = (event) => {
        if (!isMob() || !panel.classList.contains('active')) return;
        if (event.button !== undefined && event.button !== 0) return;
        controller.pointerId = event.pointerId;
        controller.lockedAxis = null;
        controller.dragging = false;
        controller.startX = event.clientX;
        controller.startY = event.clientY;
        controller.startValue = slideToValue(controller.slide);
        controller.pendingProgress = controller.startValue;
        pauseAutoCycle();
        if (typeof mobileStage.setPointerCapture === 'function') {
          mobileStage.setPointerCapture(event.pointerId);
        }
      };

      const onPointerMove = (event) => {
        if (controller.pointerId !== event.pointerId) return;

        const deltaX = event.clientX - controller.startX;
        const deltaY = event.clientY - controller.startY;

        if (!controller.lockedAxis) {
          if (Math.abs(deltaX) < PAN_INTENT && Math.abs(deltaY) < PAN_INTENT) return;
          controller.lockedAxis = Math.abs(deltaX) > Math.abs(deltaY) ? 'x' : 'y';
        }

        if (controller.lockedAxis !== 'x') return;

        controller.dragging = true;
        const passiveOffset = getPassiveOffset(controller);
        const nextProgress = clamp(controller.startValue - (deltaX / passiveOffset), 0, 1);
        requestRender(nextProgress);
      };

      const onPointerEnd = (event) => {
        if (controller.pointerId !== event.pointerId) return;
        finishInteraction(controller, true);
      };

      mobileStage.addEventListener('pointerdown', onPointerDown);
      mobileStage.addEventListener('pointermove', onPointerMove);
      mobileStage.addEventListener('pointerup', onPointerEnd);
      mobileStage.addEventListener('pointercancel', onPointerEnd);

      settleSlide(controller, controller.slide, { restartAuto: false });
      controllers.push(controller);

      controller.cleanup = () => {
        if (controller.rafId) cancelAnimationFrame(controller.rafId);
        releasePointer(controller);
        mobileStage.removeEventListener('pointerdown', onPointerDown);
        mobileStage.removeEventListener('pointermove', onPointerMove);
        mobileStage.removeEventListener('pointerup', onPointerEnd);
        mobileStage.removeEventListener('pointercancel', onPointerEnd);
      };
    });

    queueAutoCycle(0);

    window[cleanupKey] = () => {
      clearTimers();
      controllers.forEach((controller) => controller.cleanup?.());
    };
  };

  window.__initMobShowcaseCycle = initMobShowcaseCycle;
  initMobShowcaseCycle();
  document.addEventListener('astro:after-swap', initMobShowcaseCycle);
  if (!window.__mobShowcaseResizeHandler) {
    window.__mobShowcaseResizeHandler = () => {
      if (window.innerWidth <= 900) {
        initMobShowcaseCycle();
      } else if (typeof window.__mobShowcaseCycleCleanup === 'function') {
        window.__mobShowcaseCycleCleanup();
      }
    };
    window.addEventListener('resize', window.__mobShowcaseResizeHandler);
  }

  const initShowcaseServicesScene = () => {
    const cleanupKey = '__showcaseServicesSceneCleanup';
    if (typeof window[cleanupKey] === 'function') {
      window[cleanupKey]();
    }

    const scene = document.querySelector('[data-showcase-services-scene]');
    const viewport = document.querySelector('[data-showcase-services-viewport]');
    if (!(scene instanceof HTMLElement)) return;
    if (!(viewport instanceof HTMLElement)) return;

    let rafId = 0;

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const render = () => {
      rafId = 0;

      if (window.innerWidth <= 980) {
        scene.classList.remove('is-enhanced');
        scene.classList.remove('is-pinned');
        scene.classList.remove('is-complete');
        scene.style.setProperty('--services-overlay-progress', '1');
        viewport.style.removeProperty('left');
        viewport.style.removeProperty('width');
        return;
      }

      scene.classList.add('is-enhanced');

      const sceneRect = scene.getBoundingClientRect();
      const sceneTop = window.scrollY + sceneRect.top;
      const totalTravel = Math.max(scene.offsetHeight - window.innerHeight, 1);
      const start = sceneTop;
      const end = start + totalTravel;
      const currentY = window.scrollY;
      const progress = clamp((currentY - start) / totalTravel, 0, 1);
      const overlayProgress = clamp((progress - 0.16) / 0.56, 0, 1);

      scene.classList.toggle('is-pinned', currentY >= start && currentY < end);
      scene.classList.toggle('is-complete', currentY >= end);
      scene.style.setProperty('--services-overlay-progress', overlayProgress.toFixed(4));

      if (scene.classList.contains('is-pinned')) {
        viewport.style.left = `${sceneRect.left}px`;
        viewport.style.width = `${sceneRect.width}px`;
      } else {
        viewport.style.removeProperty('left');
        viewport.style.removeProperty('width');
      }
    };

    const requestRender = () => {
      if (rafId) return;
      rafId = window.requestAnimationFrame(render);
    };

    window.addEventListener('scroll', requestRender, { passive: true });
    window.addEventListener('resize', requestRender);
    render();

    window[cleanupKey] = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
      }
      window.removeEventListener('scroll', requestRender);
      window.removeEventListener('resize', requestRender);
      scene.classList.remove('is-enhanced');
      scene.style.removeProperty('--services-overlay-progress');
    };
  };

  initShowcaseServicesScene();
  document.addEventListener('astro:after-swap', initShowcaseServicesScene);

  const initAiShootsServices = () => {
    const cleanupKey = '__aiShootsServicesCleanup';
    if (typeof window[cleanupKey] === 'function') {
      window[cleanupKey]();
    }

    const board = document.querySelector('[data-services-board]');
    if (!(board instanceof HTMLElement)) return;

    const triggers = Array.from(board.querySelectorAll('[data-service-open]'));
    const panels = Array.from(board.querySelectorAll('[data-service-expanded]'));
    const closeButtons = Array.from(board.querySelectorAll('[data-service-close]'));
    if (!triggers.length || !panels.length) return;

    let activeService = '';
    let closeTimer = 0;

    const clearCloseTimer = () => {
      if (closeTimer) {
        clearTimeout(closeTimer);
        closeTimer = 0;
      }
    };

    const scheduleClose = () => {
      clearCloseTimer();
      if (!activeService) return;
      closeTimer = window.setTimeout(() => {
        setOpenService('');
      }, 10000);
    };

    const setOpenService = (serviceId) => {
      activeService = serviceId;
      board.dataset.openService = serviceId;
      board.classList.toggle('is-open', Boolean(serviceId));

      triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-service-open') === serviceId;
        trigger.setAttribute('aria-expanded', isActive ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute('data-service-expanded') === serviceId;
        panel.classList.toggle('is-active', isActive);
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });

      if (serviceId) {
        scheduleClose();
      } else {
        clearCloseTimer();
      }
    };

    const resetCloseIfOpen = () => {
      if (activeService) scheduleClose();
    };

    const onBoardClick = (event) => {
      const openTrigger = event.target.closest('[data-service-open]');
      if (openTrigger instanceof HTMLElement) {
        setOpenService(openTrigger.getAttribute('data-service-open') || '');
        return;
      }

      const closeTrigger = event.target.closest('[data-service-close]');
      if (closeTrigger instanceof HTMLElement) {
        setOpenService('');
        return;
      }

      if (event.target.closest('[data-service-expanded].is-active')) {
        resetCloseIfOpen();
      }
    };

    const onKeyDown = (event) => {
      if (event.key === 'Escape' && activeService) {
        setOpenService('');
        return;
      }
      resetCloseIfOpen();
    };

    const onPointerMove = (event) => {
      if (event.target.closest('[data-service-expanded].is-active')) {
        resetCloseIfOpen();
      }
    };

    const onFocusIn = (event) => {
      if (event.target.closest('[data-service-expanded].is-active')) {
        resetCloseIfOpen();
      }
    };

    board.addEventListener('click', onBoardClick);
    board.addEventListener('keydown', onKeyDown);
    board.addEventListener('pointermove', onPointerMove);
    board.addEventListener('focusin', onFocusIn);

    window[cleanupKey] = () => {
      clearCloseTimer();
      board.removeEventListener('click', onBoardClick);
      board.removeEventListener('keydown', onKeyDown);
      board.removeEventListener('pointermove', onPointerMove);
      board.removeEventListener('focusin', onFocusIn);
    };
  };

  initAiShootsServices();
  document.addEventListener('astro:after-swap', initAiShootsServices);

  const initAiShootsCursor = () => {
    const cleanupKey = '__aiShootsCursorCleanup';
    if (typeof window[cleanupKey] === 'function') {
      window[cleanupKey]();
    }

    const glow = document.querySelector('[data-shoots-cursor-glow]');
    const cursor = document.querySelector('[data-shoots-cursor]');
    const page = document.querySelector('.shoots-page');
    if (!(glow instanceof HTMLElement) || !(cursor instanceof HTMLElement) || !(page instanceof HTMLElement)) return;

    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
    if (!hasFinePointer) {
      glow.style.opacity = '0';
      cursor.style.opacity = '0';
      return;
    }

    const onMove = (event) => {
      glow.style.transform = `translate3d(${event.clientX}px, ${event.clientY}px, 0) translate(-50%, -50%)`;
      glow.style.opacity = '1';
      cursor.style.transform = `translate3d(${event.clientX}px, ${event.clientY}px, 0) translate(-50%, -50%)`;
      cursor.style.opacity = '1';
    };

    const onLeave = () => {
      glow.style.opacity = '0';
      cursor.style.opacity = '0';
    };

    window.addEventListener('pointermove', onMove);
    page.addEventListener('pointerleave', onLeave);

    window[cleanupKey] = () => {
      window.removeEventListener('pointermove', onMove);
      page.removeEventListener('pointerleave', onLeave);
      glow.style.opacity = '0';
      cursor.style.opacity = '0';
    };
  };

  initAiShootsCursor();
  document.addEventListener('astro:after-swap', initAiShootsCursor);

</script>
