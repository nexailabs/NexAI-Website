    gap: 0.5rem;
  }
  .sc3__in-top, .sc3__in-bottom {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    flex: 1;
  }

  /* ── Output Bento Grid ── */
  .sc3__outputs-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    max-width: 100%;
    overflow: hidden;
  }
  .sc3__ob-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .sc3__ob-card {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(200,170,100,0.18);
  }
  .sc3__ob-card img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .sc3__ob-card--3x4 { aspect-ratio: 3 / 4; }
  .sc3__ob-card--2x3 { aspect-ratio: 2 / 3; }
  .sc3__ob-card--1x1 { aspect-ratio: 1 / 1; }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .sc3__shell { grid-template-columns: clamp(9rem, 14vw, 11rem) 1fr; }
    .sc3__panel { grid-template-columns: clamp(8rem, 12vw, 10.5rem) auto 1fr; }
  }
  @media (max-width: 900px) {
    .sc3__shell {
      display: flex;
      flex-direction: column;
      gap: clamp(2rem, 4vw, 3rem);
    }
    .sc3__nav { position: static; }
    .sc3__nav-list {
      flex-direction: row; flex-wrap: wrap;
      border-left: none; gap: 0.5rem;
    }
    .sc3__nav-item {
      width: auto; padding: 0.5rem 0.8rem;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 2rem; font-size: 0.78rem;
    }
    .sc3__nav-item::before { display: none; }
    .sc3__nav-item.active {
      border-color: rgba(78,201,180,0.4);
      background: rgba(78,201,180,0.1);
      padding-left: 0.8rem;
    }
    .sc3__nav-item.active::before { display: none; }
    .sc3__nav-num { display: none; }
    .sc3__nav-dot { display: none; }
    .sc3__panel {
      grid-template-columns: 1fr;
      max-height: none;
    }
    .sc3__panel.active {
      position: relative;
    }
    .sc3__stage {
      min-height: auto;
    }
    .sc3__arrow {
      margin: 0.5rem auto;
      transform: rotate(90deg);
    }
    .sc3__input-group {
      max-width: 100%;
    }
    .sc3__outputs-bento {
      grid-template-columns: repeat(3, 1fr) !important;
      max-width: 100%;
    }
    .sc3__ob-col {
      min-width: 0;
    }
  }
  @media (max-width: 600px) {
    .sc3__panel { grid-template-columns: 1fr; }
    .sc3__outputs-bento {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

