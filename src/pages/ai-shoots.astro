        <!-- Vertical Editorial Category Nav -->
        <nav class="sc3__nav" aria-label="Service categories">
          <ul class="sc3__nav-list">
            <li><button class="sc3__nav-item active" data-target="mannequin"><span class="sc3__nav-text">Mannequin</span></button></li>
            <li><button class="sc3__nav-item" data-target="flat-lay"><span class="sc3__nav-text">Flat Lay</span></button></li>
            <li><button class="sc3__nav-item" data-target="unstitched"><span class="sc3__nav-text">Unstitched</span></button></li>
            <li><button class="sc3__nav-item" data-target="three-piece"><span class="sc3__nav-text">3-Piece</span></button></li>
            <li><button class="sc3__nav-item" data-target="saree"><span class="sc3__nav-text">Saree</span></button></li>
            <li><button class="sc3__nav-item" data-target="menswear"><span class="sc3__nav-text">Menswear</span></button></li>
          </ul>
        </nav>

        <!-- Content Stage -->
        <div class="sc3__stage">
          <!-- mannequin -->
          <div class="sc3__panel active" data-panel="mannequin">
            <!-- Left Input Block -->
            <div class="sc3__col sc3__col--left">
              <span class="sc3__label">Input Images</span>
              <div class="sc3__input-group">
                <div class="sc3__input-main sc3__placeholder">
                  <svg class="sc3__ph-icon sc3__ph-icon--lg" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg><span class="sc3__ph-text">Garment</span><div class="sc3__scan-line"></div>
                </div>
                <div class="sc3__input-side">
                  <div class="sc3__in-top sc3__placeholder"><svg class="sc3__ph-icon" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg></div>
                  <div class="sc3__in-bottom sc3__placeholder"><svg class="sc3__ph-icon" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg></div>
