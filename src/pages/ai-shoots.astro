---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const bookingUrl = 'https://cal.com/nexailabs/15min';
const email = 'hello@nexailabs.com';

const heroNavLinks = [
  { label: 'Services', href: '#services', caption: 'AI photoshoots for fashion brands.' },
  { label: 'Process', href: '#process', caption: 'How the creative pipeline works.' },
  { label: 'Work', href: '#work', caption: 'Selected visual directions and outputs.' },
  { label: 'FAQ', href: '#faq', caption: 'Answers on delivery, quality, and workflow.' },
];

const heroDeckA = [
  { src: '/assets/ai-shoots/amit-stack/deck-1/B1.jpeg', alt: 'Deck 1 card 1' },
  { src: '/assets/ai-shoots/amit-stack/deck-1/B2.jpeg', alt: 'Deck 1 card 2' },
  { src: '/assets/ai-shoots/amit-stack/deck-1/B3.jpeg', alt: 'Deck 1 card 3' },
  { src: '/assets/ai-shoots/amit-stack/deck-1/B4.jpeg', alt: 'Deck 1 card 4' },
  { src: '/assets/ai-shoots/amit-stack/deck-1/B5.png', alt: 'Deck 1 card 5' },
];

const heroDeckB = [
  { src: '/assets/ai-shoots/amit-stack/deck-2/J1.jpeg', alt: 'Deck 2 card 1' },
  { src: '/assets/ai-shoots/amit-stack/deck-2/J2.png', alt: 'Deck 2 card 2' },
  { src: '/assets/ai-shoots/amit-stack/deck-2/J3.jpg', alt: 'Deck 2 card 3' },
  { src: '/assets/ai-shoots/amit-stack/deck-2/J4.jpg', alt: 'Deck 2 card 4' },
  { src: '/assets/ai-shoots/amit-stack/deck-2/J5.jpeg', alt: 'Deck 2 card 5' },
];

const heroDeckC = [
  { src: '/assets/ai-shoots/amit-stack/deck-3/W1.jpg', alt: 'Deck 3 card 1' },
  { src: '/assets/ai-shoots/amit-stack/deck-3/W2.jpg', alt: 'Deck 3 card 2' },
  { src: '/assets/ai-shoots/amit-stack/deck-3/W3.jpg', alt: 'Deck 3 card 3' },
  { src: '/assets/ai-shoots/amit-stack/deck-3/W4.jpg', alt: 'Deck 3 card 4' },
  { src: '/assets/ai-shoots/amit-stack/deck-3/W5.jpg', alt: 'Deck 3 card 5' },
];

const heroDeckD = [
  { src: '/assets/ai-shoots/amit-stack/deck-4/G1.jpg', alt: 'Deck 4 card 1' },
  { src: '/assets/ai-shoots/amit-stack/deck-4/G2.jpg', alt: 'Deck 4 card 2' },
  { src: '/assets/ai-shoots/amit-stack/deck-4/G3.jpg', alt: 'Deck 4 card 3' },
  { src: '/assets/ai-shoots/amit-stack/deck-4/G4.jpg', alt: 'Deck 4 card 4' },
  { src: '/assets/ai-shoots/amit-stack/deck-4/G5.jpeg', alt: 'Deck 4 card 5' },
];

const heroDecks = [heroDeckD, heroDeckC, heroDeckB, heroDeckA];
---

<Layout title="AI Photoshoots for Fashion Brands | NexAI Labs" description="Premium AI fashion photography for D2C brands." showNavbar={false}>
  <main class="shoots-page">
    <Navbar
      navLinks={heroNavLinks}
      topHref="#top"
      brandAriaLabel="NexAI Labs AI Shoots home"
      ctaHref={bookingUrl}
      ctaLabel="Book a Call"
      email={email}
      takeoverMeta="India / Remote"
      panelId="ai-shoots-nav-takeover"
    />

    <section class="shoots-hero" id="top">
      <div class="container shoots-hero__shell">
        <div class="shoots-hero__copy">
          <h1 class="shoots-hero__sr-only">AI Photoshoots for Fashion Brands</h1>
          <div class="shoots-hero__title-row">
            <span class="shoots-hero__title-word shoots-hero__title-word--left" data-hero-title="left">NEXAI</span>
            <div class="shoots-hero__visual">
              <span class="shoots-hero__stack-stage" data-hero-stack-stage aria-hidden="true">
                {heroDecks.map((deck, deckIndex) => (
                  <span class:list={['shoots-hero__deck', `shoots-hero__deck--${deckIndex + 1}`]} data-hero-deck>
                    {deck.map((item, index) => (
                      <span class:list={['shoots-hero__card', `shoots-hero__card--${index + 1}`]} data-hero-card>
                        <img src={item.src} alt={item.alt} loading={deckIndex === 0 && index === deck.length - 1 ? 'eager' : 'lazy'} decoding="async" />
                      </span>
                    ))}
                  </span>
                ))}
              </span>
            </div>
            <span class="shoots-hero__title-word shoots-hero__title-word--right" data-hero-title="right">STUDIO</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .shoots-page {
    min-height: 100svh;
    background:
      radial-gradient(circle at 50% 38%, rgba(34, 75, 66, 0.2), transparent 30%),
      linear-gradient(180deg, #0b1110 0%, #09100f 100%);
  }

  .shoots-hero {
    min-height: 100svh;
    padding-top: 7.25rem;
    padding-bottom: 3rem;
    overflow: clip;
  }

  .shoots-hero__shell {
    min-height: calc(100svh - 10.25rem);
    display: grid;
    place-items: center;
  }

  .shoots-hero__copy {
    width: 100%;
    display: grid;
    justify-items: center;
  }

  .shoots-hero__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .shoots-hero__title-row {
    width: min(100%, 88rem);
    min-height: clamp(22rem, 40vh, 28rem);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.35rem, 2.2vw, 2rem);
  }

  .shoots-hero__title-word {
    display: block;
    color: #fff;
    font-size: clamp(3.6rem, 7vw, 7.4rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.88;
    transition: transform 0.82s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.34s ease;
    will-change: transform, opacity;
    white-space: nowrap;
  }

  .shoots-hero__visual {
    flex: none;
    display: grid;
    place-items: center;
  }

  .shoots-hero__stack-stage {
    position: relative;
    width: clamp(15rem, 24vw, 18.5rem);
    height: clamp(21rem, 33vw, 25.5rem);
    overflow: visible;
    pointer-events: none;
  }

  .shoots-hero__deck {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
  }

  .shoots-hero__card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(15rem, 24vw, 18.5rem);
    height: clamp(21rem, 33vw, 25.5rem);
    transform: translate(-50%, -50%);
    transform-origin: 50% 50%;
    border-radius: 1.2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    opacity: 0;
    will-change: transform, opacity;
  }

  .shoots-hero__card img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 1100px) {
    .shoots-hero__title-row {
      min-height: 21rem;
      gap: 1.15rem;
    }

    .shoots-hero__stack-stage,
    .shoots-hero__card {
      width: clamp(12rem, 26vw, 14rem);
      height: clamp(17rem, 37vw, 20rem);
    }

    .shoots-hero__title-word {
      font-size: clamp(3rem, 7vw, 5.6rem);
    }
  }

  @media (max-width: 720px) {
    .shoots-hero {
      padding-top: 6.8rem;
      padding-bottom: 2.5rem;
    }

    .shoots-hero__shell {
      min-height: calc(100svh - 9.3rem);
    }

    .shoots-hero__copy {
      width: 100%;
    }

    .shoots-hero__title-row {
      width: 100%;
      min-height: 17.5rem;
      gap: 0.75rem;
    }

    .shoots-hero__stack-stage,
    .shoots-hero__card {
      width: clamp(9.8rem, 42vw, 11.8rem);
      height: clamp(13.8rem, 58vw, 16.4rem);
      border-radius: 1rem;
    }

    .shoots-hero__title-word {
      font-size: clamp(2.2rem, 9.2vw, 3.8rem);
    }
  }
</style>

<script is:inline>
  const initAiShootsHero = () => {
    const stage = document.querySelector('[data-hero-stack-stage]');
    if (!(stage instanceof HTMLElement)) return;
    const titleLeft = document.querySelector('[data-hero-title="left"]');
    const titleRight = document.querySelector('[data-hero-title="right"]');

    const cleanupKey = '__aiShootsHeroCleanup';
    if (typeof window[cleanupKey] === 'function') {
      window[cleanupKey]();
    }

    const decks = Array.from(stage.querySelectorAll('[data-hero-deck]'));
    if (!decks.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIndex = 0;
    let cycleTimer;
    let rafA;
    let rafB;
    const timers = [];

    const getCards = (deck) => Array.from(deck.querySelectorAll('[data-hero-card]'));

    const schedule = (fn, delay) => {
      const id = window.setTimeout(fn, delay);
      timers.push(id);
      return id;
    };

    const getTitleShift = () => {
      if (window.innerWidth <= 720) return 20;
      if (window.innerWidth <= 1100) return 34;
      return 46;
    };

    const setTitleState = ({ shift = 0, opacity = 1 }, animate = true) => {
      const transition = animate
        ? 'transform 0.82s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.34s ease'
        : 'none';

      if (titleLeft instanceof HTMLElement) {
        titleLeft.style.transition = transition;
        titleLeft.style.transform = `translate3d(${-shift}px, 0, 0)`;
        titleLeft.style.opacity = `${opacity}`;
      }

      if (titleRight instanceof HTMLElement) {
        titleRight.style.transition = transition;
        titleRight.style.transform = `translate3d(${shift}px, 0, 0)`;
        titleRight.style.opacity = `${opacity}`;
      }
    };

    const getTravelOffset = () => {
      const stageRect = stage.getBoundingClientRect();
      const sampleCard = stage.querySelector('[data-hero-card]');
      const cardRect = sampleCard instanceof HTMLElement ? sampleCard.getBoundingClientRect() : { height: stageRect.height };
      const cardHeight = cardRect.height || stageRect.height;
      const stageCenterY = stageRect.top + stageRect.height / 2;
      return -(stageCenterY + cardHeight / 2 + 48);
    };

    const getStackZIndex = (index, total) => total - index;

    const stackedState = (index, total, yOffset = 0) => {
      const behind = index;
      return {
        x: 0,
        y: yOffset + behind * 4,
        scale: 1 - behind * 0.012,
        opacity: 1,
        zIndex: getStackZIndex(index, total),
      };
    };

    const getSpreadUnit = (cards) => {
      if (!cards.length) return 0;
      const width = cards[cards.length - 1].getBoundingClientRect().width || 0;
      if (window.innerWidth <= 720) return Math.max(width * 0.54, 72);
      if (window.innerWidth <= 1100) return Math.max(width * 0.8, 130);
      return width + 34;
    };

    const spreadState = (index, total, unit) => {
      const middle = (total - 1) / 2;
      const distance = index - middle;
      return {
        x: distance * unit,
        y: 0,
        scale: 1,
        opacity: 1,
        zIndex: getStackZIndex(index, total),
      };
    };

    const holdState = (index, total) => stackedState(index, total, 0);

    const entryState = (index, total) => stackedState(index, total, getTravelOffset());

    const exitState = (index, total) => stackedState(index, total, getTravelOffset());

    const applyState = (card, state, animate = true) => {
      card.style.transition = animate ? 'transform 0.88s cubic-bezier(0.16, 1, 0.3, 1)' : 'none';
      card.style.transform = `translate(-50%, -50%) translate3d(${state.x}px, ${state.y}px, 0) scale(${state.scale})`;
      card.style.opacity = `${state.opacity}`;
      card.style.zIndex = `${state.zIndex}`;
    };

    const hideDeck = (deck, immediate = false) => {
      deck.style.transition = 'none';
      deck.style.opacity = '0';
      deck.style.visibility = 'hidden';
    };

    const showDeck = (deck) => {
      const cards = getCards(deck);
      deck.style.opacity = '1';
      deck.style.visibility = 'visible';

      cards.forEach((card, index) => {
        const state = entryState(index, cards.length);
        card.style.zIndex = `${state.zIndex}`;
        card.style.opacity = '1';
        card.style.transition = 'none';
        card.style.transform = `translate(-50%, -50%) translate3d(${state.x}px, ${state.y}px, 0) scale(${state.scale})`;
      });

      rafA = requestAnimationFrame(() => {
        rafB = requestAnimationFrame(() => {
          cards.forEach((card, index) => {
            applyState(card, holdState(index, cards.length), true);
          });
        });
      });

      return cards;
    };

    decks.forEach((deck) => hideDeck(deck, true));
    setTitleState({ shift: 0, opacity: 1 }, false);

    if (prefersReducedMotion) {
      const activeDeck = decks[0];
      activeDeck.style.opacity = '1';
      activeDeck.style.visibility = 'visible';
      getCards(activeDeck).forEach((card, index, cards) => applyState(card, holdState(index, cards.length), false));
      setTitleState({ shift: getTitleShift(), opacity: 1 }, false);
      window[cleanupKey] = () => {
        cancelAnimationFrame(rafA);
        cancelAnimationFrame(rafB);
        timers.forEach((timer) => clearTimeout(timer));
      };
      return;
    }

    const runCycle = () => {
      const isLoopRestart = activeIndex === 0;

      decks.forEach((deck, deckIndex) => {
        if (deckIndex !== activeIndex) hideDeck(deck);
      });

      const deck = decks[activeIndex];
      const titleShift = getTitleShift();
      const cycleStart = isLoopRestart ? 2000 : 0;
      let cards = [];
      let spreadUnit = 0;

      const startDeck = () => {
        cards = showDeck(deck);
        spreadUnit = getSpreadUnit(cards);
      };

      if (isLoopRestart) {
        setTitleState({ shift: 0, opacity: 1 }, true);
        schedule(startDeck, cycleStart);
      } else {
        setTitleState({ shift: titleShift, opacity: 1 }, false);
        startDeck();
      }

      schedule(() => {
        setTitleState({ shift: titleShift, opacity: 1 }, true);
      }, cycleStart + 80);

      schedule(() => {
        cards.forEach((card, index) => {
          applyState(card, spreadState(index, cards.length, spreadUnit), true);
        });
      }, cycleStart + 1540);

      schedule(() => {
        cards.forEach((card, index) => {
          applyState(card, holdState(index, cards.length), true);
        });
      }, cycleStart + 2860);

      schedule(() => {
        cards.forEach((card, index) => {
          applyState(card, exitState(index, cards.length), true);
        });
      }, cycleStart + 3840);

      schedule(() => {
        hideDeck(deck);
      }, cycleStart + 4680);

      if (activeIndex === decks.length - 1) {
        schedule(() => {
          setTitleState({ shift: 0, opacity: 1 }, true);
        }, cycleStart + 4920);
      } else {
        schedule(() => {
          setTitleState({ shift: titleShift, opacity: 1 }, false);
        }, cycleStart + 4920);
      }

      activeIndex = (activeIndex + 1) % decks.length;
      cycleTimer = window.setTimeout(runCycle, cycleStart + 5000);
    };

    runCycle();

    window[cleanupKey] = () => {
      cancelAnimationFrame(rafA);
      cancelAnimationFrame(rafB);
      timers.forEach((timer) => clearTimeout(timer));
      clearTimeout(cycleTimer);
    };
  };

  initAiShootsHero();
  document.addEventListener('astro:after-swap', initAiShootsHero);
</script>
