<style is:global>
  /* ═══════════════════════════════════════
     Client Brands Marquee
     ═══════════════════════════════════════ */
  .client-marquee {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 10;
    padding: 1rem 0 2.5rem 0; /* Bottom padding pushes the logos visually upward */
    overflow: hidden;
    background: transparent;
    border-top: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15); /* 1mm white line separator */
  }
  .client-marquee__track {
    display: flex;
    width: max-content;
    animation: scrollMarquee 35s linear infinite;
  }
  /* Pause animation when hovering anywhere in the marquee container */
  .client-marquee:hover .client-marquee__track {
    animation-play-state: paused;
  }
  .client-marquee__list {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: clamp(3rem, 5vw, 6rem); /* Reduced gap to allow bigger logos */
    padding: 0 clamp(1.5rem, 3vw, 3rem);
  }
  .client-marquee__list img {
    height: clamp(3.5rem, 6vw, 5.5rem); /* Much bigger logo size */
    width: auto;
    max-width: 320px;
    object-fit: contain;
    opacity: 0.95;
    filter: grayscale(1) brightness(1.5);
    transition: all 0.4s ease;
  }
  .client-marquee__list img:hover {
    opacity: 1;
    transform: scale(1.05);
    filter: grayscale(0) brightness(1);
  }
  @keyframes scrollMarquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ═══════════════════════════════════════
     Showcase V3 — Editorial Layout
     ═══════════════════════════════════════ */
  .sc3 {
    padding: clamp(4rem, 8vw, 7rem) 0;
    position: relative;
  }
  .sc3__shell {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  /* ── Horizontal Top Nav ── */
  .sc3__nav {
    width: 100%;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }
  .sc3__nav-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .sc3__nav-item {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 99rem;
    color: rgba(255,255,255,0.5);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.8rem 1.6rem;
    cursor: pointer;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
    position: relative;
    overflow: hidden;
  }
  /* Hover Shine */
  .sc3__nav-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(78,201,180,0.3) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .sc3__nav-item:hover {
    color: rgba(255,255,255,1);
    border-color: rgba(78,201,180,0.4);
    box-shadow: 0 0 20px rgba(78,201,180,0.15);
  }
  .sc3__nav-item:hover::before {
    opacity: 1;
  }
  .sc3__nav-text {
    position: relative;
    z-index: 1;
  }

  /* Active state */
  .sc3__nav-item.active {
    color: #fff;
    background: rgba(78,201,180,0.15);
    border-color: var(--color-brand-cyan, #4ec9b4);
    box-shadow: 0 0 24px rgba(78,201,180,0.4);
    font-weight: 600;
  }
  .sc3__nav-item.active::before {
    display: none;
  }

  /* ── Stage (stacking context for overlay crossfade) ── */
  .sc3__stage {
    position: relative;
    width: 100%;
    min-height: min(50vh, 22rem);
  }

  /* ── Panel: OVERLAY CROSSFADE ── */
  .sc3__panel {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: clamp(14rem, 20vw, 22rem) auto 1fr;
    grid-template-rows: 1fr;
    gap: clamp(1rem, 2vw, 2.5rem);
    align-items: center; /* keep smaller images vertically centered and unstretched */
    opacity: 0;
    pointer-events: none;
    transform: scale(0.97);
    transition: opacity 0.5s cubic-bezier(0.16,1,0.3,1),
                transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .sc3__panel.active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }
  .sc3__panel.leaving {
    opacity: 0;
    pointer-events: none;
    transform: scale(1.02);
  }

  /* ── Columns ── */
  .sc3__col {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    animation: sc3FadeUp 0.6s ease both;
  }
  .sc3__col--right {
    animation-delay: 0.15s;
  }
  .sc3__label {
    color: rgba(255,255,255,0.4);
    font-size: 0.62rem; font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  
  /* ── Collage Left Side ── */
  .sc3__left-collage {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0.5rem;
    width: 100%;
  }
  .sc3__collage-col-2 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sc3__frame--3-4 {
    aspect-ratio: 3 / 4;
    height: 100%;
  }
  .sc3__frame--1-1 {
    aspect-ratio: 1 / 1;
    width: 100%;
  }
  .sc3__frame--1-2 {
    aspect-ratio: 1 / 2;
    width: 100%;
    flex: 1;
  }

  /* ── Input Card ── */
  .sc3__input-frame {
    position: relative;
    flex: 1;
    aspect-ratio: 3 / 4;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(200,170,100,0.2);
    background: rgba(255,255,255,0.02);
    box-shadow: 0 0 20px rgba(200,170,100,0.08), 0 8px 28px rgba(0,0,0,0.5);
  }
  .sc3__input-frame img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }

  /* ── Placeholder Styles ── */
  .sc3__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.02);
  }
  .sc3__ph-icon {
    width: 28px; height: auto;
    color: rgba(200,170,100,0.25);
  }
  .sc3__ph-icon--lg {
    width: 44px;
  }
  .sc3__ph-text {
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
  }

  /* ── Connection UI (Soft Pulse Line) ── */
  .sc3__arrow {
    position: relative;
    width: clamp(2.5rem, 5vw, 5rem);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(78,201,180,0.6), transparent);
    align-self: center;
    border-radius: 2px;
    opacity: 0;
  }
  .sc3__panel.active .sc3__arrow {
    opacity: 0.5;
    animation: sc3ConnectPulse 2.5s ease-in-out infinite alternate;
  }
  .sc3__arrow svg {
    display: none; /* Hide static SVG arrow */
  }
  @keyframes sc3ConnectPulse {
    0%   { opacity: 0.2; transform: scaleX(0.8); }
    100% { opacity: 0.8; transform: scaleX(1.2); }
  }

  /* ── Output Grid (bento staggered layout) ── */
  .sc3__outputs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.6rem, 1vw, 1.2rem);
    flex: 1;
    align-content: start;
  }
  .sc3__out-card {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid rgba(200,170,100,0.18);
    box-shadow: 0 0 16px rgba(200,170,100,0.06), 0 6px 20px rgba(0,0,0,0.4);
    opacity: 0;
    transform: translateY(16px) scale(0.97);
  }
  /* Remove stagger for 3 grid columns */

  .sc3__out-card img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .sc3__panel.active .sc3__out-card--1 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.30s both; }
  .sc3__panel.active .sc3__out-card--2 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.42s both; }
  .sc3__panel.active .sc3__out-card--3 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.54s both; }
  .sc3__panel.active .sc3__out-card--4 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.66s both; }
  .sc3__panel.active .sc3__out-card--5 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.78s both; }
  .sc3__panel.active .sc3__out-card--6 { animation: sc3CardIn 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.90s both; }

  @keyframes sc3FadeUp {
    0%   { opacity: 0; transform: translateY(16px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes sc3CardIn {
    0%   { opacity: 0; transform: translateY(16px) scale(0.97); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Input Group ── */
  .sc3__input-group {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0.5rem;
    max-width: 100%;
    overflow: hidden;
  }
  .sc3__input-main {
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(200,170,100,0.2);
