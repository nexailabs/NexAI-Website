---

<Layout title="AI Photoshoots for Fashion Brands | NexAI Labs" description="Premium AI fashion photography for D2C brands." showNavbar={false}>
  <main class="shoots-page">
    <span class="shoots-cursor-glow" aria-hidden="true" data-shoots-cursor-glow></span>
    <span class="shoots-cursor" aria-hidden="true" data-shoots-cursor></span>
    <Navbar
      navLinks={heroNavLinks}
      topHref="#top"
      brandAriaLabel="NexAI Labs AI Shoots home"
      ctaHref={bookingUrl}
      ctaLabel="Book a Call"
      email={email}
      panelId="ai-shoots-nav-takeover"
    />

    <section class="shoots-hero" id="top">
      <div class="container shoots-hero__shell">
        <div class="shoots-hero__copy">
          <h1 class="shoots-hero__sr-only">AI Photoshoots for Fashion Brands</h1>
          <div class="shoots-hero__title-row">
            <span class="shoots-hero__title-word shoots-hero__title-word--left" data-hero-title="left">NEXAI</span>
            <div class="shoots-hero__visual">
              <span class="shoots-hero__stack-stage" data-hero-stack-stage aria-hidden="true">
                {heroDecks.map((deck, deckIndex) => (
                  <span class:list={['shoots-hero__deck', `shoots-hero__deck--${deckIndex + 1}`]} data-hero-deck>
                    {deck.map((item, index) => (
                      <span class:list={['shoots-hero__card', `shoots-hero__card--${index + 1}`]} data-hero-card>
                        <img src={item.src} alt={item.alt} loading={deckIndex === 0 && index === deck.length - 1 ? 'eager' : 'lazy'} decoding="async" />
                      </span>
                    ))}
                  </span>
                ))}
              </span>
            </div>
            <span class="shoots-hero__title-word shoots-hero__title-word--right" data-hero-title="right">STUDIO</span>
          </div>
        </div>
      </div>

    <!-- Client Brands Marquee -->
    <div class="client-marquee" aria-label="Our Trusted Brands">
      <div class="client-marquee__track">
        <div class="client-marquee__list">
          <img src="/assets/brands/Banno.png" alt="Banno" loading="lazy" />
          <img src="/assets/brands/DBJ.png" alt="DBJ" loading="lazy" />
          <img src="/assets/brands/GANGA ONG.png" alt="Ganga" loading="lazy" />
          <img src="/assets/brands/INDO ERA PNG.png" alt="Indo Era" loading="lazy" />
          <img src="/assets/brands/JANASYA.png" alt="Janasya" loading="lazy" />
          <img src="/assets/brands/JUGO.png" alt="Jugo" loading="lazy" />
          <img src="/assets/brands/STF.png" alt="STF" loading="lazy" />
          <img src="/assets/brands/leemboodi.png" alt="Leemboodi" loading="lazy" />
          <img src="/assets/brands/skylee.png" alt="Skylee" loading="lazy" />
          <img src="/assets/brands/xyxx.png" alt="XYXX" loading="lazy" />
          <img src="/assets/brands/yufta.png" alt="Yufta" loading="lazy" />
        </div>
        <!-- Duplicate for continuous scroll -->
        <div class="client-marquee__list" aria-hidden="true">
          <img src="/assets/brands/Banno.png" alt="" loading="lazy" />
          <img src="/assets/brands/DBJ.png" alt="" loading="lazy" />
          <img src="/assets/brands/GANGA ONG.png" alt="" loading="lazy" />
          <img src="/assets/brands/INDO ERA PNG.png" alt="" loading="lazy" />
          <img src="/assets/brands/JANASYA.png" alt="" loading="lazy" />
          <img src="/assets/brands/JUGO.png" alt="" loading="lazy" />
          <img src="/assets/brands/STF.png" alt="" loading="lazy" />
          <img src="/assets/brands/leemboodi.png" alt="" loading="lazy" />
          <img src="/assets/brands/skylee.png" alt="" loading="lazy" />
          <img src="/assets/brands/xyxx.png" alt="" loading="lazy" />
          <img src="/assets/brands/yufta.png" alt="" loading="lazy" />
        </div>
      </div>
    </div>
    </section>

    <div class="showcase-services-scene" data-showcase-services-scene>
      <div class="showcase-services-scene__viewport" data-showcase-services-viewport>
    <!-- Services Showcase V3 -->
    <section class="sc3" id="showcase">
      <div class="container sc3__shell">
        <!-- Vertical Editorial Category Nav -->
        <nav class="sc3__nav" aria-label="Service categories">
          <ul class="sc3__nav-list">
            <li><button class="sc3__nav-item active" data-category="ethnic"><span class="sc3__nav-text">Ethnic</span></button></li>
            <li><button class="sc3__nav-item" data-category="saree"><span class="sc3__nav-text">Saree</span></button></li>
            <li><button class="sc3__nav-item" data-category="westernwear"><span class="sc3__nav-text">Westernwear</span></button></li>
            <li><button class="sc3__nav-item" data-category="menswear"><span class="sc3__nav-text">Menswear</span></button></li>
            <li><button class="sc3__nav-item" data-category="jewellery"><span class="sc3__nav-text">Jewellery</span></button></li>
            <li><button class="sc3__nav-item" data-category="product"><span class="sc3__nav-text">Product</span></button></li>
          </ul>
        </nav>

        <!-- Content Stage -->
        <div class="sc3__stage">
          <!-- westernwear -->
          <div class="sc3__panel" data-panel="westernwear">
            <div class="sc3__mobile-stage">
              <div class="sc3__mobile-card sc3__mobile-card--before">
                <span class="sc3__mobile-bookmark sc3__mobile-bookmark--before">Before</span>
                <div class="sc3__mobile-card-frame">
                  <img src={westernwearShowcaseInput} alt="Westernwear raw garment input" loading="lazy" />
                </div>
              </div>
              <div class="sc3__mobile-card sc3__mobile-card--after">
                <span class="sc3__mobile-bookmark sc3__mobile-bookmark--after">After</span>
                <div class="sc3__mobile-card-frame sc3__mobile-card-frame--collage">
                  <div class="sc3__mobile-output-grid">
                    <div class="sc3__mobile-output sc3__mobile-output--tl"><img src={westernwearShowcaseOutput[1]} alt="Westernwear AI output 2" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--tr"><img src={westernwearShowcaseOutput[2]} alt="Westernwear AI output 3" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--bl"><img src={westernwearShowcaseOutput[0]} alt="Westernwear AI output 1" loading="lazy" /></div>
                    <div class="sc3__mobile-output sc3__mobile-output--br"><img src={westernwearShowcaseOutput[3]} alt="Westernwear AI output 4" loading="lazy" /></div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Left Input Block -->
            <div class="sc3__col sc3__col--left">
              <span class="sc3__label">Raw Garments</span>
              <div class="sc3__input-group sc3__input-group--single">
                <div class="sc3__input-main">
                  <img src={westernwearShowcaseInput} alt="Westernwear raw garment input" loading="lazy" />
                </div>
