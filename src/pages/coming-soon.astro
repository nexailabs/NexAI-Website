---
import Layout from '../layouts/Layout.astro';
import { bookingUrl } from '../data/home';
---

<Layout
	title="Coming Soon | NexAI Labs"
	description="Agent Lab, Prompt Hub, and App Vault — launching soon from NexAI Labs."
	mainClass="cs"
>
	<!-- Radial gradient background washes -->
	<div class="cs__bg" aria-hidden="true">
		<div class="cs__bg-glow cs__bg-glow--top"></div>
		<div class="cs__bg-glow cs__bg-glow--bottom"></div>
		<div class="cs__dot-grid"></div>
	</div>

	<div class="cs__inner">
		<!-- Pulsing star -->
		<div class="cs__star" aria-hidden="true">
			<div class="cs__star-ring cs__star-ring--3"></div>
			<div class="cs__star-ring cs__star-ring--2"></div>
			<div class="cs__star-ring cs__star-ring--1"></div>
			<div class="cs__star-core"></div>
		</div>

		<!-- Eyebrow pill -->
		<span class="tag-pill">IN THE PIPELINE</span>

		<!-- Headline -->
		<h1 class="cs__heading">
			Something's<br /><em>Brewing</em>
		</h1>

		<!-- Subtext -->
		<p class="cs__sub">
			We're building the next layer of the NexAI stack.<br />
			Early access opens soon — get in before the queue.
		</p>

		<!-- Product chips -->
		<div class="cs__products" aria-label="Upcoming products">
			<span class="cs__chip">Agent Lab</span>
			<span class="cs__chip">Prompt Hub</span>
			<span class="cs__chip">App Vault</span>
		</div>

		<!-- CTAs -->
		<div class="cs__ctas">
			<a
				href={bookingUrl}
				class="cs__cta cs__cta--primary"
				data-cal-link="rahul-juneja/15min"
				data-cal-config='{"layout":"month_view"}'
			>
				Get Early Access
			</a>
			<a href="/" class="cs__cta cs__cta--ghost"> Back to Home </a>
		</div>
	</div>
</Layout>

<style>
	/* ── Page wrapper ── */
	.cs {
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--header-height, 5.9rem) var(--space-sm) var(--space-lg);
		position: relative;
		overflow: hidden;
		background: var(--color-bg);
	}

	/* ── Background layer ── */
	.cs__bg {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.cs__bg-glow {
		position: absolute;
		border-radius: 50%;
	}

	.cs__bg-glow--top {
		top: -10%;
		left: 50%;
		transform: translateX(-50%);
		width: 80vw;
		height: 60vh;
		background: radial-gradient(ellipse at 50% 0%, rgba(30, 126, 114, 0.14) 0%, transparent 60%);
	}

	.cs__bg-glow--bottom {
		bottom: -15%;
		left: 50%;
		transform: translateX(-50%);
		width: 60vw;
		height: 50vh;
		background: radial-gradient(ellipse at 50% 100%, rgba(78, 201, 180, 0.07) 0%, transparent 60%);
	}

	.cs__dot-grid {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 28px 28px;
		mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
	}

	/* ── Center content ── */
	.cs__inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.75rem;
		max-width: 580px;
		width: 100%;
	}

	/* ── Pulsing star ── */
	.cs__star {
		position: relative;
		width: 80px;
		height: 80px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.cs__star-core {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.92);
		box-shadow:
			0 0 8px 3px rgba(78, 201, 180, 0.6),
			0 0 25px 8px rgba(78, 201, 180, 0.3),
			0 0 60px 15px rgba(78, 201, 180, 0.1);
		animation: star-breathe 3s ease-in-out infinite;
		position: relative;
		z-index: 2;
	}

	.cs__star-ring {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) scale(1);
		border-radius: 50%;
		border: 1px solid rgba(78, 201, 180, 0.35);
		animation: star-pulse 3s ease-out infinite;
	}

	.cs__star-ring--1 {
		width: 28px;
		height: 28px;
		animation-delay: 0s;
	}

	.cs__star-ring--2 {
		width: 50px;
		height: 50px;
		animation-delay: 0.6s;
		border-color: rgba(78, 201, 180, 0.2);
	}

	.cs__star-ring--3 {
		width: 78px;
		height: 78px;
		animation-delay: 1.2s;
		border-color: rgba(78, 201, 180, 0.1);
	}

	@keyframes star-breathe {
		0%,
		100% {
			box-shadow:
				0 0 8px 3px rgba(78, 201, 180, 0.6),
				0 0 25px 8px rgba(78, 201, 180, 0.3),
				0 0 60px 15px rgba(78, 201, 180, 0.1);
		}
		50% {
			box-shadow:
				0 0 12px 5px rgba(78, 201, 180, 0.8),
				0 0 35px 12px rgba(78, 201, 180, 0.4),
				0 0 80px 20px rgba(78, 201, 180, 0.15);
		}
	}

	@keyframes star-pulse {
		0% {
			transform: translate(-50%, -50%) scale(1);
			opacity: 0.8;
		}
		100% {
			transform: translate(-50%, -50%) scale(1.6);
			opacity: 0;
		}
	}

	/* ── Heading ── */
	.cs__heading {
		font-family: var(--font-accent);
		font-size: clamp(3.5rem, 10vw, 6.5rem);
		font-weight: var(--fw-semibold);
		line-height: 1.05;
		color: var(--color-text-main);
		letter-spacing: -0.02em;
	}

	.cs__heading em {
		font-style: italic;
		background: var(--color-brand-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* ── Subtext ── */
	.cs__sub {
		font-family: var(--font-main);
		font-size: clamp(0.95rem, 1.2vw, 1.05rem);
		line-height: var(--lh-body);
		color: var(--color-text-muted);
		max-width: 440px;
	}

	/* ── Product chips ── */
	.cs__products {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.cs__chip {
		font-family: var(--font-main);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.08em;
		color: var(--color-text-subtle);
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	/* ── CTAs ── */
	.cs__ctas {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding-top: 0.25rem;
	}

	.cs__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		font-family: var(--font-main);
		font-size: var(--text-btn);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-decoration: none;
		transition:
			background 0.3s var(--ease-out-expo),
			border-color 0.3s var(--ease-out-expo),
			color 0.3s var(--ease-out-expo),
			transform 0.3s var(--ease-out-expo);
	}

	.cs__cta:active {
		transform: scale(0.97);
	}

	.cs__cta--primary {
		background: var(--color-text-main);
		color: var(--color-bg);
		border: 1px solid var(--color-text-main);
	}

	.cs__cta--primary:hover {
		background: rgba(255, 255, 255, 0.88);
		border-color: rgba(255, 255, 255, 0.88);
		transform: translateY(-1px);
	}

	.cs__cta--ghost {
		background: rgba(255, 255, 255, 0.03);
		color: var(--color-text-main);
		border: 1px solid var(--color-border);
	}

	.cs__cta--ghost:hover {
		border-color: var(--color-border-hover);
		background: rgba(255, 255, 255, 0.06);
		transform: translateY(-1px);
	}

	/* ── Mobile ── */
	@media (max-width: 720px) {
		.cs__dot-grid {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.cs {
			padding-top: calc(var(--header-height, 5.9rem) + 0.5rem);
		}

		.cs__ctas {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			max-width: 300px;
		}

		.cs__heading {
			font-size: clamp(3rem, 14vw, 4rem);
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.cs__star-core,
		.cs__star-ring {
			animation: none !important;
		}

		.cs__cta {
			transition: none !important;
		}
	}
</style>
