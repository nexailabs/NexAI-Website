---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
---

<Layout
	title="Coming Soon | NexAI Labs"
	description="Agent Lab and our booking page — live once they've been used by 10 teams."
	mainClass="cs"
	noFooter={true}
	noIndex
>
	<section class="cs__inner">
		<!-- Left: Text content -->
		<div class="cs__text">
			<p class="cs__eyebrow">Shipping next</p>
			<h1 class="cs__heading">Not ready to <em>ship.</em></h1>
			<p class="cs__sub">
				Agent Lab and our booking page go live once each one's been used by 10 teams in production.
				Drop your email and we'll send the link the day it lands.
			</p>

			<!-- Product chips -->
			<div class="cs__products" aria-label="Upcoming surfaces">
				<span class="cs__chip">Agent Lab</span>
				<span class="cs__chip">Catch Us</span>
			</div>

			<!-- CTAs -->
			<div class="cs__ctas">
				<a href={site.bookingUrl} class="cs__cta cs__cta--primary" data-open-cal>
					Tell me when it ships
				</a>
				<a href="/" class="cs__cta cs__cta--ghost">Back to Home</a>
			</div>
		</div>

		<!-- Right: Glow -->
		<div class="cs__star-area">
			<div class="cs__dot-grid" aria-hidden="true"></div>
			<div class="cs__glow" aria-hidden="true"></div>
		</div>
	</section>
</Layout>

<style>
	/* ── Page wrapper (main element lives in Layout.astro, needs :global) ── */
	:global(.cs) {
		min-height: 100svh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height, 5.9rem);
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(ellipse at 70% 40%, rgba(30, 126, 114, 0.12) 0%, transparent 55%),
			radial-gradient(ellipse at 20% 80%, rgba(78, 201, 180, 0.06) 0%, transparent 50%);
	}

	/* ── Grid layout ── */
	.cs__inner {
		width: 100%;
		max-width: 1400px;
		margin: 0 auto;
		padding: clamp(2rem, 5vh, 4rem) var(--space-sm);
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: clamp(2rem, 4vw, 4rem);
		position: relative;
		z-index: 1;
	}

	/* ── Left: Text ── */
	.cs__text {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.cs__eyebrow {
		font-family: var(--font-main);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-brand-cyan);
	}

	.cs__heading {
		font-family: var(--font-display);
		font-size: clamp(2rem, 3.8vw, 3.2rem);
		font-weight: var(--fw-semibold);
		line-height: var(--lh-heading);
		color: var(--color-text-main);
	}

	.cs__heading em {
		font-style: italic;
		background: var(--color-brand-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.cs__sub {
		font-family: var(--font-main);
		font-size: clamp(0.95rem, 1.2vw, 1.1rem);
		line-height: var(--lh-body);
		color: var(--color-text-muted);
		max-width: 480px;
	}

	/* ── Product chips ── */
	.cs__products {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.cs__chip {
		font-family: var(--font-main);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.08em;
		color: var(--color-text-subtle);
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	/* ── CTAs ── */
	.cs__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding-top: 0.5rem;
	}

	.cs__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		font-family: var(--font-main);
		font-size: var(--text-btn);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-decoration: none;
		transition:
			background 0.3s var(--ease-out-expo),
			border-color 0.3s var(--ease-out-expo),
			color 0.3s var(--ease-out-expo),
			transform 0.3s var(--ease-out-expo);
	}

	.cs__cta:active {
		transform: scale(0.97);
	}

	.cs__cta--primary {
		background: var(--color-text-main);
		color: var(--color-bg);
		border: 1px solid var(--color-text-main);
	}

	.cs__cta--primary:hover {
		background: rgba(255, 255, 255, 0.88);
		border-color: rgba(255, 255, 255, 0.88);
		transform: translateY(-1px);
	}

	.cs__cta--ghost {
		background: rgba(255, 255, 255, 0.03);
		color: var(--color-text-main);
		border: 1px solid var(--color-border);
	}

	.cs__cta--ghost:hover {
		border-color: var(--color-border-hover);
		background: rgba(255, 255, 255, 0.06);
		transform: translateY(-1px);
	}

	/* ── Right: Star area ── */
	.cs__star-area {
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		min-height: 400px;
		margin-left: -11rem;
		margin-top: -3rem;
	}

	.cs__dot-grid {
		position: absolute;
		inset: -15%;
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 28px 28px;
		mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, black 15%, transparent 75%);
		-webkit-mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, black 15%, transparent 75%);
		pointer-events: none;
		z-index: 0;
	}

	.cs__glow {
		position: relative;
		width: 120px;
		height: 120px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(255, 255, 255, 0.9) 0%,
			rgba(78, 201, 180, 0.4) 25%,
			rgba(78, 201, 180, 0.1) 55%,
			transparent 75%
		);
		will-change: opacity, transform;
		animation: csGlow 3s ease-in-out infinite;
	}

	@keyframes csGlow {
		0%,
		100% {
			opacity: 0.8;
			transform: scale(1);
		}
		50% {
			opacity: 1;
			transform: scale(1.08);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cs__glow {
			animation: none;
		}
	}

	/* ── Light mode overrides (page-specific) ── */
	:global(.cs--light) {
		background: #f5f5f5 !important;
		transition: background 0.6s ease;
	}

	:global(.cs--light) .cs__eyebrow {
		color: #0d7a6e;
	}

	:global(.cs--light) .cs__heading {
		color: #111;
	}

	:global(.cs--light) .cs__heading em {
		-webkit-text-fill-color: #111;
		color: #111;
		background: none;
	}

	:global(.cs--light) .cs__sub {
		color: #555;
	}

	:global(.cs--light) .cs__chip {
		color: #555;
		border-color: rgba(0, 0, 0, 0.15);
		background: rgba(0, 0, 0, 0.03);
	}

	:global(.cs--light) .cs__cta--primary {
		background: #111;
		color: #fff;
		border-color: #111;
	}

	:global(.cs--light) .cs__cta--ghost {
		color: #111;
		border-color: rgba(0, 0, 0, 0.25);
	}

	:global(.cs--light) .cs__cta--ghost:hover {
		border-color: #111;
		background: rgba(0, 0, 0, 0.04);
	}

	:global(.cs--light) .cs__dot-grid {
		background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 1px, transparent 1px);
	}

	/* ── Mobile ── */
	@media (max-width: 900px) {
		.cs__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.cs__text {
			align-items: center;
		}

		.cs__products {
			justify-content: center;
		}

		.cs__ctas {
			justify-content: center;
		}

		.cs__star-area {
			order: -1;
			min-height: 280px;
		}
	}

	@media (max-width: 720px) {
		.cs__dot-grid {
			display: none;
		}

		.cs__heading {
			font-size: clamp(2rem, 8vw, 2.8rem);
		}

		.cs__ctas {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			max-width: 320px;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.cs__cta {
			transition: none !important;
		}
	}
</style>
