---
import Layout from '../../layouts/Layout.astro';
import StudioHero from '../../components/StudioHero.astro';
import ClientMarquee from '../../components/ClientMarquee.astro';
import StudioShowcase from '../../components/StudioShowcase.astro';
import StudioCTA from '../../components/StudioCTA.astro';
import StudioProcess from '../../components/StudioProcess.astro';
import StudioFAQ from '../../components/StudioFAQ.astro';
import { heroDecks, brandLogos, showcaseCategories, ctaFloats } from '../../data/studio';
import { processSteps, faqItems } from '../../data/studio-copy';
import { site } from '../../config/site';
import { tr } from '../../config/imagekit';

const heroBase = heroDecks[0][0].src.replace(tr.hero, '');
const heroPreloadSrcset = [
	`${heroBase}?tr=w-400,h-533,fo-auto,f-auto,q-80 400w`,
	`${heroBase}?tr=w-600,h-800,fo-auto,f-auto,q-80 600w`,
	`${heroBase}?tr=w-900,h-1200,fo-auto,f-auto,q-80 900w`,
].join(', ');
---

<Layout
	title="AI Photoshoots for Fashion Brands | NexAI Labs"
	description="Turn mannequin shots into on-model photos in 3-5 days. 80% cheaper than studios. Trusted by 50+ Indian fashion brands."
	ogImage="https://ik.imagekit.io/nexailabs/nexai/og/ai-shoots.png?tr=w-1200,h-630,fo-auto,f-auto,q-85"
	mainClass="shoots-page"
>
	<link
		slot="head"
		rel="preload"
		as="image"
		href={heroDecks[0][0].src}
		imagesrcset={heroPreloadSrcset}
		imagesizes="(max-width: 720px) 60vw, 18vw"
	/>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@graph': [
				{
					'@type': 'WebSite',
					'@id': `${site.url}/#website`,
					url: site.url,
					name: site.name,
					publisher: { '@id': `${site.url}/#org` },
				},
				{
					'@type': 'Organization',
					'@id': `${site.url}/#org`,
					name: site.name,
					url: site.url,
					logo: 'https://ik.imagekit.io/nexailabs/nexai/og/default.png?tr=w-1200,h-630,fo-auto,f-auto,q-85',
					description: site.description,
					email: site.email,
					sameAs: [
						'https://www.linkedin.com/company/nexailabs',
						'https://www.instagram.com/nexailabs',
						'https://www.youtube.com/@nexailabs',
					],
				},
				{
					'@type': 'WebPage',
					'@id': `${site.url}/studio/`,
					url: `${site.url}/studio/`,
					name: 'AI Photoshoots for Fashion Brands | NexAI Labs',
					description: 'AI-generated fashion photoshoots for D2C brands.',
					isPartOf: { '@id': `${site.url}/#website` },
					about: { '@id': `${site.url}/studio/#service` },
				},
				{
					'@type': 'Service',
					'@id': `${site.url}/studio/#service`,
					name: 'AI Fashion Photography',
					description: 'AI photoshoots for fashion and D2C brands.',
					provider: { '@id': `${site.url}/#org` },
					serviceType: 'AI Photography',
				},
				{
					'@type': 'FAQPage',
					'@id': `${site.url}/studio/#faq`,
					mainEntity: faqItems.map((item) => ({
						'@type': 'Question',
						name: item.question,
						acceptedAnswer: { '@type': 'Answer', text: item.answer },
					})),
				},
			],
		})}
	/>

	<section class="shoots-hero" id="top">
		<StudioHero decks={heroDecks} />
		<ClientMarquee brands={brandLogos} />
	</section>

	<StudioShowcase categories={showcaseCategories} />
	<StudioProcess steps={processSteps} />
	<div class="faq-cta-zone">
		<div class="faq-cta-zone__sticky-scope">
			<!-- Sticky floating images — stay in viewport while FAQ+CTA scroll past -->
			<div class="faq-cta-zone__floats" aria-hidden="true">
				<img
					class="faq-cta-zone__float faq-cta-zone__float--1"
					src={ctaFloats[0].src}
					alt=""
					width="140"
					height="187"
					loading="lazy"
					decoding="async"
				/>
				<img
					class="faq-cta-zone__float faq-cta-zone__float--2"
					src={ctaFloats[1].src}
					alt=""
					width="150"
					height="200"
					loading="lazy"
					decoding="async"
				/>
				<img
					class="faq-cta-zone__float faq-cta-zone__float--3"
					src={ctaFloats[2].src}
					alt=""
					width="130"
					height="173"
					loading="lazy"
					decoding="async"
				/>
				<img
					class="faq-cta-zone__float faq-cta-zone__float--4"
					src={ctaFloats[3].src}
					alt=""
					width="120"
					height="160"
					loading="lazy"
					decoding="async"
				/>
				<img
					class="faq-cta-zone__float faq-cta-zone__float--5"
					src={ctaFloats[4].src}
					alt=""
					width="125"
					height="167"
					loading="lazy"
					decoding="async"
				/>
				<img
					class="faq-cta-zone__float faq-cta-zone__float--6"
					src={ctaFloats[5].src}
					alt=""
					width="140"
					height="187"
					loading="lazy"
					decoding="async"
				/>
			</div>
			<StudioFAQ items={faqItems} />
			<StudioCTA floats={ctaFloats} />
		</div>
	</div>
</Layout>

<style>
	.shoots-page {
		min-height: 100svh;
		overflow-x: hidden;
		background:
			radial-gradient(circle at 50% 38%, rgba(34, 75, 66, 0.2), transparent 30%),
			linear-gradient(180deg, #0b1110 0%, #09100f 100%);
	}

	.shoots-hero {
		--shoots-marquee-space: 5.75rem;
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding-top: calc(var(--header-height, 5rem) + 1rem);
		padding-bottom: var(--shoots-marquee-space);
		box-sizing: border-box;
		overflow-x: clip;
		overflow-y: visible;
	}

	@media (max-width: 720px) {
		.shoots-hero {
			--shoots-marquee-space: 5.75rem;
			padding-top: calc(var(--header-height, 5rem) + 0.5rem);
		}
	}

	/* ── FAQ + CTA shared float zone ── */
	.faq-cta-zone {
		position: relative;
		z-index: 1;
		margin-top: clamp(5rem, 10vh, 8rem);
	}

	.faq-cta-zone__sticky-scope {
		position: relative;
	}

	/* Float container — JS toggles between fixed (pinned) and absolute (locked) */
	.faq-cta-zone__floats {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100svh;
		pointer-events: none;
		z-index: 1;
	}

	.faq-cta-zone__floats--fixed {
		position: fixed;
	}

	.faq-cta-zone__floats--bottom {
		position: absolute;
		top: auto;
		bottom: 0;
	}

	.faq-cta-zone__float {
		position: absolute;
		border-radius: 12px;
		object-fit: cover;
		box-shadow:
			0 8px 32px rgba(0, 0, 0, 0.4),
			0 0 0 1px rgba(255, 255, 255, 0.06);
		animation: zone-float 7s ease-in-out infinite;
	}

	/* Left cluster — 3 images stacked */
	.faq-cta-zone__float--1 {
		width: clamp(90px, 10vw, 140px);
		aspect-ratio: 3/4;
		top: 12%;
		left: 9%;
		transform: rotate(-5deg);
		animation-delay: 0s;
	}

	.faq-cta-zone__float--3 {
		width: clamp(80px, 9vw, 130px);
		aspect-ratio: 3/4;
		top: 40%;
		left: 8%;
		transform: rotate(3deg);
		animation-delay: -2.5s;
	}

	.faq-cta-zone__float--5 {
		width: clamp(85px, 9vw, 125px);
		aspect-ratio: 3/4;
		top: 65%;
		left: 10%;
		transform: rotate(-2deg);
		animation-delay: -5s;
	}

	/* Right cluster — 3 images stacked */
	.faq-cta-zone__float--2 {
		width: clamp(95px, 11vw, 150px);
		aspect-ratio: 3/4;
		top: 10%;
		right: 9%;
		transform: rotate(4deg);
		animation-delay: -1.2s;
	}

	.faq-cta-zone__float--4 {
		width: clamp(80px, 9vw, 120px);
		aspect-ratio: 3/4;
		top: 38%;
		right: 8%;
		transform: rotate(-4deg);
		animation-delay: -3.8s;
	}

	.faq-cta-zone__float--6 {
		width: clamp(90px, 10vw, 140px);
		aspect-ratio: 3/4;
		top: 63%;
		right: 10%;
		transform: rotate(3deg);
		animation-delay: -1.8s;
	}

	@keyframes zone-float {
		0%,
		100% {
			translate: 0 0;
		}
		50% {
			translate: 0 -10px;
		}
	}

	/* Hide floats on mobile */
	@media (max-width: 720px) {
		.faq-cta-zone__floats {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.faq-cta-zone__float {
			animation: none;
		}
	}
</style>

<script>
	function initFloats() {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const scope = document.querySelector<HTMLElement>('.faq-cta-zone__sticky-scope');
		const floats = document.querySelector<HTMLElement>('.faq-cta-zone__floats');
		if (!scope || !floats) return;

		let ticking = false;
		let active = false;

		function update() {
			const rect = scope.getBoundingClientRect();

			if (rect.top <= 0 && rect.bottom >= window.innerHeight) {
				floats.classList.add('faq-cta-zone__floats--fixed');
				floats.classList.remove('faq-cta-zone__floats--bottom');
			} else if (rect.top <= 0 && rect.bottom < window.innerHeight) {
				floats.classList.remove('faq-cta-zone__floats--fixed');
				floats.classList.add('faq-cta-zone__floats--bottom');
			} else {
				floats.classList.remove('faq-cta-zone__floats--fixed');
				floats.classList.remove('faq-cta-zone__floats--bottom');
			}

			ticking = false;
		}

		function onScroll() {
			if (!ticking) {
				requestAnimationFrame(update);
				ticking = true;
			}
		}

		function activate() {
			if (active) return;
			active = true;
			window.addEventListener('scroll', onScroll, { passive: true });
			update();
		}

		function deactivate() {
			if (!active) return;
			active = false;
			window.removeEventListener('scroll', onScroll);
			floats.classList.remove('faq-cta-zone__floats--fixed');
			floats.classList.remove('faq-cta-zone__floats--bottom');
		}

		function onResize() {
			if (window.innerWidth > 720) {
				activate();
				update();
			} else {
				deactivate();
			}
		}

		// Initial activation based on viewport
		if (window.innerWidth > 720) activate();

		window.addEventListener('resize', onResize, { passive: true });

		document.addEventListener(
			'astro:before-swap',
			() => {
				deactivate();
				window.removeEventListener('resize', onResize);
			},
			{ once: true },
		);
	}

	document.addEventListener('astro:page-load', initFloats);
</script>
