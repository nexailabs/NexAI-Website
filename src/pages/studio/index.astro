---
import Layout from '../../layouts/Layout.astro';
import ShootsHero from '../../components/ShootsHero.astro';
import ClientMarquee from '../../components/ClientMarquee.astro';
import ShowcaseV3 from '../../components/ShowcaseV3.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import { heroDecks, brandLogos, showcaseCategories, serviceCards } from '../../data/ai-shoots';
import { site } from '../../config/site';
---

<Layout
	title="AI Photoshoots for Fashion Brands | NexAI Labs"
	description="Premium AI fashion photography for D2C brands."
	ogImage="https://ik.imagekit.io/nexailabs/nexai/og/ai-shoots.png?tr=w-1200,h-630,fo-auto,f-auto,q-85"
	mainClass="shoots-page"
>
	<link slot="head" rel="preload" as="image" href={heroDecks[0][heroDecks[0].length - 1].src} />
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'Organization',
			name: site.name,
			url: site.url,
			logo: 'https://ik.imagekit.io/nexailabs/nexai/og/default.png?tr=w-1200,h-630,fo-auto,f-auto,q-85',
			description: site.description,
			email: site.email,
			sameAs: [],
		})}
	/>

	<section class="shoots-hero" id="top">
		<ShootsHero decks={heroDecks} />
		<ClientMarquee brands={brandLogos} />
	</section>

	<ShowcaseV3 categories={showcaseCategories} />

	<ServicesGrid
		eyebrow="AI Photoshoot Services"
		heading="Transform your fashion brand with AI-powered visuals"
		subheading="We create premium on-model imagery that accelerates your collection launches while reducing production costs and time-to-market."
		cards={serviceCards}
		class="reveal-up"
	/>
</Layout>

<style>
	.shoots-page {
		min-height: 100svh;
		overflow-x: hidden;
		background:
			radial-gradient(circle at 50% 38%, rgba(34, 75, 66, 0.2), transparent 30%),
			linear-gradient(180deg, #0b1110 0%, #09100f 100%);
	}

	.shoots-hero {
		--shoots-marquee-space: 5.75rem;
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding-top: calc(var(--header-height, 5rem) + 1rem);
		padding-bottom: var(--shoots-marquee-space);
		box-sizing: border-box;
		overflow-x: clip;
		overflow-y: visible;
	}

	@media (max-width: 720px) {
		.shoots-hero {
			--shoots-marquee-space: 5.75rem;
			padding-top: calc(var(--header-height, 5rem) + 0.5rem);
		}
	}
</style>
