---
import Layout from '../../layouts/Layout.astro';
import StudioCTA from '../../components/StudioCTA.astro';
import { galleryItems, galleryCategories } from '../../data/gallery';
import { ctaFloats } from '../../data/studio';
import { site } from '../../config/site';
---

<Layout
	title="Gallery | NexAI Studio — AI Fashion Photography"
	description="Browse AI-generated fashion photography across kurta sets, sarees, western wear, menswear, jewelry, and cosmetics. Real brands, real results."
>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'CollectionPage',
			name: 'Gallery | NexAI Studio',
			description: 'AI-generated fashion photography portfolio',
			url: `${site.url}/studio/gallery`,
			isPartOf: { '@id': `${site.url}/#website` },
		})}
	/>
	<section class="gallery">
		<div class="container gallery__inner">
			<header class="section-header gallery__header">
				<h1 class="section-title">Our <em>Work</em></h1>
				<p class="section-sub">Real brands, real shoots. Browse by category.</p>
			</header>

			<!-- Filters -->
			<div class="gallery__filters">
				<div class="gallery__filter-row" data-gallery-filter="category">
					{
						galleryCategories.map((cat) => (
							<button
								class:list={[
									'gallery__filter-btn',
									{ 'gallery__filter-btn--active': cat.id === 'all' },
								]}
								data-filter-value={cat.id}
								aria-pressed={cat.id === 'all' ? 'true' : 'false'}
							>
								{cat.label}
							</button>
						))
					}
				</div>
			</div>

			<!-- Masonry grid -->
			<div class="gallery__grid" data-gallery-grid>
				{
					galleryItems.map((item) => (
						<div
							class="gallery__item"
							data-gallery-item
							data-category={item.category}
							data-type={item.type}
						>
							<img
								class="gallery__img"
								src={item.src}
								alt={item.alt}
								loading="lazy"
								decoding="async"
							/>
						</div>
					))
				}
			</div>

			<StudioCTA floats={ctaFloats} />
		</div>
	</section>
</Layout>

<style>
	.gallery {
		padding: calc(var(--header-height, 5rem) + 2rem) 0 0;
		min-height: 100vh;
	}

	.gallery__inner {
		display: flex;
		flex-direction: column;
		gap: clamp(1.25rem, 2.5vh, 2rem);
	}

	.gallery__header {
		margin-bottom: 0;
	}

	/* ── Filters ── */
	.gallery__filters {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: center;
		margin-bottom: clamp(0.5rem, 1.5vh, 1rem);
	}

	.gallery__filter-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.gallery__filter-btn {
		padding: 0.5rem 1.2rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.03);
		color: var(--color-text-muted);
		font-family: var(--font-main);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		cursor: pointer;
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.gallery__filter-btn:hover {
		color: var(--color-text-main);
		border-color: var(--color-border-hover);
	}

	.gallery__filter-btn--active {
		color: var(--color-text-main);
		border-color: var(--color-brand-cyan);
		background: rgba(78, 201, 180, 0.1);
	}

	/* ── Masonry grid — always 4 columns ── */
	.gallery__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-rows: 1px;
		column-gap: 1rem;
	}

	.gallery__item {
		overflow: hidden;
	}

	.gallery__img {
		width: 100%;
		display: block;
		border-radius: 10px;
	}

	/* ── Tablet ── */
	@media (max-width: 1100px) {
		.gallery__grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* ── Mobile ── */
	@media (max-width: 720px) {
		.gallery__grid {
			grid-template-columns: repeat(2, 1fr);
			column-gap: 0.75rem;
		}

		.gallery__img {
			border-radius: 8px;
		}

		.gallery__filter-btn {
			font-size: var(--text-xs);
			padding: 0.4rem 0.9rem;
		}
	}
</style>

<script>
	function initGallery() {
		const ROW_GAP = 16; // px gap between masonry items
		const grid = document.querySelector<HTMLElement>('[data-gallery-grid]');
		const items = Array.from(document.querySelectorAll<HTMLElement>('[data-gallery-item]'));
		const categoryBtns = document.querySelectorAll<HTMLButtonElement>(
			'[data-gallery-filter="category"] [data-filter-value]',
		);

		if (!grid || !items.length) return;

		let activeCategory = 'all';

		/* Measure each image and set grid-row-end span for masonry packing */
		function layoutMasonry() {
			const rowH = 1; // grid-auto-rows: 1px
			grid.querySelectorAll<HTMLElement>('[data-gallery-item]').forEach((item) => {
				// Reset span so we can measure natural height
				item.style.gridRowEnd = '';
				const img = item.querySelector<HTMLImageElement>('.gallery__img');
				if (!img) return;
				const h = img.getBoundingClientRect().height;
				if (h > 0) {
					item.style.gridRowEnd = `span ${Math.ceil((h + ROW_GAP) / (rowH + 0))}`;
				}
			});
		}

		/* Wait for all visible images to load, then run layout */
		function layoutAfterImages() {
			const visibleImgs = Array.from(grid.querySelectorAll<HTMLImageElement>('.gallery__img'));
			let pending = 0;

			visibleImgs.forEach((img) => {
				if (img.complete) return;
				pending++;
				img.addEventListener(
					'load',
					() => {
						pending--;
						if (pending === 0) layoutMasonry();
					},
					{ once: true },
				);
			});

			// Run immediately for already-loaded images
			layoutMasonry();
		}

		/* Filter: remove hidden items from DOM, re-append visible ones */
		function applyFilters() {
			const frag = document.createDocumentFragment();
			items.forEach((item) => {
				const cat = item.dataset.category || '';
				if (activeCategory === 'all' || cat === activeCategory) {
					frag.appendChild(item);
				} else {
					item.remove();
				}
			});
			grid.appendChild(frag);
			layoutAfterImages();
		}

		categoryBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				activeCategory = btn.dataset.filterValue || 'all';

				categoryBtns.forEach((b) => {
					b.classList.remove('gallery__filter-btn--active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('gallery__filter-btn--active');
				btn.setAttribute('aria-pressed', 'true');

				applyFilters();
			});
		});

		// Initial layout
		layoutAfterImages();

		// Re-layout on resize
		let resizeTimer: number;
		window.addEventListener('resize', () => {
			clearTimeout(resizeTimer);
			resizeTimer = window.setTimeout(layoutMasonry, 150);
		});
	}

	document.addEventListener('astro:page-load', initGallery);
</script>
