---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="404: Page Not Found | NexAI Labs"
	description="The page you were looking for does not exist."
	mainClass="not-found"
	noIndex
>
	<div class="not-found__inner">
		<span class="not-found__code">404</span>
		<h1 class="not-found__heading">Page not found</h1>
		<p class="not-found__body">The page you're looking for doesn't exist or has been moved.</p>
		<a href="/" class="btn-ghost">Back to home</a>
	</div>
</Layout>

<style>
	.not-found {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-lg) var(--space-sm);
		background: var(--gradient-hero);
	}

	.not-found__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--space-md);
		max-width: 480px;
	}

	.not-found__code {
		font-size: clamp(6rem, 20vw, 10rem);
		font-weight: 800;
		line-height: 1;
		background: var(--color-brand-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.04em;
	}

	.not-found__heading {
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 600;
		color: var(--color-text-main);
		letter-spacing: -0.02em;
	}

	.not-found__body {
		font-size: 1rem;
		color: var(--color-text-muted);
		line-height: 1.6;
	}

	/* .btn-ghost from global.css */
</style>
