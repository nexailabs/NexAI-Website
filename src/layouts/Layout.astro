---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	showNavbar?: boolean;
}

const {
	title,
	description = 'NexAI Labs - Business Growth on Autopilot',
	showNavbar = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- View Transitions -->
		<ClientRouter />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=Inter:wght@400;600;800&display=swap"
			rel="stylesheet"
		/>
		<slot name="head" />
	</head>
	<body>
		{showNavbar && <Navbar />}
		<slot />

		<!-- Global Scripts -->
		<script src="../scripts/lenis.ts"></script>
	</body>
</html>
