---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { navConfigs } from '../config/navigation';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	canonicalUrl?: string;
	mainClass?: string;
}

const {
	title,
	description = 'Building AI Agents for Businesses',
	ogImage = 'https://ik.imagekit.io/nexailabs/nexai/og/default.png?tr=w-1200,h-630,fo-auto,f-auto,q-85',
	canonicalUrl,
	mainClass,
} = Astro.props;

const section = Astro.url.pathname.split('/')[1] || 'main';
const navConfig = navConfigs[section] ?? navConfigs.main;

const resolvedCanonical = canonicalUrl || Astro.url.href;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO -->
		<link rel="canonical" href={resolvedCanonical} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta property="og:image:alt" content={description} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta property="og:site_name" content="NexAI Labs" />
		<meta property="og:locale" content="en_IN" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		<meta name="twitter:image:alt" content={description} />

		<!-- View Transitions -->
		<ClientRouter />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=Inter:wght@400;600;800&family=Montserrat:wght@600;700&display=swap"
			rel="stylesheet"
		/>
		<slot name="head" />
	</head>
	<body>
		<a class="skip-to-content" href="#main-content">Skip to content</a>
		<slot name="navbar">
			<Navbar
				navGroups={navConfig.navGroups}
				topHref={navConfig.topHref}
				brandAriaLabel={navConfig.brandAriaLabel}
				socials={navConfig.socials}
			/>
		</slot>
		<div data-page-content>
			<CustomCursor />
			<main id="main-content" class={mainClass} tabindex="-1">
				<slot />
			</main>
		</div>

		<!-- Global Scripts -->
		<script src="../scripts/lenis.ts"></script>
	</body>
</html>
