---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Footer from '../components/Footer.astro';
import { navConfigs } from '../config/navigation';
import '../styles/global.css';

// Self-hosted fonts (replaces Google Fonts CDN)
import '@fontsource/cormorant-garamond/latin-600.css';
import '@fontsource/cormorant-garamond/latin-600-italic.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-800.css';
import '@fontsource/montserrat/latin-600.css';
import '@fontsource/montserrat/latin-700.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	canonicalUrl?: string;
	mainClass?: string;
	noFooter?: boolean;
}

const {
	title,
	description = 'Building AI Agents for Businesses',
	ogImage = 'https://ik.imagekit.io/nexailabs/nexai/og/default.png?tr=w-1200,h-630,fo-auto,f-auto,q-85',
	canonicalUrl,
	mainClass,
	noFooter = false,
} = Astro.props;

const section = Astro.url.pathname.split('/')[1] || 'main';
const navConfig = navConfigs[section] ?? navConfigs.main;

const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, Astro.site).href;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://ik.imagekit.io" crossorigin />
		<link rel="dns-prefetch" href="https://ik.imagekit.io" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO -->
		<link rel="canonical" href={resolvedCanonical} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={description} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta property="og:site_name" content="NexAI Labs" />
		<meta property="og:locale" content="en_IN" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@nexailabs" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		<meta name="twitter:image:alt" content={description} />

		<!-- View Transitions -->
		<ClientRouter />

		<!-- Fonts loaded via @fontsource (self-hosted, no external requests) -->
		<slot name="head" />
	</head>
	<body>
		<a class="skip-to-content" href="#main-content">Skip to content</a>
		<slot name="navbar">
			<Navbar
				navGroups={navConfig.navGroups}
				topHref={navConfig.topHref}
				brandAriaLabel={navConfig.brandAriaLabel}
				socials={navConfig.socials}
			/>
		</slot>
		<div data-page-content>
			<CustomCursor />
			<main id="main-content" class={mainClass} tabindex="-1">
				<slot />
			</main>
			{!noFooter && <Footer />}
		</div>

		<!-- Global Scripts -->
		<script src="../scripts/lenis.ts"></script>

		<!-- Cal.com inline embed inside our own <dialog> -->
		<dialog id="cal-dialog" class="cal-dialog" aria-modal="true" aria-label="Book a call">
			<div class="cal-dialog__header">
				<button class="cal-dialog__back" aria-label="Close booking dialog">
					<svg
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg
					>
					Back
				</button>
			</div>
			<div class="cal-dialog__body" id="cal-inline"></div>
		</dialog>

		<script is:inline>
			/* eslint-disable prefer-rest-params */
			(function (C, A, L) {
				const p = function (a, ar) {
					a.q.push(ar);
				};
				const d = C.document;
				C.Cal =
					C.Cal ||
					function () {
						const cal = C.Cal;
						const ar = arguments;
						if (!cal.loaded) {
							cal.ns = {};
							cal.q = cal.q || [];
							d.head.appendChild(d.createElement('script')).src = A;
							cal.loaded = true;
						}
						if (ar[0] === L) {
							const api = function () {
								p(api, arguments);
							};
							const namespace = ar[1];
							api.q = api.q || [];
							if (typeof namespace === 'string') {
								cal.ns[namespace] = cal.ns[namespace] || api;
								p(cal.ns[namespace], ar);
								p(cal, ['initNamespace', namespace]);
							} else p(cal, ar);
							return;
						}
						p(cal, ar);
					};
			})(window, 'https://app.cal.com/embed/embed.js', 'init');

			function initCalInline() {
				const container = document.getElementById('cal-inline');
				if (!container || container.dataset.calReady) return;

				Cal('init', '15min', { origin: 'https://app.cal.com' });
				Cal.ns['15min']('inline', {
					elementOrSelector: '#cal-inline',
					config: { layout: 'month_view', useSlotsViewOnSmallScreen: 'true' },
					calLink: 'rahul-juneja/15min',
				});
				Cal.ns['15min']('ui', {
					hideEventTypeDetails: false,
					layout: 'month_view',
					cssVarsPerTheme: {
						dark: {
							'cal-bg': 'rgba(10,10,12,0.97)',
							'cal-bg-emphasis': '#18191b',
							'cal-text': '#ffffff',
							'cal-text-emphasis': '#ffffff',
							'cal-border-subtle': 'rgba(255,255,255,0.08)',
							'cal-border': 'rgba(255,255,255,0.1)',
							'cal-text-muted': 'rgba(255,255,255,0.6)',
							'cal-brand': '#4ec9b4',
							'cal-brand-emphasis': '#1e7e72',
						},
					},
				});
				container.dataset.calReady = '1';
			}
			initCalInline();
			document.addEventListener('astro:page-load', initCalInline);

			/* Open/close dialog on [data-open-cal] clicks — registered once */
			(function setupCalDialog() {
				const dialog = document.getElementById('cal-dialog');
				if (!dialog) return;

				/* Open: intercept all [data-open-cal] clicks */
				document.addEventListener('click', function (e) {
					const trigger = e.target.closest('[data-open-cal]');
					if (!trigger) return;
					e.preventDefault();
					e.stopPropagation();
					dialog.showModal();
					document.documentElement.classList.add('cal-modal-open');
				});

				/* Close: Back button */
				const backBtn = dialog.querySelector('.cal-dialog__back');
				if (backBtn) {
					backBtn.addEventListener('click', function () {
						dialog.close();
					});
				}

				/* Close: click on backdrop (outside the dialog box) */
				dialog.addEventListener('click', function (e) {
					if (e.target === dialog) dialog.close();
				});

				/* Cleanup on close */
				dialog.addEventListener('close', function () {
					document.documentElement.classList.remove('cal-modal-open');
				});
			})();
		</script>

		<style is:global>
			/* Scroll-lock when Cal dialog is open */
			html.cal-modal-open,
			html.cal-modal-open body {
				overflow: hidden !important;
			}

			/* Dialog — vertically + horizontally centered */
			.cal-dialog {
				border: none;
				background: transparent;
				padding: 0;
				position: fixed;
				inset: 0;
				margin: auto;
				max-width: 1100px;
				width: 94vw;
				height: fit-content;
				max-height: 94vh;
				overflow: visible;
				outline: none;
			}

			/* Dark backdrop */
			.cal-dialog::backdrop {
				background: rgba(5, 5, 7, 0.95);
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
			}

			/* Header with back button — aligned with card's left edge */
			.cal-dialog__header {
				display: flex;
				align-items: center;
				padding: 0 0 1.5rem 2rem;
			}

			/* Restore native cursor on dialog (custom cursor is below top layer) */
			.cal-dialog,
			.cal-dialog *,
			.cal-dialog::backdrop {
				cursor: auto !important;
			}

			.cal-dialog__back {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.05);
				color: rgba(255, 255, 255, 0.7);
				font-family: var(--font-main);
				font-size: 0.8rem;
				font-weight: var(--fw-semibold);
				letter-spacing: 0.04em;
				padding: 0.45rem 1rem 0.45rem 0.75rem;
				cursor: pointer;
				transition:
					border-color 0.2s ease,
					color 0.2s ease;
			}

			.cal-dialog__back:hover {
				border-color: rgba(255, 255, 255, 0.4);
				color: #fff;
			}

			.cal-dialog__back svg {
				flex-shrink: 0;
			}

			/* Inline embed container — tall enough to avoid scroll */
			.cal-dialog__body {
				width: 100%;
				min-height: 580px;
				border-radius: 12px;
				background: transparent;
				box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
			}

			/* Cal iframe fills the container */
			.cal-dialog__body iframe {
				border: none !important;
				border-radius: 12px;
				min-height: 580px;
				color-scheme: dark;
			}

			/* Kill any white background from Cal's embed wrapper */
			#cal-inline {
				background: transparent !important;
				color-scheme: dark;
			}

			#cal-inline > div {
				background: transparent !important;
			}

			@media (max-width: 720px) {
				.cal-dialog {
					width: 98vw;
				}

				.cal-dialog__body {
					min-height: 500px;
				}

				.cal-dialog__body iframe {
					min-height: 500px;
				}
			}
		</style>
	</body>
</html>
