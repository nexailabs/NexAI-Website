---
import { navLabLinks, navLabMeta } from '../../data/navLab';
---

<div class="split-nav" data-nav-demo data-nav-id="split-panel" data-open="false">
	<header class="split-nav__bar">
		<a class="split-nav__brand" href="#top">NexAI / Studio</a>
		<div class="split-nav__center">{navLabMeta.location}</div>
		<div class="split-nav__actions">
			<a href={navLabMeta.ctaHref} class="split-nav__cta" target="_blank" rel="noreferrer">{navLabMeta.ctaLabel}</a>
			<button class="split-nav__trigger" data-nav-trigger aria-expanded="false">
				<span>Menu</span>
				<i></i>
			</button>
		</div>
	</header>

	<div class="split-nav__panel" data-nav-panel aria-hidden="true">
		<div class="split-nav__panel-main">
			<nav>
				{
					navLabLinks.map((link) => (
						<a class="split-nav__item" href={link.href} data-nav-close>
							<span>{link.index}</span>
							<strong>{link.label}</strong>
						</a>
					))
				}
			</nav>
		</div>
		<aside class="split-nav__panel-side">
			<p>Menu overlays the work surface while the right rail keeps the conversion context alive.</p>
			<a href={navLabMeta.emailHref}>{navLabMeta.email}</a>
			<a href={navLabMeta.ctaHref} target="_blank" rel="noreferrer">{navLabMeta.ctaLabel}</a>
		</aside>
	</div>
</div>

<style>
	.split-nav {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 1rem 1.2rem 0;
	}

	.split-nav__bar {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		transition: all 0.3s ease;
	}

	.split-nav.is-scrolled .split-nav__bar {
		background: rgba(7, 8, 9, 0.68);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.35rem;
		padding: 1rem 1.2rem;
	}

	.split-nav__brand,
	.split-nav__center,
	.split-nav__cta,
	.split-nav__trigger,
	.split-nav__panel-side a,
	.split-nav__item {
		text-decoration: none;
		color: inherit;
	}

	.split-nav__brand,
	.split-nav__trigger,
	.split-nav__center {
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}

	.split-nav__center {
		justify-self: center;
		color: rgba(255, 255, 255, 0.48);
	}

	.split-nav__actions {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.split-nav__cta {
		padding: 0.75rem 1rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.split-nav__trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: transparent;
		border: 0;
		cursor: pointer;
	}

	.split-nav__trigger i,
	.split-nav__trigger i::before,
	.split-nav__trigger i::after {
		display: block;
		width: 1.2rem;
		height: 1px;
		background: currentColor;
		content: '';
	}

	.split-nav__trigger i {
		position: relative;
	}

	.split-nav__trigger i::before {
		position: absolute;
		top: -0.3rem;
	}

	.split-nav__trigger i::after {
		position: absolute;
		top: 0.3rem;
	}

	.split-nav__panel {
		position: absolute;
		inset: 0 1.2rem auto 1.2rem;
		top: 1rem;
		height: calc(100% - 1rem);
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
		border-radius: 1.7rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.94);
		backdrop-filter: blur(18px);
		opacity: 0;
		pointer-events: none;
		transform: translateX(-4%) scale(0.985);
		transform-origin: left center;
		transition: transform 0.44s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.28s ease;
	}

	.split-nav[data-open='true'] .split-nav__panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(0) scale(1);
	}

	.split-nav__panel-main {
		padding: 6rem 1.8rem 1.8rem;
		border-right: 1px solid rgba(255, 255, 255, 0.06);
	}

	.split-nav__item {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateX(-20px);
		transition: transform 0.34s ease, opacity 0.28s ease;
	}

	.split-nav[data-open='true'] .split-nav__item {
		opacity: 1;
		transform: translateX(0);
	}

	.split-nav[data-open='true'] .split-nav__item:nth-child(1) { transition-delay: 0.1s; }
	.split-nav[data-open='true'] .split-nav__item:nth-child(2) { transition-delay: 0.16s; }
	.split-nav[data-open='true'] .split-nav__item:nth-child(3) { transition-delay: 0.22s; }
	.split-nav[data-open='true'] .split-nav__item:nth-child(4) { transition-delay: 0.28s; }

	.split-nav__item span {
		color: rgba(255, 255, 255, 0.36);
	}

	.split-nav__item strong {
		font-size: clamp(2.5rem, 5vw, 4.1rem);
		font-weight: 600;
		transition:
			font-family 0.24s ease,
			color 0.24s ease,
			font-style 0.24s ease,
			letter-spacing 0.24s ease;
	}

	.split-nav__item:hover strong {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		letter-spacing: 0.03em;
		color: #ffffff;
	}

	.split-nav__panel-side {
		padding: 6rem 1.6rem 1.6rem;
		display: grid;
		align-content: end;
		gap: 1rem;
	}

	.split-nav__panel-side p,
	.split-nav__panel-side a:first-of-type {
		color: rgba(255, 255, 255, 0.62);
		line-height: 1.6;
	}

	.split-nav__panel-side a:last-of-type {
		display: inline-flex;
		justify-content: center;
		padding: 0.95rem 1rem;
		border-radius: 999px;
		background: #fff;
		color: #050607;
		font-weight: 600;
	}

	@media (max-width: 900px) {
		.split-nav__bar {
			grid-template-columns: auto auto;
			justify-content: space-between;
		}

		.split-nav__center {
			display: none;
		}

		.split-nav__cta {
			display: none;
		}

		.split-nav__panel {
			grid-template-columns: 1fr;
			inset: 0 1.2rem auto 1.2rem;
		}

		.split-nav__panel-main {
			border-right: 0;
			padding-bottom: 1rem;
		}

		.split-nav__panel-side {
			padding-top: 0;
			align-content: start;
		}
	}
</style>
