---
import { navLabLinks, navLabMeta } from '../../data/navLab';
---

<div class="obys-nav" data-nav-demo data-nav-id="obys" data-open="false">
	<header class="obys-nav__bar">
		<a class="obys-nav__brand" href="#top">NEXAI LABS</a>
		<a class="obys-nav__cta" href={navLabMeta.ctaHref} target="_blank" rel="noreferrer">{navLabMeta.ctaLabel}</a>
		<button class="obys-nav__trigger" data-nav-trigger aria-expanded="false">
			<span>Menu</span>
			<i></i>
		</button>
	</header>

	<div class="obys-nav__panel" data-nav-panel aria-hidden="true">
		<div class="obys-nav__backdrop-word">LABS</div>
		<div class="obys-nav__main">
			<nav>
				{
					navLabLinks.map((link) => (
						<a class="obys-nav__item" href={link.href} data-nav-close>
							<em>{link.index}</em>
							<strong>{link.label}</strong>
						</a>
					))
				}
			</nav>
			<div class="obys-nav__foot">
				<a href={navLabMeta.emailHref}>{navLabMeta.email}</a>
				<span>{navLabMeta.location}</span>
			</div>
		</div>
	</div>
</div>

<style>
	.obys-nav {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 1rem 1.2rem 0;
	}

	.obys-nav__bar {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.obys-nav__brand,
	.obys-nav__cta,
	.obys-nav__trigger,
	.obys-nav__foot a,
	.obys-nav__item {
		color: inherit;
		text-decoration: none;
	}

	.obys-nav__brand,
	.obys-nav__trigger {
		font-size: 0.86rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.obys-nav__cta {
		justify-self: center;
		color: rgba(255, 255, 255, 0.62);
		font-size: 0.84rem;
	}

	.obys-nav__trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		background: transparent;
		border: 0;
		cursor: pointer;
	}

	.obys-nav__trigger i,
	.obys-nav__trigger i::before {
		display: block;
		width: 1.25rem;
		height: 1px;
		background: currentColor;
		content: '';
	}

	.obys-nav__trigger i::before {
		transform: translateY(-0.32rem);
	}

	.obys-nav__panel {
		position: absolute;
		inset: 0 auto auto 0;
		width: min(42rem, calc(100% - 2.4rem));
		height: calc(100% - 1rem);
		padding: 5.8rem 1.2rem 1.2rem;
		opacity: 0;
		pointer-events: none;
		transform: translateX(-102%);
		transition: transform 0.52s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.26s ease;
	}

	.obys-nav[data-open='true'] .obys-nav__panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(0);
	}

	.obys-nav__main {
		position: relative;
		height: 100%;
		border-radius: 1.8rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(10, 7, 6, 0.94);
		backdrop-filter: blur(18px);
		padding: 1.5rem;
		display: grid;
		align-content: start;
		gap: 1rem;
		overflow: hidden;
	}

	.obys-nav__backdrop-word {
		position: absolute;
		inset: 3rem auto auto 1.6rem;
		font-size: clamp(6rem, 16vw, 12rem);
		font-family: 'Syne', sans-serif;
		font-weight: 800;
		line-height: 0.8;
		letter-spacing: -0.06em;
		color: rgba(255, 255, 255, 0.04);
		pointer-events: none;
	}

	.obys-nav__item {
		position: relative;
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateX(-26px);
		transition: transform 0.34s ease, opacity 0.28s ease;
	}

	.obys-nav[data-open='true'] .obys-nav__item {
		opacity: 1;
		transform: translateX(0);
	}

	.obys-nav[data-open='true'] .obys-nav__item:nth-child(1) { transition-delay: 0.08s; }
	.obys-nav[data-open='true'] .obys-nav__item:nth-child(2) { transition-delay: 0.15s; }
	.obys-nav[data-open='true'] .obys-nav__item:nth-child(3) { transition-delay: 0.22s; }
	.obys-nav[data-open='true'] .obys-nav__item:nth-child(4) { transition-delay: 0.29s; }

	.obys-nav__item em {
		font-style: normal;
		color: rgba(255, 255, 255, 0.34);
	}

	.obys-nav__item strong {
		font-size: clamp(3rem, 7vw, 5rem);
		line-height: 0.9;
		font-weight: 700;
		transition:
			font-family 0.24s ease,
			font-style 0.24s ease,
			transform 0.24s ease,
			color 0.24s ease;
	}

	.obys-nav__item:hover strong {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		transform: translateX(12px);
		color: #ffb388;
	}

	.obys-nav__foot {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 1.4rem;
		color: rgba(255, 255, 255, 0.52);
		font-size: 0.88rem;
	}

	@media (max-width: 900px) {
		.obys-nav__cta {
			display: none;
		}

		.obys-nav__panel {
			width: calc(100% - 2.4rem);
		}

		.obys-nav__foot {
			flex-direction: column;
		}
	}
</style>
