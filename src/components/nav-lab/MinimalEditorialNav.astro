---
import { navLabLinks, navLabMeta } from '../../data/navLab';
---

<div class="demo-nav demo-nav--editorial" data-nav-demo data-nav-id="editorial" data-open="false">
	<header class="demo-nav__bar">
		<a class="demo-nav__brand" href="#top">
			<img src="/assets/logo/nexai-logo-white.png" alt="NexAI Labs" width="166" height="40" />
		</a>

		<div class="demo-nav__rail">
			<a class="demo-nav__meta" href={navLabMeta.emailHref}>{navLabMeta.email}</a>
			<a class="demo-nav__cta" href={navLabMeta.ctaHref} target="_blank" rel="noreferrer">
				{navLabMeta.ctaLabel}
			</a>
			<button class="demo-nav__trigger" data-nav-trigger aria-expanded="false" aria-label="Open menu">
				<span>Index</span>
				<i></i>
			</button>
		</div>
	</header>

	<div class="demo-nav__panel" data-nav-panel aria-hidden="true">
		<div class="demo-nav__panel-inner">
			<p class="demo-nav__panel-label">Minimal Editorial Rail</p>
			<nav>
				{
					navLabLinks.map((link) => (
						<a class="demo-nav__item" href={link.href} data-nav-close>
							<em>{link.index}</em>
							<div>
								<strong>{link.label}</strong>
								<span>{link.caption}</span>
							</div>
						</a>
					))
				}
			</nav>
		</div>
	</div>
</div>

<style>
	.demo-nav {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 1.15rem;
	}

	.demo-nav__bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		transition: padding 0.25s ease, backdrop-filter 0.25s ease, background 0.25s ease;
	}

	.demo-nav.is-scrolled .demo-nav__bar {
		padding: 0.85rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.25rem;
		backdrop-filter: blur(16px);
		background: rgba(7, 8, 9, 0.66);
	}

	.demo-nav__brand img {
		height: 1.7rem;
		width: auto;
	}

	.demo-nav__rail {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.demo-nav__meta,
	.demo-nav__cta,
	.demo-nav__trigger,
	.demo-nav__item {
		text-decoration: none;
		color: inherit;
	}

	.demo-nav__meta,
	.demo-nav__trigger {
		font-size: 0.82rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.62);
	}

	.demo-nav__cta {
		padding: 0.8rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.04);
	}

	.demo-nav__trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		border: 0;
		background: transparent;
		cursor: pointer;
	}

	.demo-nav__trigger i {
		display: block;
		width: 2.5rem;
		height: 1px;
		background: currentColor;
		position: relative;
	}

	.demo-nav__trigger i::after {
		content: '';
		position: absolute;
		right: 0;
		top: -0.35rem;
		width: 1.2rem;
		height: 1px;
		background: currentColor;
	}

	.demo-nav__panel {
		position: absolute;
		inset: 0 auto auto 0;
		width: min(30rem, calc(100% - 2.3rem));
		height: calc(100% - 2.3rem);
		min-height: 30rem;
		padding: 6.2rem 1.15rem 1.15rem;
		opacity: 0;
		pointer-events: none;
		transform: translateX(-104%);
		transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
	}

	.demo-nav[data-open='true'] .demo-nav__panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(0);
	}

	.demo-nav__panel-inner {
		height: 100%;
		border-radius: 1.7rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.92);
		backdrop-filter: blur(18px);
		padding: 1.5rem;
		display: grid;
		align-content: start;
		gap: 1rem;
	}

	.demo-nav__panel-label {
		font-size: 0.74rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.4);
	}

	.demo-nav__item {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateX(-24px);
		transition: transform 0.38s ease, opacity 0.32s ease;
	}

	.demo-nav[data-open='true'] .demo-nav__item {
		opacity: 1;
		transform: translateX(0);
	}

	.demo-nav[data-open='true'] .demo-nav__item:nth-child(1) { transition-delay: 0.08s; }
	.demo-nav[data-open='true'] .demo-nav__item:nth-child(2) { transition-delay: 0.14s; }
	.demo-nav[data-open='true'] .demo-nav__item:nth-child(3) { transition-delay: 0.2s; }
	.demo-nav[data-open='true'] .demo-nav__item:nth-child(4) { transition-delay: 0.26s; }

	.demo-nav__item em {
		font-style: normal;
		color: rgba(255, 255, 255, 0.38);
	}

	.demo-nav__item strong {
		display: block;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 600;
		transition: font-family 0.25s ease, letter-spacing 0.25s ease;
	}

	.demo-nav__item span {
		display: block;
		margin-top: 0.45rem;
		color: rgba(255, 255, 255, 0.58);
		max-width: 18rem;
	}

	.demo-nav__item:hover strong {
		font-family: 'Cormorant Garamond', serif;
		letter-spacing: 0.03em;
	}

	@media (max-width: 900px) {
		.demo-nav__meta,
		.demo-nav__cta {
			display: none;
		}

		.demo-nav__panel {
			width: calc(100% - 2.3rem);
			min-height: calc(100% - 2.3rem);
		}
	}
</style>
