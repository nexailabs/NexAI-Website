---
interface Props {
	id: string;
	eyebrow: string;
	title: string;
	description: string;
	intent: string;
	tone?: 'teal' | 'charcoal' | 'lime' | 'violet' | 'sand' | 'obys';
}

const { id, eyebrow, title, description, intent, tone = 'teal' } = Astro.props;
---

<section class={`nav-lab-stage nav-lab-stage--${tone}`} id={id}>
	<div class="nav-lab-stage__meta">
		<div>
			<p class="nav-lab-stage__eyebrow">{eyebrow}</p>
			<h2>{title}</h2>
		</div>
		<div class="nav-lab-stage__copy">
			<p>{description}</p>
			<span>{intent}</span>
		</div>
	</div>

	<div class="nav-lab-stage__viewport" data-nav-lab-viewport data-menu-open="false">
		<slot name="nav" />

		<div class="nav-lab-stage__surface">
			<div class="nav-lab-stage__focus">
				<p class="nav-lab-stage__hero-label">Focus</p>
				<h3>Navigation only.</h3>
				<p>
					Test the bar, the trigger, hover typography, and the menu reveal. The surface below is
					intentionally quiet so the navbar direction is easy to judge.
				</p>
			</div>

			<div class="nav-lab-stage__chips">
				<div>Hover type</div>
				<div>Trigger motion</div>
				<div>Open state</div>
				<div>CTA weight</div>
			</div>

			<div class="nav-lab-stage__note">
				<span>Review</span>
				<p>Pick based on the closed bar, how the menu opens, and whether the hover feels premium or forced.</p>
			</div>
		</div>
	</div>
</section>

<style>
	.nav-lab-stage {
		display: grid;
		gap: 1.4rem;
	}

	.nav-lab-stage__meta {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: end;
	}

	.nav-lab-stage__eyebrow,
	.nav-lab-stage__hero-label,
	.nav-lab-stage__note span {
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.52);
	}

	.nav-lab-stage__meta h2 {
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1;
		margin-top: 0.55rem;
	}

	.nav-lab-stage__copy {
		max-width: 32rem;
		display: grid;
		gap: 0.65rem;
	}

	.nav-lab-stage__copy p {
		color: rgba(255, 255, 255, 0.72);
		line-height: 1.6;
	}

	.nav-lab-stage__copy span {
		color: rgba(255, 255, 255, 0.48);
		font-size: 0.92rem;
	}

	.nav-lab-stage__viewport {
		position: relative;
		height: 38rem;
		overflow: hidden;
		border-radius: 2rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background:
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 42%),
			radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.04), transparent 36%),
			#070809;
		box-shadow: 0 28px 80px rgba(0, 0, 0, 0.32);
	}

	.nav-lab-stage--teal .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(78, 201, 180, 0.14), transparent 44%),
			radial-gradient(circle at bottom right, rgba(30, 126, 114, 0.08), transparent 38%),
			#070809;
	}

	.nav-lab-stage--charcoal .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 44%),
			radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.04), transparent 26%),
			#090909;
	}

	.nav-lab-stage--lime .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(220, 234, 34, 0.12), transparent 42%),
			radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.04), transparent 34%),
			#070809;
	}

	.nav-lab-stage--violet .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(176, 144, 255, 0.14), transparent 40%),
			radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.04), transparent 34%),
			#060708;
	}

	.nav-lab-stage--sand .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(227, 208, 162, 0.12), transparent 40%),
			radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.03), transparent 34%),
			#080808;
	}

	.nav-lab-stage--obys .nav-lab-stage__viewport {
		background:
			radial-gradient(circle at top left, rgba(255, 138, 76, 0.12), transparent 36%),
			radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.03), transparent 30%),
			#080606;
	}

	.nav-lab-stage__surface {
		display: grid;
		gap: 1.25rem;
		padding: 6.8rem 1.5rem 1.5rem;
		align-content: start;
	}

	.nav-lab-stage__focus {
		max-width: 38rem;
	}

	.nav-lab-stage__focus h3 {
		font-size: clamp(2.3rem, 5vw, 4.2rem);
		line-height: 0.92;
		letter-spacing: -0.04em;
		margin: 0.75rem 0 0.9rem;
	}

	.nav-lab-stage__focus p,
	.nav-lab-stage__note p {
		color: rgba(255, 255, 255, 0.72);
		line-height: 1.65;
	}

	.nav-lab-stage__chips div,
	.nav-lab-stage__note {
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.6rem;
		background: rgba(255, 255, 255, 0.04);
		backdrop-filter: blur(12px);
	}

	.nav-lab-stage__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.nav-lab-stage__chips div {
		padding: 0.9rem 1rem;
		border-radius: 999px;
		color: rgba(255, 255, 255, 0.78);
	}

	.nav-lab-stage__note {
		padding: 1.4rem;
		max-width: 34rem;
	}

	@media (max-width: 900px) {
		.nav-lab-stage__meta {
			grid-template-columns: 1fr;
			display: grid;
		}

		.nav-lab-stage__viewport {
			height: 34rem;
		}

		.nav-lab-stage__surface {
			padding: 6rem 1rem 1rem;
		}

		.nav-lab-stage__focus h3 {
			font-size: clamp(2rem, 9vw, 3.3rem);
		}
	}
</style>
