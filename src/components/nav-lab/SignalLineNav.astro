---
import { navLabLinks, navLabMeta } from '../../data/navLab';
---

<div class="signal-nav" data-nav-demo data-nav-id="signal-line" data-open="false">
	<header class="signal-nav__bar">
		<a href="#top" class="signal-nav__brand">
			<img src="/assets/logo/nexai-logo-white.png" alt="NexAI Labs" width="166" height="40" />
		</a>
		<div class="signal-nav__line"></div>
		<button class="signal-nav__trigger" data-nav-trigger aria-expanded="false" aria-label="Open navigation">
			<span class="signal-nav__trigger-core" aria-hidden="true">
				<i></i>
				<i></i>
				<i></i>
			</span>
		</button>
	</header>

	<div class="signal-nav__panel" data-nav-panel aria-hidden="true">
		<div class="signal-nav__panel-head">
			<span>{navLabMeta.location}</span>
			<a href={navLabMeta.emailHref}>{navLabMeta.email}</a>
		</div>

		<nav class="signal-nav__list">
			{
				navLabLinks.map((link) => (
					<a class="signal-nav__item" href={link.href} data-nav-close>
						<span>{link.index}</span>
						<div class="signal-nav__item-copy">
							<strong class="signal-nav__label">{link.label}</strong>
							<small>{link.caption}</small>
						</div>
					</a>
				))
			}
		</nav>

		<div class="signal-nav__panel-foot">
			<a href={navLabMeta.ctaHref} target="_blank" rel="noreferrer">{navLabMeta.ctaLabel}</a>
		</div>
	</div>
</div>

<style>
	.signal-nav {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 0.9rem 1.2rem 0;
	}

	.signal-nav__bar {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.35rem 0 0.1rem;
		transition:
			padding 0.45s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.45s ease,
			background 0.45s ease,
			backdrop-filter 0.45s ease;
	}

	.signal-nav.is-scrolled .signal-nav__bar {
		padding: 0.9rem 1rem;
		border-radius: 1.4rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.68);
		backdrop-filter: blur(18px);
	}

	.signal-nav__brand img {
		height: 1.55rem;
		width: auto;
	}

	.signal-nav__line {
		height: 1px;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.04));
	}

	.signal-nav__trigger,
	.signal-nav__col a,
	.signal-nav__item {
		color: inherit;
		text-decoration: none;
	}

	.signal-nav__trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.35rem;
		height: 3.35rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(10px);
		cursor: pointer;
		transition:
			transform 0.42s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.42s ease,
			background 0.42s ease,
			box-shadow 0.42s ease;
	}

	.signal-nav__trigger:hover,
	.signal-nav__trigger:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.05);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
		outline: none;
	}

	.signal-nav__trigger-core {
		position: relative;
		display: inline-flex;
		width: 1.35rem;
		height: 1.35rem;
		align-items: center;
		justify-content: center;
	}

	.signal-nav__trigger-core::before {
		content: '';
		position: absolute;
		inset: -0.55rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 999px;
		animation: signal-pulse 2.8s ease-in-out infinite;
	}

	.signal-nav__trigger-core i {
		position: absolute;
		display: block;
		width: 1.35rem;
		height: 1px;
		background: currentColor;
		transform-origin: center;
		transition:
			transform 0.42s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.32s ease;
	}

	.signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(0deg);
	}

	.signal-nav__trigger-core i:nth-child(2) {
		transform: rotate(60deg);
	}

	.signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(120deg);
	}

	.signal-nav[data-open='true'] .signal-nav__trigger-core::before {
		animation: none;
		opacity: 0.5;
	}

	.signal-nav[data-open='true'] .signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(45deg);
	}

	.signal-nav[data-open='true'] .signal-nav__trigger-core i:nth-child(2) {
		opacity: 0;
	}

	.signal-nav[data-open='true'] .signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(-45deg);
	}

	.signal-nav__panel {
		position: absolute;
		inset: 0 1.2rem auto 1.2rem;
		top: 0.8rem;
		padding: 5.2rem 1.4rem 1.4rem;
		border-radius: 1.9rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.95);
		backdrop-filter: blur(20px);
		opacity: 0;
		pointer-events: none;
		transform: translateX(-102%);
		transition:
			transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.5s ease;
	}

	.signal-nav[data-open='true'] .signal-nav__panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(0);
	}

	.signal-nav__panel-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.8rem;
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.42);
	}

	.signal-nav__panel-head a,
	.signal-nav__panel-foot a {
		color: inherit;
		text-decoration: none;
	}

	.signal-nav__list {
		display: grid;
		gap: 0.2rem;
	}

	.signal-nav__item {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateX(-24px);
		transition:
			transform 0.62s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.52s ease,
			border-color 0.42s ease;
	}

	.signal-nav[data-open='true'] .signal-nav__item {
		opacity: 1;
		transform: translateX(0);
	}

	.signal-nav[data-open='true'] .signal-nav__item:nth-child(1) { transition-delay: 0.12s; }
	.signal-nav[data-open='true'] .signal-nav__item:nth-child(2) { transition-delay: 0.2s; }
	.signal-nav[data-open='true'] .signal-nav__item:nth-child(3) { transition-delay: 0.28s; }
	.signal-nav[data-open='true'] .signal-nav__item:nth-child(4) { transition-delay: 0.36s; }

	.signal-nav__item span {
		color: rgba(255, 255, 255, 0.32);
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.signal-nav__item-copy {
		display: grid;
		gap: 0.55rem;
	}

	.signal-nav__label {
		font-size: clamp(2.45rem, 5vw, 4.25rem);
		line-height: 0.94;
		font-weight: 600;
		letter-spacing: -0.02em;
		transition:
			transform 0.52s cubic-bezier(0.16, 1, 0.3, 1),
			letter-spacing 0.42s ease,
			opacity 0.42s ease;
	}

	.signal-nav__item small {
		color: rgba(255, 255, 255, 0.46);
		font-size: 0.92rem;
		line-height: 1.6;
		max-width: 30rem;
		transition:
			color 0.42s ease,
			transform 0.52s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.42s ease;
	}

	.signal-nav__item:hover {
		border-color: rgba(255, 255, 255, 0.12);
	}

	.signal-nav__item:hover .signal-nav__label {
		transform: translateX(8px);
		letter-spacing: 0;
	}

	.signal-nav__item:hover small {
		color: rgba(255, 255, 255, 0.66);
		transform: translateX(4px);
	}

	.signal-nav__panel-foot {
		display: flex;
		justify-content: flex-start;
		padding-top: 1.6rem;
	}

	.signal-nav__panel-foot a {
		display: inline-flex;
		padding: 0.92rem 1.05rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		width: max-content;
		transition:
			transform 0.36s ease,
			border-color 0.36s ease,
			background 0.36s ease;
	}

	.signal-nav__panel-foot a:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.22);
		background: rgba(255, 255, 255, 0.04);
	}

	@media (max-width: 900px) {
		.signal-nav__panel-head {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@keyframes signal-pulse {
		0%,
		100% {
			transform: scale(0.92);
			opacity: 0.45;
		}

		50% {
			transform: scale(1);
			opacity: 0.9;
		}
	}
</style>
