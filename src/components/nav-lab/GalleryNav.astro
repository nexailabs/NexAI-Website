---
import { navLabLinks, navLabMeta } from '../../data/navLab';
---

<div class="gallery-nav" data-nav-demo data-nav-id="gallery" data-open="false">
	<header class="gallery-nav__bar">
		<a class="gallery-nav__brand" href="#top">
			<img src="/assets/logo/nexai-icon.png" alt="" width="40" height="40" />
			<span>NexAI Labs</span>
		</a>
		<div class="gallery-nav__actions">
			<a href={navLabMeta.ctaHref} target="_blank" rel="noreferrer">{navLabMeta.ctaLabel}</a>
			<button class="gallery-nav__trigger" data-nav-trigger aria-expanded="false">Menu</button>
		</div>
	</header>

	<div class="gallery-nav__panel" data-nav-panel aria-hidden="true">
		<nav class="gallery-nav__list">
			{
				navLabLinks.map((link) => (
					<a class="gallery-nav__item" href={link.href} data-nav-close>
						<div class="gallery-nav__item-copy">
							<em>{link.index}</em>
							<strong>{link.label}</strong>
						</div>
						<p>{link.caption}</p>
					</a>
				))
			}
		</nav>
		<div class="gallery-nav__note">
			<span>Concept</span>
			<p>Gallery-style menu with softer previews and a cleaner top bar.</p>
			<a href={navLabMeta.emailHref}>{navLabMeta.email}</a>
		</div>
	</div>
</div>

<style>
	.gallery-nav {
		position: sticky;
		top: 0.8rem;
		z-index: 30;
		padding: 1rem 1.2rem 0;
	}

	.gallery-nav__bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.95rem 1.1rem;
		border-radius: 1.25rem;
		background: rgba(10, 10, 10, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
	}

	.gallery-nav__brand,
	.gallery-nav__actions a,
	.gallery-nav__trigger,
	.gallery-nav__item,
	.gallery-nav__note a {
		color: inherit;
		text-decoration: none;
	}

	.gallery-nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		font-size: 0.88rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.gallery-nav__brand img {
		width: 2.15rem;
		height: 2.15rem;
	}

	.gallery-nav__actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.gallery-nav__actions a,
	.gallery-nav__trigger {
		padding: 0.75rem 0.95rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.03);
	}

	.gallery-nav__trigger {
		background: #fff;
		color: #050607;
		border: 0;
		cursor: pointer;
	}

	.gallery-nav__panel {
		position: absolute;
		inset: 0 1.2rem auto 1.2rem;
		top: 1rem;
		display: grid;
		grid-template-columns: 1fr 18rem;
		gap: 1rem;
		padding: 5.7rem 1.1rem 1.1rem;
		border-radius: 1.8rem;
		background: rgba(11, 10, 9, 0.94);
		border: 1px solid rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(18px);
		opacity: 0;
		pointer-events: none;
		transform: translateY(-4%) scale(0.985);
		transition: transform 0.42s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.28s ease;
	}

	.gallery-nav[data-open='true'] .gallery-nav__panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0) scale(1);
	}

	.gallery-nav__list {
		display: grid;
		gap: 0.9rem;
	}

	.gallery-nav__item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 18rem;
		gap: 1rem;
		padding: 1rem;
		border-radius: 1.3rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateY(18px);
		transition:
			transform 0.34s ease,
			opacity 0.28s ease,
			border-color 0.24s ease,
			background 0.24s ease;
	}

	.gallery-nav[data-open='true'] .gallery-nav__item {
		opacity: 1;
		transform: translateY(0);
	}

	.gallery-nav[data-open='true'] .gallery-nav__item:nth-child(1) { transition-delay: 0.08s; }
	.gallery-nav[data-open='true'] .gallery-nav__item:nth-child(2) { transition-delay: 0.14s; }
	.gallery-nav[data-open='true'] .gallery-nav__item:nth-child(3) { transition-delay: 0.2s; }
	.gallery-nav[data-open='true'] .gallery-nav__item:nth-child(4) { transition-delay: 0.26s; }

	.gallery-nav__item-copy {
		display: flex;
		align-items: baseline;
		gap: 1rem;
	}

	.gallery-nav__item em,
	.gallery-nav__note span {
		font-style: normal;
		font-size: 0.74rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.42);
	}

	.gallery-nav__item strong {
		font-size: clamp(2rem, 4vw, 3.5rem);
		transition: font-family 0.24s ease, transform 0.24s ease;
	}

	.gallery-nav__item p,
	.gallery-nav__note p,
	.gallery-nav__note a {
		color: rgba(255, 255, 255, 0.62);
		line-height: 1.55;
	}

	.gallery-nav__item:hover {
		border-color: rgba(255, 255, 255, 0.16);
		background: rgba(255, 255, 255, 0.05);
	}

	.gallery-nav__item:hover strong {
		font-family: 'Cormorant Garamond', serif;
		transform: translateX(8px);
	}

	.gallery-nav__note {
		padding: 1rem;
		border-radius: 1.3rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		display: grid;
		align-content: start;
		gap: 0.9rem;
	}

	@media (max-width: 900px) {
		.gallery-nav__actions a {
			display: none;
		}

		.gallery-nav__panel,
		.gallery-nav__item {
			grid-template-columns: 1fr;
		}
	}
</style>
