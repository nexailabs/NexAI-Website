---
import type { HeroImage } from '../types/studio';
import { site } from '../config/site';
interface Props {
	floats: HeroImage[];
}

const { floats } = Astro.props;
---

<section class="studio-cta">
	<div class="container studio-cta__inner">
		<h3 class="section-title">
			Launch the collection.<br />Skip the <em>shoot</em>.
		</h3>
		<p class="section-sub">
			<span class="studio-cta__sub-desktop"
				>Get sample shoots on the house. See your category in action before you commit.</span
			>
			<span class="studio-cta__sub-mobile">Get sample shoots on the house.</span>
		</p>
		<a class="studio-cta__btn" href={site.bookingUrl} data-open-cal> Book a Free Call </a>
		<div class="studio-cta__proof">
			<div class="studio-cta__avatars">
				<img
					src={floats[0]?.src}
					alt=""
					class="studio-cta__avatar"
					width="32"
					height="32"
					loading="lazy"
				/>
				<img
					src={floats[3]?.src}
					alt=""
					class="studio-cta__avatar"
					width="32"
					height="32"
					loading="lazy"
				/>
				<img
					src={floats[4]?.src}
					alt=""
					class="studio-cta__avatar"
					width="32"
					height="32"
					loading="lazy"
				/>
			</div>
			<span class="studio-cta__proof-text">
				<strong>50+ brands</strong> trust NexAI Studio
			</span>
		</div>
	</div>
</section>

<style>
	.studio-cta {
		position: relative;
		padding: clamp(4rem, 8vh, 6rem) 0;
		background: radial-gradient(ellipse at 50% 60%, rgba(30, 126, 114, 0.25), transparent 70%);
	}

	/* ── Inner content ── */
	.studio-cta__inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	/* Heading/sub use global .section-title / .section-sub */

	/* ── CTA button ── */
	.studio-cta__btn {
		display: inline-flex;
		align-items: center;
		padding: 0.85rem 2.2rem;
		border-radius: 999px;
		background: var(--color-text-main);
		color: var(--color-bg);
		font-family: var(--font-main);
		font-weight: var(--fw-semibold);
		font-size: 0.95rem;
		text-decoration: none;
		transition:
			transform 0.3s var(--ease-out-expo),
			box-shadow 0.3s var(--ease-out-expo);
	}

	.studio-cta__btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 0 24px rgba(78, 201, 180, 0.2);
	}

	/* ── Social proof ── */
	.studio-cta__proof {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.studio-cta__avatars {
		display: flex;
	}

	.studio-cta__avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--color-bg);
		margin-left: -8px;
	}

	.studio-cta__avatar:first-child {
		margin-left: 0;
	}

	.studio-cta__proof-text {
		font-family: var(--font-main);
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.studio-cta__proof-text strong {
		color: var(--color-text-main);
	}

	.studio-cta__sub-mobile {
		display: none;
	}

	/* ── Mobile ── */
	@media (max-width: 720px) {
		.studio-cta {
			padding: clamp(4rem, 10vh, 7rem) 0;
		}

		.studio-cta__inner .section-sub {
			margin-top: -0.75rem;
		}

		.studio-cta__sub-desktop {
			display: none;
		}
		.studio-cta__sub-mobile {
			display: inline;
		}

		.studio-cta__proof {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
