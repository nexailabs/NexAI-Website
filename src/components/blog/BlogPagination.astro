---
interface Props {
	page: {
		currentPage: number;
		lastPage: number;
		url: { prev?: string; next?: string };
	};
}

const { page } = Astro.props;
if (page.lastPage <= 1) {
	return null;
}
---

<nav class="container blog-pagination" aria-label="Blog pages">
	{
		page.url.prev ? (
			<a class="btn-ghost" href={page.url.prev}>
				← Previous
			</a>
		) : (
			<span />
		)
	}
	<span class="blog-pagination__meta">Page {page.currentPage} of {page.lastPage}</span>
	{
		page.url.next ? (
			<a class="btn-ghost" href={page.url.next}>
				Next →
			</a>
		) : (
			<span />
		)
	}
</nav>

<style>
	.blog-pagination {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		margin-top: clamp(2rem, 5vh, 4rem);
	}
	.blog-pagination .btn-ghost:last-child {
		justify-self: end;
	}
	.blog-pagination__meta {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
	}
	@media (max-width: 640px) {
		.blog-pagination {
			grid-template-columns: 1fr;
		}
		.blog-pagination .btn-ghost:last-child {
			justify-self: start;
		}
	}
</style>
