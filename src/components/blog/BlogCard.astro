---
import type { CollectionEntry } from 'astro:content';
import { tr } from '../../config/imagekit';

type Variant = 'default' | 'compact' | 'related';

interface Props {
	post: CollectionEntry<'blog'>;
	variant?: Variant;
}

const { post, variant = 'default' } = Astro.props;
const slug = post.data.slug ?? post.id.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const href = `/blog/${slug}/`;
const published = post.data.publishedAt.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<article class={`blog-card blog-card--${variant}`}>
	<a href={href} class="blog-card__media-link">
		<img
			class="blog-card__image"
			src={`${post.data.cover.src}${tr.showcase}`}
			alt={post.data.cover.alt}
			loading="lazy"
			decoding="async"
		/>
	</a>
	<div class="blog-card__content">
		<p class="blog-card__meta">{post.data.category} · {published}</p>
		<h2 class="blog-card__title">
			<a href={href}>{post.data.title}</a>
		</h2>
		{variant === 'default' && <p class="blog-card__excerpt">{post.data.description}</p>}
	</div>
</article>

<style>
	.blog-card {
		display: grid;
		gap: 0.9rem;
	}
	.blog-card__media-link {
		overflow: hidden;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		aspect-ratio: 16 / 10;
		display: block;
		background: var(--color-surface);
	}
	.blog-card__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s var(--ease-out-expo);
	}
	.blog-card:hover .blog-card__image {
		transform: scale(1.03);
	}
	.blog-card__meta {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
	.blog-card__title a {
		color: var(--color-text-main);
		text-decoration: none;
		font-size: clamp(1.06rem, 1.6vw, 1.3rem);
		line-height: var(--lh-ui);
	}
	.blog-card__title a:hover {
		color: var(--color-brand-cyan);
	}
	.blog-card__excerpt {
		color: var(--color-text-muted);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		line-height: var(--lh-body);
	}
	.blog-card--compact .blog-card__title a,
	.blog-card--related .blog-card__title a {
		font-size: 1.05rem;
	}
</style>
