---
// Eyebrow label — uppercase Inter semibold, matching the homepage hero eyebrow
// (see src/components/home/HomeHero.astro `.home-hero__eyebrow`).
// Component name is historical; the underlying style is now brand-consistent.
interface Props {
	class?: string;
	tint?: 'accent' | 'default' | 'dim';
}

const { class: className = '', tint = 'default' } = Astro.props;
---

<span class:list={['blog-eyebrow', `blog-eyebrow--${tint}`, className]}>
	<slot />
</span>

<style>
	.blog-eyebrow {
		font-family: var(--font-main);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}
	.blog-eyebrow--accent {
		color: var(--color-brand-cyan);
	}
	.blog-eyebrow--default {
		color: var(--color-text-muted);
	}
	.blog-eyebrow--dim {
		color: var(--color-text-dim);
	}
</style>
