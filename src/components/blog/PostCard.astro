---
import Cover from './Cover.astro';
import Meta from './Meta.astro';
import EmphasisText from './EmphasisText.astro';

interface Props {
	href: string;
	title: string;
	emphasis?: string;
	excerpt?: string;
	category: string;
	date: string;
	seed: number;
	size?: 'sm' | 'md' | 'lg' | 'xl';
	span?: number;
	showExcerpt?: boolean;
}

const {
	href,
	title,
	emphasis,
	excerpt,
	category,
	date,
	seed,
	size = 'md',
	span,
	showExcerpt = false,
} = Astro.props;

const coverHeight = { sm: '240px', md: '320px', lg: '420px', xl: '520px' }[size];
---

<a
	href={href}
	class:list={['blog-card', `blog-card--${size}`]}
	style={span ? `grid-column: span ${span};` : undefined}
>
	<div class="blog-card__cover">
		<Cover seed={seed} height={coverHeight} />
		<span class="blog-card__arrow" aria-hidden="true">
			<svg
				width="12"
				height="12"
				viewBox="0 0 24 24"
				fill="none"
				stroke-width="1.5"
				stroke-linecap="round"
			>
				<line x1="5" y1="12" x2="19" y2="12"></line>
				<polyline points="13 6 19 12 13 18"></polyline>
			</svg>
		</span>
	</div>
	<h3 class="blog-card__title">
		<EmphasisText text={title} emphasis={emphasis} />
	</h3>
	{showExcerpt && excerpt && <p class="blog-card__excerpt">{excerpt}</p>}
	<div class="blog-card__meta">
		<Meta category={category} date={date} />
	</div>
</a>

<style>
	.blog-card {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.blog-card__cover {
		position: relative;
		width: 100%;
		margin-bottom: 20px;
		transition: transform 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
	}

	.blog-card:hover .blog-card__cover {
		transform: translateY(-3px);
	}

	.blog-card__arrow {
		position: absolute;
		right: 14px;
		bottom: 14px;
		width: 30px;
		height: 30px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.3);
		background: rgba(10, 10, 10, 0.4);
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgba(255, 255, 255, 0.8);
		transition:
			background 0.3s ease,
			color 0.3s ease;
	}

	.blog-card:hover .blog-card__arrow {
		background: rgba(255, 255, 255, 0.95);
		color: var(--color-bg, #050607);
	}

	.blog-card__arrow svg {
		stroke: currentColor;
	}

	.blog-card__title {
		font-family: var(--font-display);
		font-weight: var(--fw-semibold);
		font-size: 1.35rem;
		line-height: var(--lh-heading);
		color: var(--color-text-main);
		margin: 0;
		text-wrap: balance;
		letter-spacing: -0.005em;
		transition: color 0.2s;
	}

	.blog-card--lg .blog-card__title {
		font-size: 1.75rem;
	}

	.blog-card--xl .blog-card__title {
		font-size: 2.15rem;
	}

	.blog-card__excerpt {
		margin-top: 12px;
		margin-bottom: 0;
		font-family: var(--font-main);
		font-size: 0.95rem;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.5);
		max-width: 520px;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__meta {
		margin-top: 14px;
	}

	@media (prefers-reduced-motion: reduce) {
		.blog-card:hover .blog-card__cover {
			transform: none;
		}
	}

	@media (max-width: 600px) {
		.blog-card--sm .blog-card__cover :global(.blog-cover) {
			height: 240px !important;
		}

		.blog-card--md .blog-card__cover :global(.blog-cover),
		.blog-card--lg .blog-card__cover :global(.blog-cover),
		.blog-card--xl .blog-card__cover :global(.blog-cover) {
			height: 320px !important;
		}
	}
</style>
