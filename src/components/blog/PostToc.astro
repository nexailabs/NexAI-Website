---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const h2Count = headings.filter((h) => h.depth === 2).length;
if (h2Count < 3) {
	return null;
}
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside class="post-toc" aria-label="Table of contents">
	<p class="post-toc__title">On this page</p>
	<ul>
		{
			tocHeadings.map((heading) => (
				<li class={heading.depth === 3 ? 'is-h3' : undefined}>
					<a href={`#${heading.slug}`} data-toc-link>
						{heading.text}
					</a>
				</li>
			))
		}
	</ul>
</aside>

<script>
	const links = Array.from(document.querySelectorAll('[data-toc-link]'));
	const sections = links
		.map((link) => document.querySelector(link.getAttribute('href') ?? ''))
		.filter((section) => section instanceof HTMLElement);

	if (links.length && sections.length) {
		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

				if (!visible) return;
				links.forEach((link) => {
					link.classList.toggle('is-active', link.getAttribute('href') === `#${visible.target.id}`);
				});
			},
			{ rootMargin: '-20% 0px -60% 0px', threshold: [0.1, 0.4, 0.8] },
		);

		sections.forEach((section) => observer.observe(section));
	}
</script>

<style>
	.post-toc {
		display: none;
	}
	@media (min-width: 1100px) {
		.post-toc {
			display: block;
			position: sticky;
			top: calc(var(--header-height) + 1rem);
			height: fit-content;
			font-size: var(--text-sm);
		}
	}
	.post-toc__title {
		font-size: var(--text-xs);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		margin-bottom: 0.8rem;
	}
	.post-toc ul {
		list-style: none;
		display: grid;
		gap: 0.5rem;
	}
	.post-toc li.is-h3 {
		padding-left: 0.75rem;
	}
	.post-toc a {
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.post-toc a.is-active,
	.post-toc a:hover {
		color: var(--color-brand-cyan);
	}
</style>
