---
import type { ShowcaseCategory } from '../types/studio';
import { showcaseSrcset } from '../config/imagekit';

interface Props {
	categories: ShowcaseCategory[];
}

const { categories } = Astro.props;
const scSizes = '(max-width: 900px) 80vw, 35vw';

const aspectDims: Record<string, { w: number; h: number }> = {
	'3x4': { w: 600, h: 800 },
	'2x3': { w: 600, h: 900 },
	'1x1': { w: 600, h: 600 },
};

const placeholderSvg = `<svg class="sc3__ph-icon" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>`;
const placeholderSvgLg = `<svg class="sc3__ph-icon sc3__ph-icon--lg" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>`;
---

<section class="sc3" id="showcase">
	<div class="container sc3__shell">
		<header class="section-header">
			<h2 class="section-title">See the <em>difference</em></h2>
			<p class="section-sub">Product in, photoshoot out. Pick a category to explore.</p>
		</header>
		<div class="sc3__nav">
			<ul class="sc3__nav-list" role="tablist" aria-label="Showcase categories">
				{
					categories.map((cat, i) => (
						<li role="presentation">
							<button
								class:list={['sc3__nav-item', { active: i === 0 }]}
								data-target={cat.id}
								role="tab"
								id={`tab-${cat.id}`}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`panel-${cat.id}`}
								tabindex={i === 0 ? 0 : -1}
							>
								<span class="sc3__nav-text">{cat.label}</span>
							</button>
						</li>
					))
				}
			</ul>
		</div>

		<div class="sc3__stage">
			{
				categories.map((cat, i) => (
					<div
						class:list={['sc3__panel', { active: i === 0 }]}
						data-panel={cat.id}
						role="tabpanel"
						id={`panel-${cat.id}`}
						aria-labelledby={`tab-${cat.id}`}
						aria-hidden={i !== 0 ? 'true' : 'false'}
					>
						{/* Mobile Before/After Stage */}
						<div class="sc3__mobile-stage">
							<div class="sc3__mobile-card sc3__mobile-card--before">
								<div class="sc3__mobile-card-body" data-label="Before">
									<div class="sc3__mobile-card-content">
										{cat.inputMain ? (
											cat.inputSideTop || cat.inputSideBottom ? (
												<div
													class:list={[
														'sc3__mobile-before-grid',
														{
															'sc3__mobile-before-grid--triple':
																cat.inputSideTop && cat.inputSideBottom,
														},
													]}
												>
													<div class="sc3__mobile-before-main">
														<img
															src={cat.inputMain}
															srcset={showcaseSrcset(cat.inputMain)}
															sizes={scSizes}
															alt={`${cat.label} raw input`}
															width="600"
															height="800"
															loading="lazy"
														/>
													</div>
													<div class="sc3__mobile-before-side">
														{cat.inputSideTop && (
															<div class="sc3__mobile-before-side-card">
																<img
																	src={cat.inputSideTop}
																	srcset={showcaseSrcset(cat.inputSideTop)}
																	sizes={scSizes}
																	alt={`${cat.label} side input top`}
																	width="600"
																	height="800"
																	loading="lazy"
																/>
															</div>
														)}
														{cat.inputSideBottom && (
															<div class="sc3__mobile-before-side-card">
																<img
																	src={cat.inputSideBottom}
																	srcset={showcaseSrcset(cat.inputSideBottom)}
																	sizes={scSizes}
																	alt={`${cat.label} side input bottom`}
																	width="600"
																	height="800"
																	loading="lazy"
																/>
															</div>
														)}
													</div>
												</div>
											) : (
												<img
													src={cat.inputMain}
													srcset={showcaseSrcset(cat.inputMain)}
													sizes={scSizes}
													alt={`${cat.label} raw input`}
													width="600"
													height="800"
													loading="lazy"
												/>
											)
										) : (
											<div class="sc3__mobile-ph">
												<Fragment set:html={placeholderSvgLg} />
												<span class="sc3__ph-text">Input coming soon</span>
											</div>
										)}
									</div>
								</div>
							</div>
							<div class="sc3__mobile-card sc3__mobile-card--after">
								<div class="sc3__mobile-card-body" data-label="After">
									<div class="sc3__mobile-card-content">
										<div class="sc3__mobile-output-grid">
											{[1, 2, 0, 3].map((outputIdx, gridIdx) => {
												const pos = ['tl', 'tr', 'bl', 'br'][gridIdx];
												const slot = cat.outputs[outputIdx];
												return slot?.src ? (
													<div class={`sc3__mobile-output sc3__mobile-output--${pos}`}>
														<img
															src={slot.src}
															srcset={showcaseSrcset(slot.src)}
															sizes={scSizes}
															alt={slot.alt}
															width="600"
															height="800"
															loading="lazy"
														/>
													</div>
												) : (
													<div class={`sc3__mobile-output sc3__mobile-output--${pos}`}>
														<div class="sc3__mobile-output-ph">
															<Fragment set:html={placeholderSvg} />
														</div>
													</div>
												);
											})}
										</div>
									</div>
								</div>
							</div>
						</div>

						{/* Left Input Block */}
						<div class="sc3__col sc3__col--left">
							<span class="sc3__label">Input Images</span>
							<div class="sc3__input-wrap">
								<div
									class:list={[
										'sc3__input-group',
										{ 'sc3__input-group--solo': !cat.inputSideTop && !cat.inputSideBottom },
									]}
								>
									<div class:list={['sc3__input-main', { sc3__placeholder: !cat.inputMain }]}>
										{cat.inputMain ? (
											<img
												src={cat.inputMain}
												srcset={showcaseSrcset(cat.inputMain)}
												sizes={scSizes}
												alt="Raw Garment"
												width="600"
												height="800"
												loading="lazy"
											/>
										) : (
											<Fragment set:html={placeholderSvgLg} />
										)}
										{!cat.inputMain && <span class="sc3__ph-text">Garment</span>}
									</div>
									<div class="sc3__input-side">
										<div class:list={['sc3__in-top', { sc3__placeholder: !cat.inputSideTop }]}>
											{cat.inputSideTop ? (
												<img
													src={cat.inputSideTop}
													srcset={showcaseSrcset(cat.inputSideTop)}
													sizes={scSizes}
													alt="Side input"
													width="600"
													height="800"
													loading="lazy"
												/>
											) : (
												<Fragment set:html={placeholderSvg} />
											)}
										</div>
										<div
											class:list={['sc3__in-bottom', { sc3__placeholder: !cat.inputSideBottom }]}
										>
											{cat.inputSideBottom ? (
												<img
													src={cat.inputSideBottom}
													srcset={showcaseSrcset(cat.inputSideBottom)}
													sizes={scSizes}
													alt="Side input"
													width="600"
													height="800"
													loading="lazy"
												/>
											) : (
												<Fragment set:html={placeholderSvg} />
											)}
										</div>
									</div>
								</div>
							</div>
						</div>

						{/* Arrow Bridge */}
						<div class="sc3__arrow" aria-hidden="true" />

						{/* Right Output Block */}
						<div class="sc3__col sc3__col--right">
							<span class="sc3__label">Output Images</span>
							<div class="sc3__outputs-bento">
								{/* Col 1: outputs[0] (3x4) + outputs[1] (1x1) */}
								<div class="sc3__ob-col sc3__ob-col--1">
									{[cat.outputs[0], cat.outputs[1]].map((slot, si) => (
										<div
											class:list={[
												'sc3__ob-card',
												`sc3__ob-card--${slot.aspect}`,
												`sc3__out-card--${si + 1}`,
												{ sc3__placeholder: !slot.src },
											]}
										>
											{slot.src ? (
												<img
													src={slot.src}
													srcset={showcaseSrcset(slot.src)}
													sizes={scSizes}
													alt={slot.alt}
													width={aspectDims[slot.aspect].w}
													height={aspectDims[slot.aspect].h}
													loading="lazy"
												/>
											) : (
												<>
													<Fragment set:html={placeholderSvg} />
													<span class="sc3__ph-text">{slot.alt}</span>
												</>
											)}
										</div>
									))}
								</div>
								{/* Col 2: outputs[2] (2x3) */}
								<div class="sc3__ob-col sc3__ob-col--2">
									{(() => {
										const slot = cat.outputs[2];
										return (
											<div
												class:list={[
													'sc3__ob-card',
													`sc3__ob-card--${slot.aspect}`,
													'sc3__out-card--3',
													{ sc3__placeholder: !slot.src },
												]}
											>
												{slot.src ? (
													<img
														src={slot.src}
														srcset={showcaseSrcset(slot.src)}
														sizes={scSizes}
														alt={slot.alt}
														width={aspectDims[slot.aspect].w}
														height={aspectDims[slot.aspect].h}
														loading="lazy"
													/>
												) : (
													<>
														<Fragment set:html={placeholderSvg} />
														<span class="sc3__ph-text">{slot.alt}</span>
													</>
												)}
											</div>
										);
									})()}
								</div>
								{/* Col 3: outputs[3] (1x1) + outputs[4] (3x4) */}
								<div class="sc3__ob-col sc3__ob-col--3">
									{[cat.outputs[3], cat.outputs[4]].map((slot, si) => (
										<div
											class:list={[
												'sc3__ob-card',
												`sc3__ob-card--${slot.aspect}`,
												`sc3__out-card--${si + 4}`,
												{ sc3__placeholder: !slot.src },
											]}
										>
											{slot.src ? (
												<img
													src={slot.src}
													srcset={showcaseSrcset(slot.src)}
													sizes={scSizes}
													alt={slot.alt}
													width={aspectDims[slot.aspect].w}
													height={aspectDims[slot.aspect].h}
													loading="lazy"
												/>
											) : (
												<>
													<Fragment set:html={placeholderSvg} />
													<span class="sc3__ph-text">{slot.alt}</span>
												</>
											)}
										</div>
									))}
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style is:global>
	.sc3 {
		padding: clamp(3.5rem, 7vh, 5.5rem) 0 clamp(4rem, 8vh, 6rem);
		position: relative;
	}
	.sc3 .section-header {
		margin-bottom: 0;
	}
	.sc3__shell {
		display: flex;
		flex-direction: column;
		gap: clamp(1.25rem, 2.5vw, 2rem);
	}

	/* ── Horizontal Top Nav ── */
	.sc3__nav {
		width: 100%;
		margin: 0 auto;
		display: flex;
		justify-content: center;
	}
	.sc3__nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
	}
	.sc3__nav-item {
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 99rem;
		color: rgba(255, 255, 255, 0.5);
		font-family: inherit;
		font-size: 0.95rem;
		font-weight: 500;
		padding: 0.8rem 1.6rem;
		cursor: pointer;
		text-align: center;
		transition:
			color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
		overflow: hidden;
	}
	.sc3__nav-item::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at center, rgba(78, 201, 180, 0.3) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.sc3__nav-item:hover {
		color: rgba(255, 255, 255, 1);
		border-color: rgba(78, 201, 180, 0.4);
		box-shadow: 0 0 20px rgba(78, 201, 180, 0.15);
	}
	.sc3__nav-item:hover::before {
		opacity: 1;
	}
	.sc3__nav-item:focus-visible {
		outline: 2px solid var(--color-brand-cyan);
		outline-offset: 2px;
	}
	.sc3__nav-text {
		position: relative;
		z-index: 1;
	}
	.sc3__nav-item.active {
		color: var(--color-text-main);
		background: rgba(78, 201, 180, 0.15);
		border-color: var(--color-brand-cyan, #4ec9b4);
		box-shadow: 0 0 24px rgba(78, 201, 180, 0.4);
		font-weight: 600;
	}
	.sc3__nav-item.active::before {
		display: none;
	}

	/* ── Stage ── */
	.sc3__stage {
		position: relative;
		width: 100%;
		min-height: 0;
	}

	.sc3__mobile-stage {
		display: none;
	}

	/* ── Panel: OVERLAY CROSSFADE ── */
	.sc3__panel {
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: 1fr auto 2fr;
		grid-template-rows: 1fr;
		gap: clamp(1rem, 2vw, 2.5rem);
		align-items: stretch;
		opacity: 0;
		pointer-events: none;
		transform: scale(0.97);
		transition:
			opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.sc3__panel.active {
		position: relative;
		opacity: 1;
		pointer-events: auto;
		transform: scale(1);
	}
	.sc3__panel.leaving {
		opacity: 0;
		pointer-events: none;
		transform: scale(1.02);
	}
	.sc3__panel:not(.active):not(.leaving) {
		content-visibility: hidden;
	}

	/* ── Columns ── */
	.sc3__col {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		min-width: 0;
		min-height: 0;
		overflow: hidden;
		animation: sc3FadeUp 0.6s ease both;
	}
	.sc3__col--right {
		animation-delay: 0.15s;
	}
	.sc3__label {
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		flex-shrink: 0;
	}

	/* ── Placeholder Styles ── */
	.sc3__placeholder {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		background: rgba(255, 255, 255, 0.02);
		padding: 0.6rem;
		text-align: center;
	}
	.sc3__ph-icon {
		width: 28px;
		height: auto;
		color: rgba(78, 201, 180, 0.55);
		flex-shrink: 0;
	}
	.sc3__ph-icon--lg {
		width: 44px;
	}
	.sc3__ph-text {
		font-size: 0.58rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.38);
		line-height: 1.45;
		max-width: 100%;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		text-overflow: ellipsis;
		word-break: break-word;
	}

	/* ── Connection UI ── */
	.sc3__arrow {
		position: relative;
		width: clamp(2.5rem, 5vw, 5rem);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(78, 201, 180, 0.9), transparent);
		align-self: center;
		border-radius: 2px;
		opacity: 0.4;
		box-shadow: 0 0 10px rgba(78, 201, 180, 0.35);
	}
	.sc3__panel.active .sc3__arrow {
		opacity: 0.95;
		animation: sc3ConnectPulse 2.5s ease-in-out infinite alternate;
	}
	@keyframes sc3ConnectPulse {
		0% {
			opacity: 0.2;
			transform: scaleX(0.8);
		}
		100% {
			opacity: 0.8;
			transform: scaleX(1.2);
		}
	}

	.sc3__panel.active .sc3__out-card--1 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
	}
	.sc3__panel.active .sc3__out-card--2 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.42s both;
	}
	.sc3__panel.active .sc3__out-card--3 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.54s both;
	}
	.sc3__panel.active .sc3__out-card--4 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.66s both;
	}
	.sc3__panel.active .sc3__out-card--5 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.78s both;
	}

	@keyframes sc3FadeUp {
		0% {
			opacity: 0;
			transform: translateY(16px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes sc3CardIn {
		0% {
			opacity: 0;
			transform: translateY(16px) scale(0.97);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	/* ── Input Group ── */
	.sc3__input-wrap {
		position: relative;
		flex: 1;
		min-height: 0;
	}
	.sc3__input-group {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 0.5rem;
		position: absolute;
		inset: 0;
		overflow: hidden;
	}
	.sc3__input-main {
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid rgba(78, 201, 180, 0.12);
	}
	.sc3__input-main img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		display: block;
	}
	.sc3__input-group--solo {
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
	}
	.sc3__input-group--solo .sc3__input-side {
		display: none;
	}
	.sc3__input-group--solo .sc3__input-main {
		height: 100%;
		min-height: 0;
	}
	.sc3__input-side {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.sc3__in-top,
	.sc3__in-bottom {
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.06);
		flex: 1;
		min-height: 0;
	}
	.sc3__in-top img,
	.sc3__in-bottom img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* ── Output Bento Grid ── */
	.sc3__outputs-bento {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.5rem;
		max-width: 100%;
		overflow: hidden;
		flex: 1;
		min-height: 0;
	}
	.sc3__ob-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		min-width: 0;
	}
	.sc3__ob-card {
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid rgba(78, 201, 180, 0.1);
	}
	.sc3__ob-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		display: block;
	}
	.sc3__ob-card--3x4 {
		aspect-ratio: 3 / 3.24;
	}
	.sc3__ob-card--2x3 {
		flex: 1;
	}
	.sc3__ob-card--1x1 {
		aspect-ratio: 1 / 0.81;
	}

	/* ── Responsive ── */
	@media (max-width: 1100px) {
		.sc3__shell {
			grid-template-columns: clamp(9rem, 14vw, 11rem) 1fr;
		}
		.sc3__panel {
			grid-template-columns: 1fr auto 2fr;
		}
	}
	@media (max-width: 900px) {
		.sc3 {
			padding-top: clamp(3.5rem, 7vh, 5rem);
			padding-bottom: clamp(0.5rem, 1vh, 1rem);
		}

		.sc3__shell {
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
		}
		.sc3__nav {
			position: static;
			margin-top: 1.25rem;
		}
		.sc3__nav-list {
