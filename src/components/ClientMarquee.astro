---
import type { BrandLogo } from '../types/ai-shoots';

interface Props {
	brands: BrandLogo[];
}

const { brands } = Astro.props;
---

<div class="client-marquee" aria-label="Our Trusted Brands">
	<div class="client-marquee__track">
		<div class="client-marquee__list">
			{
				brands.map((b) => (
					<img src={b.src} alt={b.alt} width={b.width} height={b.height} loading="lazy" />
				))
			}
		</div>
		<div class="client-marquee__list" aria-hidden="true">
			{
				brands.map((b) => (
					<img src={b.src} alt="" width={b.width} height={b.height} loading="lazy" />
				))
			}
		</div>
	</div>
</div>

<style>
	.client-marquee {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		z-index: 10;
		padding: 0.85rem 0 2.5rem 0;
		overflow: hidden;
		background: transparent;
		border-top: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.15);
	}
	.client-marquee__track {
		display: flex;
		width: max-content;
		animation: scrollMarquee 35s linear infinite;
	}
	.client-marquee:hover .client-marquee__track {
		animation-play-state: paused;
	}
	.client-marquee__list {
		display: flex;
		align-items: center;
		justify-content: space-around;
		gap: clamp(2.2rem, 5vw, 6rem);
		padding: 0 clamp(1rem, 3vw, 3rem);
	}
	.client-marquee__list img {
		height: clamp(2.4rem, 5vw, 4.2rem);
		width: auto;
		max-width: 320px;
		object-fit: contain;
		opacity: 0.95;
		filter: grayscale(1) brightness(1.5);
		background: transparent;
		transition:
			opacity 0.4s ease,
			transform 0.4s ease,
			filter 0.4s ease;
	}
	.client-marquee__list img:hover {
		opacity: 1;
		transform: scale(1.05);
		filter: grayscale(0) brightness(1);
	}
	@media (max-width: 720px) {
		.client-marquee__list {
			gap: clamp(1.5rem, 7vw, 2.5rem);
		}
	}
	@keyframes scrollMarquee {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.client-marquee__track {
			animation: none;
		}
	}
</style>
