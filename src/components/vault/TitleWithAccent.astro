---
// Splits a title around a `accent` substring (case-insensitive)
// and wraps the matched portion in italic display.
interface Props {
	text: string;
	accent?: string;
}

const { text, accent } = Astro.props;

function split(text: string, accent?: string) {
	if (!accent) return { before: text };
	const idx = text.toLowerCase().indexOf(accent.toLowerCase());
	if (idx < 0) return { before: text };
	return {
		before: text.slice(0, idx),
		match: text.slice(idx, idx + accent.length),
		after: text.slice(idx + accent.length),
	};
}

const parts = split(text, accent);
---

{parts.before}{parts.match && <em class="vault-italic">{parts.match}</em>}{parts.after}

<style>
	.vault-italic {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: var(--fw-regular);
		letter-spacing: -0.005em;
	}
</style>
