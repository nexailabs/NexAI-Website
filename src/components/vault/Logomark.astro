---
import { LOGO_TINTS } from '../../data/vault';

interface Props {
	tool: string;
	size?: number;
	radius?: number;
}

const { tool, size = 44, radius = 8 } = Astro.props;
const fallback = { letter: tool[0]?.toUpperCase() ?? '?', tint: '#e5e5e5' };
const m = LOGO_TINTS[tool] ?? fallback;
const fontPx = (m.letter.length > 1 ? size * 0.34 : size * 0.46).toFixed(2);
---

<span
	class="logomark"
	style={`width: ${size}px; height: ${size}px; border-radius: ${radius}px; color: ${m.tint}; font-size: ${fontPx}px;`}
	aria-hidden="true"
	title={tool}
>
	{m.letter}
</span>

<style>
	.logomark {
		background: #0e0f10;
		border: 1px solid rgba(255, 255, 255, 0.08);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-main);
		font-weight: var(--fw-semibold);
		letter-spacing: -0.02em;
		flex-shrink: 0;
	}
</style>
