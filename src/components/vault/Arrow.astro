---
interface Props {
	size?: number;
	color?: string;
}

const { size = 12, color = 'currentColor' } = Astro.props;
---

<svg
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke={color}
	stroke-width="1.5"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	<line x1="5" y1="12" x2="19" y2="12"></line>
	<polyline points="13 6 19 12 13 18"></polyline>
</svg>
