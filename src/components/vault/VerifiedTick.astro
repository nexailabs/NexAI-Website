---
interface Props {
	size?: number;
}

const { size = 14 } = Astro.props;
---

<span
	class="verified-tick"
	style={`width: ${size}px; height: ${size}px;`}
	title="In active use at NexAI Labs"
	aria-label="Verified, in active use"
>
	<svg
		width={size * 0.7}
		height={size * 0.7}
		viewBox="0 0 24 24"
		fill="none"
		stroke="#050607"
		stroke-width="3.5"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<polyline points="20 6 9 17 4 12"></polyline>
	</svg>
</span>

<style>
	.verified-tick {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--color-brand-cyan);
		color: var(--color-bg);
		flex-shrink: 0;
	}
</style>
