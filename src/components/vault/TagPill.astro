---
interface Props {
	tag: string;
}

const { tag } = Astro.props;
---

<span class="tag-pill-vault">
	<span class="tag-pill-vault__hash" aria-hidden="true">#</span>{tag}
</span>

<style>
	.tag-pill-vault {
		display: inline-flex;
		align-items: center;
		padding: 4px 10px;
		border-radius: var(--radius-full);
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.02);
		font-family: var(--font-main);
		font-size: 0.72rem;
		color: var(--color-text-subtle);
		letter-spacing: 0.01em;
	}
	.tag-pill-vault__hash {
		color: var(--color-brand-cyan);
		opacity: 0.7;
		margin-right: 4px;
	}
</style>
