---
import type { HeroImage } from '../types/studio';
import { tr } from '../config/imagekit';

interface Props {
	decks: HeroImage[][];
}

const { decks } = Astro.props;

const heroSrcset = (src: string) => {
	const base = src.replace(tr.hero, '');
	return [
		`${base}?tr=w-400,h-533,fo-auto,f-auto,q-80 400w`,
		`${base}?tr=w-600,h-800,fo-auto,f-auto,q-80 600w`,
		`${base}?tr=w-900,h-1200,fo-auto,f-auto,q-80 900w`,
	].join(', ');
};
---

<div class="container shoots-hero__shell">
	<div class="shoots-hero__copy">
		<h1 class="shoots-hero__sr-only">AI Photoshoots for Fashion Brands</h1>
		<div class="shoots-hero__title-row">
			<span class="shoots-hero__title-word shoots-hero__title-word--left" data-hero-title="left"
				>NEXAI</span
			>
			<div class="shoots-hero__visual">
				<span class="shoots-hero__stack-stage" data-hero-stack-stage aria-hidden="true">
					{
						decks.map((deck, deckIndex) => (
							<span
								class:list={['shoots-hero__deck', `shoots-hero__deck--${deckIndex + 1}`]}
								data-hero-deck
							>
								{deck.map((item, index) => (
									<span
										class:list={['shoots-hero__card', `shoots-hero__card--${index + 1}`]}
										data-hero-card
									>
										<img
											src={item.src}
											srcset={heroSrcset(item.src)}
											sizes="(max-width: 720px) 60vw, 18vw"
											alt={item.alt}
											width="600"
											height="800"
											loading={deckIndex === 0 && index === 0 ? 'eager' : 'lazy'}
											decoding="async"
											fetchpriority={deckIndex === 0 && index === 0 ? 'high' : undefined}
										/>
									</span>
								))}
							</span>
						))
					}
				</span>
			</div>
			<span class="shoots-hero__title-word shoots-hero__title-word--right" data-hero-title="right"
				>STUDIO</span
			>
		</div>
	</div>

	<div role="group" class="shoots-hero__dock" data-hero-dock aria-label="Browse collections">
		{
			decks.map((deck, i) => (
				<button
					class:list={['shoots-hero__dock-thumb', i === 0 && 'shoots-hero__dock-thumb--active']}
					data-hero-thumb={i}
					aria-label={deck[0].alt}
				>
					<img
						src={deck[0].src.replace(tr.hero, tr.thumb)}
						alt=""
						width="200"
						height="200"
						loading="lazy"
						decoding="async"
					/>
				</button>
			))
		}
	</div>
</div>

<style>
	.shoots-hero__shell {
		width: 100%;
		display: grid;
		grid-template-rows: minmax(0, 1fr) auto;
		align-items: stretch;
		min-height: max(24rem, calc(100svh - var(--header-height, 5rem) - var(--shoots-marquee-space)));
		padding-top: 0;
		padding-bottom: clamp(1rem, 3vh, 2rem);
		row-gap: clamp(1.5rem, 3.5vh, 3rem);
	}

	.shoots-hero__copy {
		width: 100%;
		display: grid;
		justify-items: center;
		align-content: center;
		min-height: 0;
	}

	.shoots-hero__sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.shoots-hero__title-row {
		width: min(100%, 92rem);
		min-height: clamp(22rem, 45vh, 34rem);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(1.6rem, 2.8vw, 3rem);
	}

	.shoots-hero__title-word {
		flex: 1;
		display: block;
		min-width: 0;
		color: #fff;
		font-size: clamp(3.6rem, 7vw, 7.4rem);
		font-weight: 800;
		letter-spacing: -0.06em;
		line-height: 0.88;
		transition:
			transform 0.86s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.32s ease;
		will-change: transform, opacity;
		white-space: nowrap;
	}

	.shoots-hero__title-word--left {
		text-align: right;
	}

	.shoots-hero__title-word--right {
		text-align: left;
	}

	.shoots-hero__visual {
		flex: none;
		display: grid;
		place-items: center;
	}

	.shoots-hero__stack-stage {
		--hero-card-width: clamp(11rem, 18vw, 28rem);
		--hero-card-height: clamp(15rem, 25vw, 37.5rem);
		position: relative;
		width: var(--hero-card-width);
		height: var(--hero-card-height);
		overflow: visible;
		pointer-events: none;
	}

	.shoots-hero__deck {
		position: absolute;
		inset: 0;
		opacity: 0;
		visibility: hidden;
	}

	.shoots-hero__card {
		position: absolute;
		top: 50%;
		left: 50%;
		width: var(--hero-card-width);
		height: var(--hero-card-height);
		transform: translate(-50%, -50%);
		transform-origin: 50% 50%;
		border-radius: 1.2rem;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.03);
		opacity: 0;
		will-change: transform, opacity;
	}

	.shoots-hero__card img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	@media (max-width: 1100px) {
		.shoots-hero__title-row {
			min-height: 21rem;
			gap: clamp(1.2rem, 2.4vw, 2rem);
		}

		.shoots-hero__title-word {
			font-size: clamp(3rem, 7vw, 5.6rem);
		}
	}

	@media (max-width: 720px) {
		.shoots-hero__shell {
			min-height: max(
				20rem,
				calc(100svh - var(--header-height, 5rem) - var(--shoots-marquee-space))
			);
			padding-top: clamp(0.45rem, 1.8vh, 1rem);
			padding-bottom: clamp(2rem, 5vh, 4rem);
			row-gap: clamp(0.4rem, 1.2vh, 0.8rem);
		}

		.shoots-hero__copy {
			width: 100%;
			padding-bottom: 4vh;
		}

		.shoots-hero__title-row {
			width: 100%;
			min-height: clamp(17rem, 68vh, 23rem);
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
			justify-content: center;
			column-gap: clamp(0.4rem, 2vw, 0.8rem);
		}

		.shoots-hero__title-word {
			flex: none;
			font-size: clamp(2rem, 10.2vw, 3.8rem);
			letter-spacing: -0.03em;
		}

		.shoots-hero__title-word--left {
			justify-self: end;
		}

		.shoots-hero__title-word--right {
			justify-self: start;
		}

		.shoots-hero__stack-stage {
			--hero-card-width: clamp(12.1rem, 66vw, 17.6rem);
			--hero-card-height: clamp(16.2rem, 88.4vw, 23.5rem);
			width: 0;
			height: var(--hero-card-height);
			overflow: visible;
		}

		.shoots-hero__card {
			--hero-card-width: clamp(12.1rem, 66vw, 17.6rem);
			--hero-card-height: clamp(16.2rem, 88.4vw, 23.5rem);
			width: var(--hero-card-width);
			height: var(--hero-card-height);
			border-radius: 1rem;
		}

		.shoots-hero__dock {
			transform: scale(1.1);
		}
	}

	.shoots-hero__dock {
		position: relative;
		justify-self: center;
		display: flex;
		gap: 0.6rem;
		padding: 0.4rem;
		margin-top: clamp(0.5rem, 2vh, 1.5rem);
		background: rgba(255, 255, 255, 0.06);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-radius: 0.8rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		z-index: 20;
	}

	.shoots-hero__dock-thumb {
		all: unset;
		cursor: pointer;
		width: 3rem;
		aspect-ratio: 3 / 4;
		border-radius: 0.4rem;
		overflow: hidden;
		opacity: 0.5;
		border: 2px solid transparent;
		transition:
			opacity 0.3s ease,
			border-color 0.3s ease,
			transform 0.3s ease;
	}

	.shoots-hero__dock-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.shoots-hero__dock-thumb:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.7);
		outline-offset: 2px;
	}

	.shoots-hero__dock-thumb--active {
		opacity: 1;
		border-color: rgba(255, 255, 255, 0.5);
		transform: scale(1.1);
	}

	@media (prefers-reduced-motion: reduce) {
		.shoots-hero__title-word,
		.shoots-hero__card,
		.shoots-hero__dock-thumb {
			transition: none !important;
			animation: none !important;
		}
	}
</style>

<script src="../scripts/studio-hero.ts"></script>
