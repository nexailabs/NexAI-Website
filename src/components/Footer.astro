---
import { site } from '../config/site';
import { ik } from '../config/imagekit';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container site-footer__inner">
		<!-- Brand -->
		<div class="site-footer__brand">
			<a href="/" class="site-footer__logo" aria-label="NexAI Labs home">
				<img
					src={`${ik}/nexai/logos/nexai-icon.png?tr=w-80,h-80,fo-auto,f-auto,q-90`}
					alt=""
					width="28"
					height="28"
				/>
				<span>NexAI Labs</span>
			</a>
			<p class="site-footer__tagline">{site.description}</p>
		</div>

		<!-- Mobile CTA (hidden on desktop) -->
		<a class="site-footer__cta" href={site.bookingUrl} target="_blank" rel="noopener noreferrer">
			Book a Free Call
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path
					d="M3 8h10M9 4l4 4-4 4"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</a>

		<!-- Link columns -->
		<nav class="site-footer__nav" aria-label="Footer navigation">
			<div class="site-footer__col">
				<h3 class="site-footer__heading">Products</h3>
				<ul class="site-footer__links">
					<li><a href="/studio">NexAI Studio</a></li>
					<li><a href="/coming-soon">Agent Lab</a></li>
					<li><a href="/coming-soon">Prompt Hub</a></li>
					<li><a href="/coming-soon">App Vault</a></li>
				</ul>
			</div>
			<div class="site-footer__col">
				<h3 class="site-footer__heading">Studio</h3>
				<ul class="site-footer__links">
					<li><a href="/studio#showcase">Showcase</a></li>
					<li><a href="/studio/gallery">Gallery</a></li>
					<li class="site-footer__hide-mobile">
						<a href={site.bookingUrl} target="_blank" rel="noopener noreferrer">Book a Call</a>
					</li>
				</ul>
			</div>
			<div class="site-footer__col site-footer__col--connect">
				<h3 class="site-footer__heading">Connect</h3>
				<!-- Social icons (shown on mobile, text links on desktop) -->
				<div class="site-footer__socials">
					<a
						href="https://www.instagram.com/nexailabs/"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Instagram"
						class="site-footer__social-icon"
					>
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="5"
							></circle><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"
							></circle></svg
						>
						<span class="site-footer__social-label">Instagram</span>
					</a>
					<a
						href="https://www.linkedin.com/company/nexailabs/"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="site-footer__social-icon"
					>
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"></path><rect
								x="2"
								y="9"
								width="4"
								height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg
						>
						<span class="site-footer__social-label">LinkedIn</span>
					</a>
					<a
						href="https://www.youtube.com/@nexailabs"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="YouTube"
						class="site-footer__social-icon"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
							><path
								d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.7 31.7 0 000 12a31.7 31.7 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.7 31.7 0 0024 12a31.7 31.7 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"
							></path></svg
						>
						<span class="site-footer__social-label">YouTube</span>
					</a>
				</div>
				<a href={`mailto:${site.email}`} class="site-footer__email">{site.email}</a>
			</div>
		</nav>
	</div>

	<!-- Bottom bar -->
	<div class="container site-footer__bottom">
		<span>&copy; {year} {site.name}. All rights reserved.</span>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		z-index: 2;
		background: var(--color-bg);
		border-top: 1px solid var(--color-border);
		padding-top: clamp(3rem, 6vh, 5rem);
		padding-bottom: clamp(1.5rem, 3vh, 2.5rem);
	}

	.site-footer__inner {
		display: grid;
		grid-template-columns: 1.2fr repeat(3, 1fr);
		gap: clamp(2rem, 4vw, 4rem);
	}

	/* ── Brand ── */
	.site-footer__logo {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--color-text-main);
		font-family: var(--font-brand);
		font-weight: var(--fw-bold);
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.site-footer__logo img {
		border-radius: 6px;
	}

	.site-footer__tagline {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: var(--lh-body);
		margin-top: 0.75rem;
		max-width: 22ch;
	}

	/* ── CTA (mobile only) ── */
	.site-footer__cta {
		display: none;
	}

	/* ── Nav columns ── */
	.site-footer__nav {
		display: contents;
	}

	.site-footer__heading {
		font-family: var(--font-main);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		color: var(--color-text-main);
		margin-bottom: 1rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.site-footer__links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.site-footer__links a {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.site-footer__links a:hover {
		color: var(--color-text-main);
	}

	/* ── Socials (desktop: pill boxes with icon + label; mobile: icon-only squares) ── */
	.site-footer__socials {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-footer__social-icon {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.5rem 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.site-footer__social-icon svg {
		display: block; /* always shown — icon + text on desktop */
		flex-shrink: 0;
	}

	.site-footer__social-icon:hover {
		color: var(--color-brand-cyan);
		border-color: var(--color-brand-cyan);
		background: rgba(78, 201, 180, 0.06);
	}

	.site-footer__email {
		display: inline-flex;
		align-items: center;
		margin-top: 0.75rem;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.5rem 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.site-footer__email:hover {
		color: var(--color-brand-cyan);
		border-color: var(--color-brand-cyan);
		background: rgba(78, 201, 180, 0.06);
	}

	.site-footer__hide-mobile {
		display: list-item;
	}

	/* ── Bottom bar ── */
	.site-footer__bottom {
		margin-top: clamp(2rem, 4vh, 3rem);
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	/* ════════════════════════════════════════════════════ */
	/*                     MOBILE                          */
	/* ════════════════════════════════════════════════════ */
	@media (max-width: 720px) {
		.site-footer {
			padding-top: 2.5rem;
		}

		.site-footer__inner {
			display: flex;
			flex-direction: column;
			gap: 0;
		}

		/* ── Brand — compact ── */
		.site-footer__brand {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding-bottom: 1.5rem;
		}

		.site-footer__tagline {
			margin-top: 0;
			font-size: var(--text-xs);
			max-width: none;
		}

		/* ── CTA button — full width teal gradient ── */
		.site-footer__cta {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
			width: 100%;
			padding: 1rem;
			border-radius: 12px;
			background: var(--color-brand-gradient);
			color: #fff;
			font-family: var(--font-main);
			font-weight: var(--fw-semibold);
			font-size: 0.95rem;
			text-decoration: none;
			margin-bottom: 1.5rem;
			transition: opacity 0.2s ease;
		}

		.site-footer__cta:hover {
			opacity: 0.9;
		}

		/* ── Nav columns — compact sections ── */
		.site-footer__nav {
			display: flex;
			flex-direction: column;
			gap: 0;
		}

		.site-footer__col {
			padding: 1.25rem 0;
			border-top: 1px solid var(--color-border);
		}

		.site-footer__heading {
			font-size: var(--text-xs);
			margin-bottom: 0.75rem;
			color: var(--color-text-main);
			letter-spacing: 0.1em;
		}

		.site-footer__links {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0;
		}

		.site-footer__links li {
			display: inline;
		}

		.site-footer__links li::after {
			content: '·';
			color: var(--color-text-muted);
			margin: 0 0.5rem;
		}

		.site-footer__links li:last-child::after {
			display: none;
		}

		.site-footer__hide-mobile {
			display: none;
		}

		/* ── Social icons — horizontal row, icon-only squares ── */
		.site-footer__socials {
			flex-direction: row;
			gap: 1rem;
		}

		.site-footer__social-label {
			display: none; /* hide text label, icon only */
		}

		.site-footer__social-icon {
			width: 40px;
			height: 40px;
			padding: 0;
			border-radius: 10px;
			justify-content: center;
		}

		.site-footer__social-icon:hover {
			border-color: var(--color-brand-cyan);
			color: var(--color-brand-cyan);
			background: rgba(78, 201, 180, 0.06);
		}

		.site-footer__email {
			margin-top: 1rem;
			font-size: var(--text-xs);
			color: var(--color-text-dim);
		}

		/* ── Bottom ── */
		.site-footer__bottom {
			margin-top: 1.5rem;
			text-align: center;
		}
	}
</style>
