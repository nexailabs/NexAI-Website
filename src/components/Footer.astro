---
import { site, socials } from '../config/site';
import { ik } from '../config/imagekit';
import SocialIcon from './SocialIcon.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container site-footer__inner">
		<!-- Brand -->
		<div class="site-footer__brand">
			<a href="/" class="site-footer__logo" aria-label="NexAI Labs home">
				<img
					src={`${ik}/nexai/logos/nexai-icon.png?tr=w-80,h-80,fo-auto,f-auto,q-90`}
					alt=""
					width="28"
					height="28"
				/>
				<span>NexAI Labs</span>
			</a>
			<p class="site-footer__tagline">{site.description}</p>
		</div>

		<!-- Mobile CTA (hidden on desktop) -->
		<a class="site-footer__cta" href="#book" data-open-cal>
			Book a Free Call
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path
					d="M3 8h10M9 4l4 4-4 4"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</a>

		<!-- Link columns -->
		<nav class="site-footer__nav" aria-label="Footer navigation">
			<div class="site-footer__col">
				<h3 class="site-footer__heading">Products</h3>
				<ul class="site-footer__links">
					<li><a href="/studio">NexAI Studio</a></li>
					<li><a href="/coming-soon">Agent Lab</a></li>
					<li><a href="/coming-soon">Prompt Hub</a></li>
					<li><a href="/coming-soon">App Vault</a></li>
				</ul>
			</div>
			<div class="site-footer__col">
				<h3 class="site-footer__heading">Studio</h3>
				<ul class="site-footer__links">
					<li><a href="/studio#showcase">Showcase</a></li>
					<li><a href="/studio/gallery">Gallery</a></li>
					<li class="site-footer__hide-mobile">
						<a href="#book" data-open-cal>Book a Call</a>
					</li>
				</ul>
			</div>
			<div class="site-footer__col site-footer__col--connect">
				<h3 class="site-footer__heading">Connect</h3>
				<!-- Social icons (shown on mobile, text links on desktop) -->
				<div class="site-footer__socials">
					{
						socials.map((s) => (
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={s.label}
								class="site-footer__social-icon"
							>
								<SocialIcon platform={s.platform} />
							</a>
						))
					}
				</div>
				<a href={`mailto:${site.email}`} class="site-footer__email">{site.email}</a>
			</div>
		</nav>
	</div>

	<!-- Bottom bar -->
	<div class="container site-footer__bottom">
		<span>&copy; {year} {site.name}. All rights reserved.</span>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		z-index: 2;
		background: var(--color-bg);
		border-top: 1px solid var(--color-border);
		padding-top: clamp(3rem, 6vh, 5rem);
		padding-bottom: clamp(1.5rem, 3vh, 2.5rem);
	}

	.site-footer__inner {
		display: grid;
		grid-template-columns: 1.2fr repeat(3, 1fr);
		gap: clamp(2rem, 4vw, 4rem);
	}

	/* ── Brand ── */
	.site-footer__logo {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--color-text-main);
		font-family: var(--font-brand);
		font-weight: var(--fw-bold);
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.site-footer__logo img {
		border-radius: 6px;
	}

	.site-footer__tagline {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: var(--lh-body);
		margin-top: 0.75rem;
		max-width: 22ch;
	}

	/* ── CTA (mobile only) ── */
	.site-footer__cta {
		display: none;
	}

	/* ── Nav columns ── */
	.site-footer__nav {
		display: contents;
	}

	.site-footer__heading {
		font-family: var(--font-main);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		color: var(--color-text-main);
		margin-bottom: 1rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.site-footer__links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.site-footer__links a {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.site-footer__links a:hover {
		color: var(--color-text-main);
	}

	/* ── Socials (desktop: pill boxes with icon + label; mobile: icon-only squares) ── */
	.site-footer__socials {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-footer__social-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		color: var(--color-text-muted);
		text-decoration: none;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 999px;
		background: transparent;
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.site-footer__social-icon svg {
		display: block;
		flex-shrink: 0;
	}

	.site-footer__social-icon:hover {
		color: rgba(255, 255, 255, 0.9);
		border-color: var(--color-border-hover);
		transform: translateY(-2px);
	}

	.site-footer__email {
		display: inline-flex;
		align-items: center;
		margin-top: 0.75rem;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.5rem 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.site-footer__email:hover {
		color: var(--color-brand-cyan);
		border-color: var(--color-brand-cyan);
		background: rgba(78, 201, 180, 0.06);
	}

	.site-footer__hide-mobile {
		display: list-item;
	}

	/* ── Bottom bar ── */
	.site-footer__bottom {
		margin-top: clamp(2rem, 4vh, 3rem);
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	/* ════════════════════════════════════════════════════ */
	/*                     MOBILE                          */
	/* ════════════════════════════════════════════════════ */
	@media (max-width: 720px) {
		.site-footer {
			padding-top: 2.5rem;
		}

		.site-footer__inner {
			display: flex;
			flex-direction: column;
			gap: 0;
		}

		/* ── Brand — compact ── */
		.site-footer__brand {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding-bottom: 1.5rem;
		}

		.site-footer__tagline {
			margin-top: 0;
			font-size: var(--text-xs);
			max-width: none;
		}

		/* ── CTA button — full width teal gradient ── */
		.site-footer__cta {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
			width: 100%;
			padding: 1rem;
			border-radius: 12px;
			background: var(--color-brand-gradient);
			color: #fff;
			font-family: var(--font-main);
			font-weight: var(--fw-semibold);
			font-size: 0.95rem;
			text-decoration: none;
			margin-bottom: 1.5rem;
			transition: opacity 0.2s ease;
		}

		.site-footer__cta:hover {
			opacity: 0.9;
		}

		/* ── Nav columns — compact sections ── */
		.site-footer__nav {
			display: flex;
			flex-direction: column;
			gap: 0;
		}

		.site-footer__col {
			padding: 1.25rem 0;
			border-top: 1px solid var(--color-border);
		}

		.site-footer__heading {
			font-size: var(--text-xs);
			margin-bottom: 0.75rem;
			color: var(--color-text-main);
			letter-spacing: 0.1em;
		}

		.site-footer__links {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0;
		}

		.site-footer__links li {
			display: inline;
		}

		.site-footer__links li::after {
			content: '·';
			color: var(--color-text-muted);
			margin: 0 0.5rem;
		}

		.site-footer__links li:last-child::after {
			display: none;
		}

		.site-footer__hide-mobile {
			display: none;
		}

		.site-footer__email {
			margin-top: 1rem;
			font-size: var(--text-xs);
			color: var(--color-text-dim);
		}

		/* ── Bottom ── */
		.site-footer__bottom {
			margin-top: 1.5rem;
			text-align: center;
		}
	}
</style>
