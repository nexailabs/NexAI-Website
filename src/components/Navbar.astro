---
import type { NavGroup } from '../types/ai-shoots';

interface Props {
	navGroups?: NavGroup[];
	topHref?: string;
	brandAriaLabel?: string;
	ctaHref?: string;
	ctaLabel?: string;
	email?: string;
	panelId?: string;
}

const defaultNavGroups: NavGroup[] = [
	{
		label: 'NexAI Studio',
		href: '/ai-shoots',
		caption: 'AI-powered photoshoots for fashion brands.',
		children: [
			{ label: 'Ethnic Wear', href: '/coming-soon' },
			{ label: 'Saree', href: '/coming-soon' },
			{ label: 'Video Gen', href: '/coming-soon' },
		],
	},
	{
		label: 'Agent Lab',
		href: '/coming-soon',
		caption: 'Custom AI agents built for your workflow.',
	},
	{
		label: 'Prompt Hub',
		href: '/coming-soon',
		caption: 'Curated prompts, skills, and SOPs we swear by.',
	},
	{
		label: 'App Vault',
		href: '/coming-soon',
		caption: 'The best AI tools we use and recommend.',
	},
	{
		label: 'AI Drops',
		href: '/coming-soon',
		caption: "Dispatches on what we're building and learning.",
	},
	{
		label: 'Catch Us',
		href: '/coming-soon',
		caption: "Let's talk — no pitch decks, just coffee.",
	},
];

const {
	navGroups = defaultNavGroups,
	topHref = '#top',
	brandAriaLabel = 'NexAI Labs home',
	ctaHref = 'https://cal.com/nexailabs/15min',
	ctaLabel = 'Book a Call',
	email = 'hello@nexailabs.com',
	panelId = 'primary-nav-takeover',
} = Astro.props;
---

<header class="prod-signal-nav" data-prod-signal-nav data-open="false">
	<div class="prod-signal-nav__inner container">
		<div class="prod-signal-nav__bar">
			<a href={topHref} class="prod-signal-nav__brand" aria-label={brandAriaLabel}>
				<img src="/assets/logo/nexai-icon.png" alt="" width="40" height="40" />
				<span>NexAI Labs</span>
			</a>

			<div class="prod-signal-nav__line" aria-hidden="true"></div>

			<div class="prod-signal-nav__actions">
				<a class="prod-signal-nav__cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>

				<button
					class="prod-signal-nav__trigger"
					type="button"
					data-nav-trigger
					aria-expanded="false"
					aria-controls={panelId}
					aria-label="Open navigation"
				>
					<span class="prod-signal-nav__trigger-core" aria-hidden="true">
						<i></i>
						<i></i>
						<i></i>
					</span>
				</button>
			</div>
		</div>
	</div>

	<div class="prod-signal-nav__takeover" id={panelId} data-nav-panel aria-hidden="true">
		<div class="prod-signal-nav__takeover-shell container">
			<nav class="prod-signal-nav__list" aria-label="Primary">
				{
					navGroups.map((group) =>
						group.children && group.children.length > 0 ? (
							<div class="prod-signal-nav__item" data-nav-group>
								<div class="prod-signal-nav__item-header">
									<a href={group.href} class="prod-signal-nav__item-link" data-nav-close>
										<div class="prod-signal-nav__item-copy">
											<strong class="prod-signal-nav__label">{group.label}</strong>
											{group.caption && <small>{group.caption}</small>}
										</div>
									</a>
									<button
										class="prod-signal-nav__expand"
										data-nav-expand
										aria-expanded="false"
										aria-label={`Expand ${group.label}`}
									>
										<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
											<path
												d="M5 8l5 5 5-5"
												stroke="currentColor"
												stroke-width="1.5"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</button>
								</div>
								<div class="prod-signal-nav__sub" data-nav-sub hidden>
									{group.children.map((child) => (
										<a href={child.href} class="prod-signal-nav__sub-link" data-nav-close>
											{child.label}
										</a>
									))}
								</div>
							</div>
						) : (
							<a class="prod-signal-nav__item" href={group.href} data-nav-close>
								<div class="prod-signal-nav__item-copy">
									<strong class="prod-signal-nav__label">{group.label}</strong>
									{group.caption && <small>{group.caption}</small>}
								</div>
							</a>
						),
					)
				}
			</nav>

			<div class="prod-signal-nav__takeover-foot">
				<a class="prod-signal-nav__panel-cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>
				<a class="prod-signal-nav__panel-email" href={`mailto:${email}`}>{email}</a>
			</div>
		</div>
	</div>
</header>

<script src="../scripts/navbar.ts"></script>

<style>
	.prod-signal-nav {
		position: fixed;
		inset: 0 0 auto;
		z-index: 100;
		padding-top: 1rem;
		pointer-events: none;
	}

	.prod-signal-nav__inner,
	.prod-signal-nav__takeover {
		pointer-events: none;
	}

	.prod-signal-nav__bar,
	.prod-signal-nav__takeover,
	.prod-signal-nav__trigger,
	.prod-signal-nav__cta,
	.prod-signal-nav__brand {
		pointer-events: auto;
	}

	.prod-signal-nav__bar {
		position: relative;
		z-index: 4;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.4rem 0 0.1rem;
		transition:
			padding 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			margin 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.5s ease,
			border-radius 0.5s ease,
			background 0.5s ease,
			backdrop-filter 0.5s ease,
			box-shadow 0.5s ease,
			opacity 0.3s ease;
	}

	.prod-signal-nav.is-scrolled .prod-signal-nav__bar {
		padding: 0.72rem 1.15rem 0.42rem;
		margin-inline: -1.15rem;
		border-radius: 1.65rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.7);
		backdrop-filter: blur(18px);
		box-shadow: 0 16px 50px rgba(0, 0, 0, 0.2);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__bar {
		padding: 0.4rem 0 0.1rem;
		margin-inline: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		backdrop-filter: none;
		box-shadow: none;
	}

	.prod-signal-nav__brand,
	.prod-signal-nav__cta,
	.prod-signal-nav__item,
	.prod-signal-nav__item-link,
	.prod-signal-nav__sub-link,
	.prod-signal-nav__panel-cta,
	.prod-signal-nav__panel-email {
		color: inherit;
		text-decoration: none;
	}

	.prod-signal-nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.98rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.prod-signal-nav__brand img {
		width: 2rem;
		height: 2rem;
		display: block;
		flex: none;
		background: transparent;
		mix-blend-mode: screen;
	}

	.prod-signal-nav__line {
		height: 1px;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04));
		transition: opacity 0.3s ease;
	}

	.prod-signal-nav.is-scrolled .prod-signal-nav__line {
		opacity: 0.4;
	}

	.prod-signal-nav__actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		justify-self: end;
	}

	.prod-signal-nav__cta,
	.prod-signal-nav__panel-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.88rem 1.08rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.03);
		font-size: 0.92rem;
		font-weight: 600;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			background 0.3s ease,
			opacity 0.3s ease;
	}

	.prod-signal-nav__cta:hover,
	.prod-signal-nav__panel-cta:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.06);
	}

	.prod-signal-nav__cta:focus-visible,
	.prod-signal-nav__panel-cta:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.06);
		outline: 2px solid rgba(255, 255, 255, 0.5);
		outline-offset: 2px;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__cta {
		opacity: 0;
		transform: translateY(-6px);
		pointer-events: none;
		visibility: hidden;
	}

	.prod-signal-nav__trigger {
		position: relative;
		z-index: 5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.7rem;
		height: 3.7rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: rgba(11, 12, 13, 0.88);
		backdrop-filter: blur(12px);
		cursor: pointer;
		transition:
			transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.3s ease,
			background 0.3s ease,
			box-shadow 0.3s ease;
	}

	.prod-signal-nav__trigger:hover,
	.prod-signal-nav__trigger:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.3);
		background: rgba(15, 17, 18, 0.96);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
		outline: none;
	}

	.prod-signal-nav__trigger-core {
		position: relative;
		display: inline-flex;
		width: 1.55rem;
		height: 1.55rem;
		align-items: center;
		justify-content: center;
	}

	.prod-signal-nav__trigger-core::before {
		content: '';
		position: absolute;
		inset: -0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 999px;
		animation: prod-signal-pulse 2.8s ease-in-out infinite;
	}

	.prod-signal-nav__trigger-core i {
		position: absolute;
		display: block;
		width: 1.45rem;
		height: 1.5px;
		background: rgba(255, 255, 255, 0.98);
		transform-origin: center;
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.3s ease;
	}

	.prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(0deg);
	}

	.prod-signal-nav__trigger-core i:nth-child(2) {
		transform: rotate(60deg);
	}

	.prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(120deg);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger {
		border-color: rgba(255, 255, 255, 0.26);
		background: rgba(10, 11, 12, 0.98);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i {
		background: rgba(255, 255, 255, 0.8);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core::before {
		animation: none;
		opacity: 0.82;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(45deg);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(2) {
		opacity: 0;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(-45deg);
	}

	.prod-signal-nav__takeover {
		position: fixed;
		inset: 0;
		z-index: 1;
		background:
			radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.035), transparent 24%),
			radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.02), transparent 30%), #050607;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.5s ease,
			visibility 0s linear 0.5s;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__takeover {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition:
			opacity 0.5s ease,
			visibility 0s linear 0s;
	}

	.prod-signal-nav__takeover-shell {
		display: grid;
		grid-template-rows: 1fr auto;
		height: 100vh;
		height: 100dvh;
		padding-top: clamp(4rem, 10dvh, 7rem);
		padding-bottom: clamp(1rem, 3dvh, 2rem);
	}

	.prod-signal-nav__list {
		display: grid;
		align-content: start;
		gap: 0;
		padding-top: clamp(0.5rem, 1.5dvh, 1.5rem);
	}

	/* ── Nav items (shared) ── */

	.prod-signal-nav__item {
		display: block;
		padding: clamp(0.35rem, 1dvh, 0.9rem) 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateY(24px);
		transition:
			transform 0.75s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.5s ease,
			border-color 0.3s ease;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item {
		opacity: 1;
		transform: translateY(0);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(1) {
		transition-delay: 0.06s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(2) {
		transition-delay: 0.12s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(3) {
		transition-delay: 0.18s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(4) {
		transition-delay: 0.24s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(5) {
		transition-delay: 0.3s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(6) {
		transition-delay: 0.36s;
	}

	.prod-signal-nav__item-copy {
		display: grid;
		gap: clamp(0.15rem, 0.5dvh, 0.45rem);
	}

	.prod-signal-nav__label {
		display: inline-block;
		font-size: clamp(1.6rem, 4dvh, 4rem);
		line-height: 0.92;
		font-weight: 600;
		letter-spacing: -0.045em;
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			letter-spacing 0.5s ease,
			color 0.3s ease,
			text-shadow 0.3s ease;
	}

	.prod-signal-nav__item-copy small {
		max-width: 38rem;
		color: rgba(255, 255, 255, 0.48);
		font-size: clamp(0.65rem, 1.1dvh, 0.88rem);
		line-height: 1.5;
		transition:
			color 0.3s ease,
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* Hover — applies to both plain items and item-link inside groups */
	.prod-signal-nav__item:hover,
	.prod-signal-nav__item:focus-visible,
	.prod-signal-nav__item-link:hover,
	.prod-signal-nav__item-link:focus-visible {
		border-color: rgba(255, 255, 255, 0.12);
		outline: none;
	}

	.prod-signal-nav__item:hover > .prod-signal-nav__item-copy .prod-signal-nav__label,
	.prod-signal-nav__item:focus-visible > .prod-signal-nav__item-copy .prod-signal-nav__label,
	.prod-signal-nav__item-link:hover .prod-signal-nav__label,
	.prod-signal-nav__item-link:focus-visible .prod-signal-nav__label {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.015em;
		transform: translateX(10px);
		text-shadow: 0 0 24px rgba(255, 255, 255, 0.04);
	}

	.prod-signal-nav__item:hover > .prod-signal-nav__item-copy small,
	.prod-signal-nav__item:focus-visible > .prod-signal-nav__item-copy small,
	.prod-signal-nav__item-link:hover small,
	.prod-signal-nav__item-link:focus-visible small {
		color: rgba(255, 255, 255, 0.68);
		transform: translateX(10px);
	}

	/* ── Collapsible group (items with children) ── */

	.prod-signal-nav__item-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.prod-signal-nav__item-link {
		flex: 1;
		min-width: 0;
	}

	.prod-signal-nav__expand {
		all: unset;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		flex: none;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.5);
		transition:
			transform 0.3s ease,
			color 0.3s ease,
			border-color 0.3s ease,
			background 0.3s ease;
	}

	.prod-signal-nav__expand:hover,
	.prod-signal-nav__expand:focus-visible {
		color: rgba(255, 255, 255, 0.9);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.04);
		outline: none;
	}

	.prod-signal-nav__expand svg {
		transition: transform 0.3s ease;
	}

	.prod-signal-nav__expand[aria-expanded='true'] svg {
		transform: rotate(180deg);
	}

	.prod-signal-nav__sub {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__sub[hidden] {
		display: grid;
		grid-template-rows: 0fr;
	}

	.prod-signal-nav__sub:not([hidden]) {
		grid-template-rows: 1fr;
	}

	.prod-signal-nav__sub > * {
		overflow: hidden;
	}

	.prod-signal-nav__sub-link {
		display: block;
		padding: clamp(0.3rem, 0.6dvh, 0.5rem) 0 clamp(0.3rem, 0.6dvh, 0.5rem) 1.2rem;
		font-size: clamp(0.82rem, 1.4dvh, 1.05rem);
		color: rgba(255, 255, 255, 0.55);
		border-left: 2px solid rgba(255, 255, 255, 0.1);
		transition:
			color 0.3s ease,
			border-color 0.3s ease,
			padding-left 0.3s ease;
	}

	.prod-signal-nav__sub-link:hover,
	.prod-signal-nav__sub-link:focus-visible {
		color: rgba(255, 255, 255, 0.9);
		border-left-color: rgba(78, 201, 180, 0.6);
		padding-left: 1.5rem;
		outline: none;
	}

	/* ── Footer ── */

	.prod-signal-nav__takeover-foot {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding-top: clamp(0.5rem, 1.5dvh, 1.5rem);
	}

	.prod-signal-nav__panel-email {
		font-size: 0.86rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		transition: color 0.3s ease;
	}

	.prod-signal-nav__panel-email:hover,
	.prod-signal-nav__panel-email:focus-visible {
		color: rgba(255, 255, 255, 0.78);
		outline: none;
	}

	/* ── Responsive ── */

	@media (max-width: 900px) {
		.prod-signal-nav {
			padding-top: 0.85rem;
		}

		.prod-signal-nav__cta {
			display: none;
		}

		.prod-signal-nav__takeover-shell {
			padding-top: clamp(3.5rem, 9dvh, 6.35rem);
			padding-bottom: clamp(0.75rem, 2dvh, 1.35rem);
		}

		.prod-signal-nav__label {
			font-size: clamp(1.4rem, 3.5dvh, 3rem);
		}

		.prod-signal-nav__item-copy small {
			max-width: none;
			font-size: clamp(0.6rem, 1dvh, 0.82rem);
		}

		.prod-signal-nav__takeover-foot {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 640px) {
		.prod-signal-nav__bar {
			grid-template-columns: minmax(0, auto) 1fr auto;
			gap: 0.75rem;
		}

		.prod-signal-nav__brand {
			gap: 0.55rem;
			font-size: 0.8rem;
			letter-spacing: 0.06em;
		}

		.prod-signal-nav__brand img {
			width: 1.7rem;
			height: 1.7rem;
		}

		.prod-signal-nav__trigger {
			width: 3.35rem;
			height: 3.35rem;
		}

		.prod-signal-nav__item {
			padding: clamp(0.25rem, 0.8dvh, 0.7rem) 0;
		}
	}

	@media (max-width: 380px) {
		.prod-signal-nav__brand span {
			display: none;
		}

		.prod-signal-nav__bar {
			gap: 0.5rem;
		}
	}

	@keyframes prod-signal-pulse {
		0%,
		100% {
			transform: scale(0.85);
			opacity: 0.3;
		}

		50% {
			transform: scale(1.05);
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.prod-signal-nav__trigger-core::before,
		.prod-signal-nav__trigger-core i,
		.prod-signal-nav__item,
		.prod-signal-nav__label,
		.prod-signal-nav__sub,
		.prod-signal-nav__expand svg {
