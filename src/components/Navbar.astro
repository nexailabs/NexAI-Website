---
interface NavLink {
	label: string;
	href: string;
	caption: string;
}

interface Props {
	navLinks?: NavLink[];
	topHref?: string;
	brandAriaLabel?: string;
	ctaHref?: string;
	ctaLabel?: string;
	email?: string;
	takeoverMeta?: string;
	panelId?: string;
}

const defaultNavLinks: NavLink[] = [
	{
		label: 'Services',
		href: '#services',
		caption: 'Core automation offers across sales, content, workflow, and support.',
	},
	{
		label: 'Process',
		href: '#process',
		caption: 'How NexAI audits, builds, and ships systems without bloated delivery cycles.',
	},
	{
		label: 'Work',
		href: '#work',
		caption: 'Selected proof, case-study signals, and productized outcomes from recent work.',
	},
	{
		label: 'FAQ',
		href: '#faq',
		caption: 'Buying-friction answers on delivery speed, tooling, fit, and reliability.',
	},
];

const {
	navLinks = defaultNavLinks,
	topHref = '#top',
	brandAriaLabel = 'NexAI Labs home',
	ctaHref = 'https://cal.com/nexailabs/15min',
	ctaLabel = 'Book a Call',
	email = 'hello@nexailabs.com',
	takeoverMeta = 'India / Remote',
	panelId = 'primary-nav-takeover',
} = Astro.props;
---

<header class="prod-signal-nav" data-prod-signal-nav data-open="false">
	<div class="prod-signal-nav__inner container">
		<div class="prod-signal-nav__bar">
			<a href={topHref} class="prod-signal-nav__brand" aria-label={brandAriaLabel}>
				<img src="/assets/logo/nexai-icon.png" alt="" width="40" height="40" />
				<span>NexAI Labs</span>
			</a>

			<div class="prod-signal-nav__line" aria-hidden="true"></div>

			<div class="prod-signal-nav__actions">
				<a class="prod-signal-nav__cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>

				<button
					class="prod-signal-nav__trigger"
					type="button"
					data-nav-trigger
					aria-expanded="false"
					aria-controls={panelId}
					aria-label="Open navigation"
				>
					<span class="prod-signal-nav__trigger-core" aria-hidden="true">
						<i></i>
						<i></i>
						<i></i>
					</span>
				</button>
			</div>
		</div>
	</div>

	<div class="prod-signal-nav__takeover" id={panelId} data-nav-panel aria-hidden="true">
		<div class="prod-signal-nav__takeover-shell container">
			<div class="prod-signal-nav__takeover-meta">
				<span>{takeoverMeta}</span>
			</div>

			<nav class="prod-signal-nav__list" aria-label="Primary">
				{
					navLinks.map((link) => (
						<a class="prod-signal-nav__item" href={link.href} data-nav-close>
							<div class="prod-signal-nav__item-copy">
								<strong class="prod-signal-nav__label">{link.label}</strong>
								<small>{link.caption}</small>
							</div>
						</a>
					))
				}
			</nav>

			<div class="prod-signal-nav__takeover-foot">
				<a class="prod-signal-nav__panel-cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>
				<a class="prod-signal-nav__panel-email" href={`mailto:${email}`}>{email}</a>
			</div>
		</div>
	</div>
</header>

<script is:inline>
	const initProductionSignalNav = () => {
		const root = document.querySelector('[data-prod-signal-nav]');
		if (!root || root.dataset.ready === 'true') return;

		root.dataset.ready = 'true';

		const trigger = root.querySelector('[data-nav-trigger]');
		const panel = root.querySelector('[data-nav-panel]');
		const closers = root.querySelectorAll('[data-nav-close]');

		const syncScrollState = () => {
			root.classList.toggle('is-scrolled', window.scrollY > 24);
		};

		const closeMenu = () => {
			root.dataset.open = 'false';
			trigger?.setAttribute('aria-expanded', 'false');
			trigger?.setAttribute('aria-label', 'Open navigation');
			panel?.setAttribute('aria-hidden', 'true');
			document.body.classList.remove('nav-open');
		};

		const openMenu = () => {
			root.dataset.open = 'true';
			trigger?.setAttribute('aria-expanded', 'true');
			trigger?.setAttribute('aria-label', 'Close navigation');
			panel?.setAttribute('aria-hidden', 'false');
			document.body.classList.add('nav-open');
		};

		trigger?.addEventListener('click', () => {
			if (root.dataset.open === 'true') {
				closeMenu();
				return;
			}

			openMenu();
		});

		closers.forEach((link) => {
			link.addEventListener('click', () => closeMenu());
		});

		window.addEventListener('scroll', syncScrollState, { passive: true });
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && root.dataset.open === 'true') {
				closeMenu();
			}
		});

		syncScrollState();
	};

	initProductionSignalNav();
	document.addEventListener('astro:page-load', initProductionSignalNav);
</script>

<style>
	.prod-signal-nav {
		position: fixed;
		inset: 0 0 auto;
		z-index: 100;
		padding-top: 1rem;
		pointer-events: none;
	}

	.prod-signal-nav__inner,
	.prod-signal-nav__takeover {
		pointer-events: none;
	}

	.prod-signal-nav__bar,
	.prod-signal-nav__takeover,
	.prod-signal-nav__trigger,
	.prod-signal-nav__cta,
	.prod-signal-nav__brand {
		pointer-events: auto;
	}

	.prod-signal-nav__bar {
		position: relative;
		z-index: 4;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.4rem 0 0.1rem;
		transition:
			padding 0.45s cubic-bezier(0.16, 1, 0.3, 1),
			margin 0.45s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.45s ease,
			border-radius 0.45s ease,
			background 0.45s ease,
			backdrop-filter 0.45s ease,
			box-shadow 0.45s ease,
			opacity 0.35s ease;
	}

	.prod-signal-nav.is-scrolled .prod-signal-nav__bar {
		padding: 0.72rem 1.15rem 0.42rem;
		margin-inline: -1.15rem;
		border-radius: 1.65rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.7);
		backdrop-filter: blur(18px);
		box-shadow: 0 16px 50px rgba(0, 0, 0, 0.2);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__bar {
		padding: 0.4rem 0 0.1rem;
		margin-inline: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		backdrop-filter: none;
		box-shadow: none;
	}

	.prod-signal-nav__brand,
	.prod-signal-nav__cta,
	.prod-signal-nav__item,
	.prod-signal-nav__panel-cta,
	.prod-signal-nav__panel-email {
		color: inherit;
		text-decoration: none;
	}

	.prod-signal-nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.98rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.prod-signal-nav__brand img {
		width: 2rem;
		height: 2rem;
		display: block;
		flex: none;
	}

	.prod-signal-nav__line {
		height: 1px;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04));
		transition: opacity 0.35s ease;
	}

	.prod-signal-nav__actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		justify-self: end;
	}

	.prod-signal-nav__cta,
	.prod-signal-nav__panel-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.88rem 1.08rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.03);
		font-size: 0.92rem;
		font-weight: 600;
		transition:
			transform 0.32s ease,
			border-color 0.32s ease,
			background 0.32s ease,
			opacity 0.32s ease;
	}

	.prod-signal-nav__cta:hover,
	.prod-signal-nav__cta:focus-visible,
	.prod-signal-nav__panel-cta:hover,
	.prod-signal-nav__panel-cta:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.06);
		outline: none;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__cta {
		opacity: 0;
		transform: translateY(-6px);
		pointer-events: none;
	}

	.prod-signal-nav__trigger {
		position: relative;
		z-index: 5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.7rem;
		height: 3.7rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: rgba(11, 12, 13, 0.88);
		backdrop-filter: blur(12px);
		cursor: pointer;
		transition:
			transform 0.42s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.42s ease,
			background 0.42s ease,
			box-shadow 0.42s ease;
	}

	.prod-signal-nav__trigger:hover,
	.prod-signal-nav__trigger:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.3);
		background: rgba(15, 17, 18, 0.96);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
		outline: none;
	}

	.prod-signal-nav__trigger-core {
		position: relative;
		display: inline-flex;
		width: 1.55rem;
		height: 1.55rem;
		align-items: center;
		justify-content: center;
	}

	.prod-signal-nav__trigger-core::before {
		content: '';
		position: absolute;
		inset: -0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 999px;
		animation: prod-signal-pulse 2.8s ease-in-out infinite;
	}

	.prod-signal-nav__trigger-core i {
		position: absolute;
		display: block;
		width: 1.45rem;
		height: 1.5px;
		background: rgba(255, 255, 255, 0.98);
		transform-origin: center;
		transition:
			transform 0.46s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.34s ease;
	}

	.prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(0deg);
	}

	.prod-signal-nav__trigger-core i:nth-child(2) {
		transform: rotate(60deg);
	}

	.prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(120deg);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger {
		border-color: rgba(255, 255, 255, 0.26);
		background: rgba(10, 11, 12, 0.98);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core::before {
		animation: none;
		opacity: 0.82;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(45deg);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(2) {
		opacity: 0;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(-45deg);
	}

	.prod-signal-nav__takeover {
		position: fixed;
		inset: 0;
		z-index: 1;
		background:
			radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.035), transparent 24%),
			radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.02), transparent 30%),
			#050607;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.45s ease,
			visibility 0s linear 0.45s;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__takeover {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition:
			opacity 0.45s ease,
			visibility 0s linear 0s;
	}

	.prod-signal-nav__takeover-shell {
		display: grid;
		grid-template-rows: auto 1fr auto;
		min-height: 100vh;
		padding-top: 7rem;
		padding-bottom: 2rem;
	}

	.prod-signal-nav__takeover-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 1rem;
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.42);
	}

	.prod-signal-nav__list {
		display: grid;
		align-content: start;
		gap: 0;
		padding-top: 2.25rem;
	}

	.prod-signal-nav__item {
		display: block;
		padding: 1.35rem 0 1.2rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateY(24px);
		transition:
			transform 0.72s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.52s ease,
			border-color 0.42s ease;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item {
		opacity: 1;
		transform: translateY(0);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(1) { transition-delay: 0.08s; }
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(2) { transition-delay: 0.16s; }
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(3) { transition-delay: 0.24s; }
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(4) { transition-delay: 0.32s; }

	.prod-signal-nav__item-copy {
		display: grid;
		gap: 0.65rem;
	}

	.prod-signal-nav__label {
		display: inline-block;
		font-size: clamp(3.25rem, 8vw, 5.3rem);
		line-height: 0.92;
		font-weight: 600;
		letter-spacing: -0.045em;
		transition:
			transform 0.52s cubic-bezier(0.16, 1, 0.3, 1),
			letter-spacing 0.52s ease,
			color 0.42s ease,
			text-shadow 0.42s ease;
	}

	.prod-signal-nav__item-copy small {
		max-width: 38rem;
		color: rgba(255, 255, 255, 0.48);
		font-size: 0.96rem;
		line-height: 1.6;
		transition:
			color 0.42s ease,
			transform 0.52s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__item:hover,
	.prod-signal-nav__item:focus-visible {
		border-color: rgba(255, 255, 255, 0.12);
		outline: none;
	}

	.prod-signal-nav__item:hover .prod-signal-nav__label,
	.prod-signal-nav__item:focus-visible .prod-signal-nav__label {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.015em;
		transform: translateX(10px);
		text-shadow: 0 0 24px rgba(255, 255, 255, 0.04);
	}

	.prod-signal-nav__item:hover .prod-signal-nav__item-copy small,
	.prod-signal-nav__item:focus-visible .prod-signal-nav__item-copy small {
		color: rgba(255, 255, 255, 0.68);
		transform: translateX(10px);
	}

	.prod-signal-nav__takeover-foot {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 2rem;
	}

	.prod-signal-nav__panel-email {
		font-size: 0.86rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		transition: color 0.32s ease;
	}

	.prod-signal-nav__panel-email:hover,
	.prod-signal-nav__panel-email:focus-visible {
		color: rgba(255, 255, 255, 0.78);
		outline: none;
	}

	@media (max-width: 900px) {
		.prod-signal-nav {
			padding-top: 0.85rem;
		}

		.prod-signal-nav__cta {
			display: none;
		}

		.prod-signal-nav__takeover-shell {
			padding-top: 6.35rem;
			padding-bottom: 1.35rem;
		}

		.prod-signal-nav__list {
			padding-top: 1.75rem;
		}

		.prod-signal-nav__label {
			font-size: clamp(2.9rem, 13vw, 4rem);
		}

		.prod-signal-nav__item-copy small {
			max-width: none;
			font-size: 0.9rem;
		}

		.prod-signal-nav__takeover-foot {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 640px) {
		.prod-signal-nav__bar {
			grid-template-columns: minmax(0, auto) 1fr auto;
			gap: 0.75rem;
		}

		.prod-signal-nav__brand {
			gap: 0.55rem;
			font-size: 0.8rem;
			letter-spacing: 0.06em;
		}

		.prod-signal-nav__brand img {
			width: 1.7rem;
			height: 1.7rem;
		}

		.prod-signal-nav__trigger {
			width: 3.35rem;
			height: 3.35rem;
		}

		.prod-signal-nav__takeover-meta {
			font-size: 0.68rem;
			letter-spacing: 0.14em;
		}

		.prod-signal-nav__item {
			padding: 1.1rem 0 1rem;
		}
	}

	@keyframes prod-signal-pulse {
		0%,
		100% {
			transform: scale(0.92);
			opacity: 0.45;
		}

		50% {
			transform: scale(1);
			opacity: 0.9;
		}
	}
</style>
