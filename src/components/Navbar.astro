---
import type { NavGroup } from '../types/navigation';

interface Props {
	navGroups: NavGroup[];
	topHref?: string;
	brandAriaLabel?: string;
	ctaHref?: string;
	ctaLabel?: string;
	email?: string;
	panelId?: string;
}

const {
	navGroups,
	topHref = '#top',
	brandAriaLabel = 'NexAI Labs home',
	ctaHref = 'https://cal.com/nexailabs/15min',
	ctaLabel = 'Book a Call',
	email = 'hello@nexailabs.com',
	panelId = 'primary-nav-takeover',
} = Astro.props;
---

<header class="prod-signal-nav" data-prod-signal-nav data-open="false">
	<div class="prod-signal-nav__inner container">
		<div class="prod-signal-nav__bar">
			<a href={topHref} class="prod-signal-nav__brand" aria-label={brandAriaLabel}>
				<img src="/assets/logo/nexai-icon.png" alt="" width="40" height="40" />
				<span>NEXAI LABS</span>
			</a>

			<div class="prod-signal-nav__line" aria-hidden="true"></div>

			<div class="prod-signal-nav__actions">
				<a class="prod-signal-nav__cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>

				<button
					class="prod-signal-nav__trigger"
					type="button"
					data-nav-trigger
					aria-expanded="false"
					aria-controls={panelId}
					aria-label="Open navigation"
				>
					<span class="prod-signal-nav__trigger-core" aria-hidden="true">
						<i></i>
						<i></i>
						<i></i>
					</span>
				</button>
			</div>
		</div>
	</div>

	<div class="prod-signal-nav__takeover" id={panelId} data-nav-panel aria-hidden="true">
		<div class="prod-signal-nav__takeover-shell container">
			<div class="prod-signal-nav__columns">
				<nav class="prod-signal-nav__list" aria-label="Primary">
					{
						navGroups.map((group) =>
							group.children && group.children.length > 0 ? (
								<div
									class="prod-signal-nav__item prod-signal-nav__item--has-children"
									data-nav-group
									data-nav-group-id={group.id}
								>
									<div class="prod-signal-nav__item-header">
										<a href={group.href} class="prod-signal-nav__item-link" data-nav-close>
											<div class="prod-signal-nav__item-copy">
												<strong class="prod-signal-nav__label">{group.label}</strong>
												{group.caption && <small>{group.caption}</small>}
											</div>
										</a>
										<button
											class="prod-signal-nav__expand"
											data-nav-expand
											aria-expanded="false"
											aria-label={`Expand ${group.label}`}
										>
											<svg
												width="24"
												height="24"
												viewBox="0 0 24 24"
												fill="none"
												aria-hidden="true"
											>
												<path
													d="M6 9l6 6 6-6"
													stroke="currentColor"
													stroke-width="1.5"
													stroke-linecap="round"
													stroke-linejoin="round"
												/>
											</svg>
										</button>
									</div>
									{/* Mobile: inline collapsible sub-menu */}
									<div
										class="prod-signal-nav__sub prod-signal-nav__sub--mobile"
										data-nav-sub
										hidden
									>
										{group.children.map((child) => (
											<a href={child.href} class="prod-signal-nav__sub-link" data-nav-close>
												{child.label}
											</a>
										))}
									</div>
								</div>
							) : (
								<a class="prod-signal-nav__item" href={group.href} data-nav-close>
									<div class="prod-signal-nav__item-copy">
										<strong class="prod-signal-nav__label">{group.label}</strong>
										{group.caption && <small>{group.caption}</small>}
									</div>
								</a>
							),
						)
					}
				</nav>

				{/* Desktop: flyout sub-panel (col 2) */}
				<div class="prod-signal-nav__flyout" data-nav-flyout aria-hidden="true">
					{
						navGroups
							.filter((g) => g.children && g.children.length > 0)
							.map((group) => (
								<div class="prod-signal-nav__flyout-group" data-flyout-for={group.id} hidden>
									{group.children!.map((child) => (
										<a href={child.href} class="prod-signal-nav__flyout-link" data-nav-close>
											<strong>{child.label}</strong>
											{child.caption && <small>{child.caption}</small>}
										</a>
									))}
								</div>
							))
					}
				</div>
			</div>

			<div class="prod-signal-nav__takeover-foot">
				<a class="prod-signal-nav__panel-cta" href={ctaHref} target="_blank" rel="noreferrer">
					{ctaLabel}
				</a>
				<a class="prod-signal-nav__panel-email" href={`mailto:${email}`}>{email}</a>
			</div>
		</div>
	</div>
</header>

<script src="../scripts/navbar.ts"></script>

<style>
	/* ── Fixed header shell ── */

	.prod-signal-nav {
		position: fixed;
		inset: 0 0 auto;
		z-index: 100;
		padding-top: 1rem;
		pointer-events: none;
	}

	.prod-signal-nav__inner,
	.prod-signal-nav__takeover {
		pointer-events: none;
	}

	.prod-signal-nav__bar,
	.prod-signal-nav__takeover,
	.prod-signal-nav__trigger,
	.prod-signal-nav__cta,
	.prod-signal-nav__brand {
		pointer-events: auto;
	}

	.prod-signal-nav__bar {
		position: relative;
		z-index: 4;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.4rem 0 0.1rem;
		transition:
			padding 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			margin 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.5s ease,
			border-radius 0.5s ease,
			background 0.5s ease,
			backdrop-filter 0.5s ease,
			box-shadow 0.5s ease,
			opacity 0.3s ease;
	}

	.prod-signal-nav.is-scrolled .prod-signal-nav__bar {
		padding: 0.72rem 1.15rem 0.42rem;
		margin-inline: -1.15rem;
		border-radius: 1.65rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 8, 9, 0.7);
		backdrop-filter: blur(18px);
		box-shadow: 0 16px 50px rgba(0, 0, 0, 0.2);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__bar {
		padding: 0.4rem 0 0.1rem;
		margin-inline: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		backdrop-filter: none;
		box-shadow: none;
	}

	/* ── Links reset ── */

	.prod-signal-nav__brand,
	.prod-signal-nav__cta,
	.prod-signal-nav__item,
	.prod-signal-nav__item-link,
	.prod-signal-nav__sub-link,
	.prod-signal-nav__flyout-link,
	.prod-signal-nav__panel-cta,
	.prod-signal-nav__panel-email {
		color: inherit;
		text-decoration: none;
	}

	/* ── Brand ── */

	.prod-signal-nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-family: 'Montserrat', sans-serif;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.prod-signal-nav__brand img {
		width: 2rem;
		height: 2rem;
		display: block;
		flex: none;
		background: transparent;
		mix-blend-mode: screen;
	}

	/* ── Divider line ── */

	.prod-signal-nav__line {
		height: 1px;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04));
		transition: opacity 0.3s ease;
	}

	.prod-signal-nav.is-scrolled .prod-signal-nav__line {
		opacity: 0.4;
	}

	/* ── Actions (CTA + trigger) ── */

	.prod-signal-nav__actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		justify-self: end;
	}

	.prod-signal-nav__cta,
	.prod-signal-nav__panel-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.88rem 1.08rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.03);
		font-size: 0.92rem;
		font-weight: 600;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			background 0.3s ease,
			opacity 0.3s ease;
	}

	.prod-signal-nav__cta:hover,
	.prod-signal-nav__panel-cta:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.06);
	}

	.prod-signal-nav__cta:focus-visible,
	.prod-signal-nav__panel-cta:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.06);
		outline: 2px solid rgba(255, 255, 255, 0.5);
		outline-offset: 2px;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__cta {
		opacity: 0;
		transform: translateY(-6px);
		pointer-events: none;
		visibility: hidden;
	}

	/* ── Trigger (hamburger / X) ── */

	.prod-signal-nav__trigger {
		position: relative;
		z-index: 5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.7rem;
		height: 3.7rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: rgba(11, 12, 13, 0.88);
		backdrop-filter: blur(12px);
		cursor: pointer;
		transition:
			transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.3s ease,
			background 0.3s ease,
			box-shadow 0.3s ease;
	}

	.prod-signal-nav__trigger:hover,
	.prod-signal-nav__trigger:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.3);
		background: rgba(15, 17, 18, 0.96);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
		outline: none;
	}

	.prod-signal-nav__trigger-core {
		position: relative;
		display: inline-flex;
		width: 1.55rem;
		height: 1.55rem;
		align-items: center;
		justify-content: center;
	}

	.prod-signal-nav__trigger-core::before {
		content: '';
		position: absolute;
		inset: -0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 999px;
		animation: prod-signal-pulse 2.8s ease-in-out infinite;
	}

	.prod-signal-nav__trigger-core i {
		position: absolute;
		display: block;
		width: 1.45rem;
		height: 1.5px;
		background: rgba(255, 255, 255, 0.98);
		transform-origin: center;
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.3s ease;
	}

	.prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(0deg);
	}
	.prod-signal-nav__trigger-core i:nth-child(2) {
		transform: rotate(60deg);
	}
	.prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(120deg);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger {
		border-color: rgba(255, 255, 255, 0.26);
		background: rgba(10, 11, 12, 0.98);
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i {
		background: rgba(255, 255, 255, 0.8);
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core::before {
		animation: none;
		opacity: 0.82;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(1) {
		transform: rotate(45deg);
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(2) {
		opacity: 0;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__trigger-core i:nth-child(3) {
		transform: rotate(-45deg);
	}

	/* ── Takeover panel ── */

	.prod-signal-nav__takeover {
		position: fixed;
		inset: 0;
		z-index: 1;
		background:
			radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.035), transparent 24%),
			radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.02), transparent 30%), #050607;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.5s ease,
			visibility 0s linear 0.5s;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__takeover {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition:
			opacity 0.5s ease,
			visibility 0s linear 0s;
	}

	.prod-signal-nav__takeover-shell {
		display: grid;
		grid-template-rows: 1fr auto;
		height: 100vh;
		height: 100dvh;
		padding-top: clamp(4rem, 10dvh, 7rem);
		padding-bottom: clamp(1rem, 3dvh, 2rem);
	}

	/* ── Columns wrapper (desktop: 2-col, mobile: single col) ── */

	.prod-signal-nav__columns {
		display: grid;
		grid-template-columns: 1fr;
		min-height: 0;
	}

	/* ── Nav list ── */

	.prod-signal-nav__list {
		display: grid;
		align-content: start;
		gap: 0;
		padding-top: clamp(1rem, 2.5dvh, 2rem);
	}

	/* ── Nav items (shared) ── */

	.prod-signal-nav__item {
		display: block;
		padding: clamp(0.75rem, 2dvh, 1.5rem) 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		opacity: 0;
		transform: translateY(24px);
		transition:
			transform 0.75s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.5s ease,
			border-color 0.3s ease;
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item {
		opacity: 1;
		transform: translateY(0);
	}

	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(1) {
		transition-delay: 0.06s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(2) {
		transition-delay: 0.12s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(3) {
		transition-delay: 0.18s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(4) {
		transition-delay: 0.24s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(5) {
		transition-delay: 0.3s;
	}
	.prod-signal-nav[data-open='true'] .prod-signal-nav__item:nth-child(6) {
		transition-delay: 0.36s;
	}

	.prod-signal-nav__item-copy {
		display: grid;
		gap: clamp(0.3rem, 0.8dvh, 0.65rem);
	}

	.prod-signal-nav__label {
		display: inline-block;
		font-size: clamp(1.6rem, 4dvh, 4rem);
		line-height: 0.92;
		font-weight: 600;
		letter-spacing: -0.045em;
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			letter-spacing 0.5s ease,
			color 0.3s ease,
			text-shadow 0.3s ease;
	}

	.prod-signal-nav__item-copy small {
		max-width: 38rem;
		color: rgba(255, 255, 255, 0.48);
		font-size: clamp(0.78rem, 1.4dvh, 1rem);
		line-height: 1.5;
		transition:
			color 0.3s ease,
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* Hover for plain items and item-links */
	.prod-signal-nav__item:hover,
	.prod-signal-nav__item:focus-visible,
	.prod-signal-nav__item-link:hover,
	.prod-signal-nav__item-link:focus-visible {
		border-color: rgba(255, 255, 255, 0.12);
		outline: none;
	}

	.prod-signal-nav__item:hover > .prod-signal-nav__item-copy .prod-signal-nav__label,
	.prod-signal-nav__item:focus-visible > .prod-signal-nav__item-copy .prod-signal-nav__label,
	.prod-signal-nav__item-link:hover .prod-signal-nav__label,
	.prod-signal-nav__item-link:focus-visible .prod-signal-nav__label {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.015em;
		transform: translateX(10px);
		text-shadow: 0 0 24px rgba(255, 255, 255, 0.04);
	}

	.prod-signal-nav__item:hover > .prod-signal-nav__item-copy small,
	.prod-signal-nav__item:focus-visible > .prod-signal-nav__item-copy small,
	.prod-signal-nav__item-link:hover small,
	.prod-signal-nav__item-link:focus-visible small {
		color: rgba(255, 255, 255, 0.68);
		transform: translateX(10px);
	}

	/* ── Collapsible group header ── */

	.prod-signal-nav__item-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.prod-signal-nav__item-link {
		flex: 1;
		min-width: 0;
	}

	/* ── Expand button (mobile only — minimal arrow) ── */

	.prod-signal-nav__expand {
		all: unset;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.25rem;
		color: rgba(255, 255, 255, 0.4);
		transition:
			color 0.3s ease,
			transform 0.3s ease;
	}

	.prod-signal-nav__expand:hover,
	.prod-signal-nav__expand:focus-visible {
		color: rgba(255, 255, 255, 0.8);
		outline: none;
	}

	.prod-signal-nav__expand svg {
		transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__expand[aria-expanded='true'] svg {
		transform: rotate(180deg);
	}

	/* ── Mobile sub-menu (collapsible) ── */

	.prod-signal-nav__sub--mobile {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__sub--mobile[hidden] {
		display: grid;
		grid-template-rows: 0fr;
	}

	.prod-signal-nav__sub--mobile:not([hidden]) {
		grid-template-rows: 1fr;
	}

	.prod-signal-nav__sub--mobile > * {
		overflow: hidden;
	}

	.prod-signal-nav__sub-link {
		display: block;
		padding: clamp(0.4rem, 0.8dvh, 0.7rem) 0 clamp(0.4rem, 0.8dvh, 0.7rem) 1.4rem;
		font-size: clamp(1rem, 1.8dvh, 1.3rem);
		color: rgba(255, 255, 255, 0.55);
		border-left: 2px solid rgba(255, 255, 255, 0.1);
		transition:
			color 0.3s ease,
			border-color 0.3s ease,
			padding-left 0.3s ease;
	}

	.prod-signal-nav__sub-link:hover,
	.prod-signal-nav__sub-link:focus-visible {
		color: rgba(255, 255, 255, 0.9);
		border-left-color: rgba(78, 201, 180, 0.6);
		padding-left: 1.8rem;
		outline: none;
	}

	/* ── Desktop flyout (col 2 — hidden on mobile) ── */

	.prod-signal-nav__flyout {
		display: none;
	}

	.prod-signal-nav__flyout-group {
		display: grid;
		gap: 0;
		opacity: 0;
		transform: translateX(20px);
		transition:
			opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__flyout-group:not([hidden]) {
		opacity: 1;
		transform: translateX(0);
	}

	.prod-signal-nav__flyout-link {
		display: grid;
		gap: clamp(0.3rem, 0.8dvh, 0.65rem);
		padding: clamp(0.75rem, 2dvh, 1.5rem) 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		transition: border-color 0.3s ease;
	}

	.prod-signal-nav__flyout-link strong {
		display: inline-block;
		font-size: clamp(1.6rem, 4dvh, 4rem);
		line-height: 0.92;
		font-weight: 600;
		letter-spacing: -0.045em;
		color: rgba(255, 255, 255, 1);
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			letter-spacing 0.5s ease,
			color 0.3s ease,
			text-shadow 0.3s ease;
	}

	.prod-signal-nav__flyout-link small {
		color: rgba(255, 255, 255, 0.48);
		font-size: clamp(0.78rem, 1.4dvh, 1rem);
		line-height: 1.5;
		transition:
			color 0.3s ease,
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prod-signal-nav__flyout-link:hover,
	.prod-signal-nav__flyout-link:focus-visible {
		border-color: rgba(255, 255, 255, 0.12);
		outline: none;
	}

	.prod-signal-nav__flyout-link:hover strong,
	.prod-signal-nav__flyout-link:focus-visible strong {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.015em;
		color: rgba(255, 255, 255, 0.95);
		transform: translateX(10px);
		text-shadow: 0 0 24px rgba(255, 255, 255, 0.04);
	}

	.prod-signal-nav__flyout-link:hover small,
	.prod-signal-nav__flyout-link:focus-visible small {
		color: rgba(255, 255, 255, 0.68);
		transform: translateX(10px);
	}

