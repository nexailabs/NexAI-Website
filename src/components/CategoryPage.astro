---
interface Props {
	title: string;
	tag: string;
	description: string;
	backHref: string;
	backLabel: string;
}

const { title, tag, description, backHref, backLabel } = Astro.props;
---

<div class="category-page">
	<div class="category-page__inner">
		<span class="tag-pill">{tag}</span>
		<h1 class="category-page__heading">{title}</h1>
		<p class="category-page__body">{description}</p>
		<a href={backHref} class="btn-ghost">{backLabel}</a>
	</div>
</div>

<style>
	.category-page {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-lg) var(--space-sm);
		background: var(--color-bg);
		position: relative;
	}

	.category-page__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
		max-width: 520px;
	}

	/* .tag-pill from global.css */

	.category-page__heading {
		font-family: var(--font-display);
		font-size: clamp(3rem, 10vw, 6rem);
		font-weight: var(--fw-black);
		line-height: 0.9;
		background: var(--color-brand-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.04em;
	}

	.category-page__body {
		font-size: var(--text-base);
		color: var(--color-text-muted);
		line-height: var(--lh-reading);
	}

	/* .btn-ghost from global.css */
</style>
