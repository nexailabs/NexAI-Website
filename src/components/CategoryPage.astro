---
interface Props {
	title: string;
	tag: string;
	description: string;
	backHref: string;
	backLabel: string;
}

const { title, tag, description, backHref, backLabel } = Astro.props;
---

<div class="category-page">
	<div class="category-page__inner">
		<span class="category-page__tag">{tag}</span>
		<h1 class="category-page__heading">{title}</h1>
		<p class="category-page__body">{description}</p>
		<a href={backHref} class="category-page__back">{backLabel}</a>
	</div>
</div>

<style>
	.category-page {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-lg) var(--space-sm);
		background: var(--color-bg);
		position: relative;
	}

	.category-page__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
		max-width: 520px;
	}

	.category-page__tag {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-brand-cyan);
		padding: 0.4rem 1rem;
		border: 1px solid rgba(78, 201, 180, 0.2);
		border-radius: 999px;
		background: rgba(78, 201, 180, 0.06);
	}

	.category-page__heading {
		font-size: clamp(3rem, 10vw, 6rem);
		font-weight: 800;
		line-height: 0.9;
		background: var(--color-brand-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.04em;
	}

	.category-page__body {
		font-size: 1rem;
		color: var(--color-text-muted);
		line-height: 1.7;
	}

	.category-page__back {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.03);
		color: var(--color-text-main);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.category-page__back:hover,
	.category-page__back:focus-visible {
		border-color: var(--color-border-hover);
		transform: translateY(-1px);
		outline: 2px solid rgba(255, 255, 255, 0.5);
		outline-offset: 2px;
	}
</style>
