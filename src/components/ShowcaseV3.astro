---
import type { ShowcaseCategory } from '../types/ai-shoots';

interface Props {
	categories: ShowcaseCategory[];
}

const { categories } = Astro.props;

const aspectDims: Record<string, { w: number; h: number }> = {
	'3x4': { w: 600, h: 800 },
	'2x3': { w: 600, h: 900 },
	'1x1': { w: 600, h: 600 },
};

const placeholderSvg = `<svg class="sc3__ph-icon" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>`;
const placeholderSvgLg = `<svg class="sc3__ph-icon sc3__ph-icon--lg" viewBox="0 0 40 60" fill="none"><circle cx="20" cy="12" r="6" stroke="currentColor" stroke-width="1"/><path d="M10 58V34a10 10 0 0120 0v24" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>`;
---

<section class="sc3" id="showcase">
	<div class="container sc3__shell">
		<nav class="sc3__nav">
			<ul class="sc3__nav-list" role="tablist" aria-label="Showcase categories">
				{
					categories.map((cat, i) => (
						<li role="presentation">
							<button
								class:list={['sc3__nav-item', { active: i === 0 }]}
								data-target={cat.id}
								role="tab"
								id={`tab-${cat.id}`}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`panel-${cat.id}`}
								tabindex={i === 0 ? 0 : -1}
							>
								<span class="sc3__nav-text">{cat.label}</span>
							</button>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="sc3__stage">
			{
				categories.map((cat, i) => (
					<div
						class:list={['sc3__panel', { active: i === 0 }]}
						data-panel={cat.id}
						role="tabpanel"
						id={`panel-${cat.id}`}
						aria-labelledby={`tab-${cat.id}`}
						aria-hidden={i !== 0 ? 'true' : 'false'}
					>
						{/* Mobile Before/After Stage */}
						{cat.inputMain && (
							<div class="sc3__mobile-stage">
								<div class="sc3__mobile-card sc3__mobile-card--before">
									<span class="sc3__mobile-bookmark sc3__mobile-bookmark--before">Before</span>
									<div class="sc3__mobile-card-frame">
										<img
											src={cat.inputMain}
											alt={`${cat.label} raw input`}
											width="600"
											height="800"
											loading="lazy"
										/>
									</div>
								</div>
								<div class="sc3__mobile-card sc3__mobile-card--after">
									<span class="sc3__mobile-bookmark sc3__mobile-bookmark--after">After</span>
									<div class="sc3__mobile-card-frame sc3__mobile-card-frame--collage">
										<div class="sc3__mobile-output-grid">
											{[1, 2, 0, 3].map((outputIdx, gridIdx) => {
												const pos = ['tl', 'tr', 'bl', 'br'][gridIdx];
												const slot = cat.outputs[outputIdx];
												return slot?.src ? (
													<div class={`sc3__mobile-output sc3__mobile-output--${pos}`}>
														<img
															src={slot.src}
															alt={slot.alt}
															width="600"
															height="800"
															loading="lazy"
														/>
													</div>
												) : (
													<div class={`sc3__mobile-output sc3__mobile-output--${pos}`} />
												);
											})}
										</div>
									</div>
								</div>
							</div>
						)}

						{/* Left Input Block */}
						<div class="sc3__col sc3__col--left">
							<span class="sc3__label">Input Images</span>
							<div class="sc3__input-group">
								<div class:list={['sc3__input-main', { sc3__placeholder: !cat.inputMain }]}>
									{cat.inputMain ? (
										<img
											src={cat.inputMain}
											alt="Raw Garment"
											width="600"
											height="800"
											loading="lazy"
										/>
									) : (
										<Fragment set:html={placeholderSvgLg} />
									)}
									{!cat.inputMain && <span class="sc3__ph-text">Garment</span>}
								</div>
								<div class="sc3__input-side">
									<div class:list={['sc3__in-top', { sc3__placeholder: !cat.inputSideTop }]}>
										{cat.inputSideTop ? (
											<img
												src={cat.inputSideTop}
												alt="Side input"
												width="600"
												height="800"
												loading="lazy"
											/>
										) : (
											<Fragment set:html={placeholderSvg} />
										)}
									</div>
									<div class:list={['sc3__in-bottom', { sc3__placeholder: !cat.inputSideBottom }]}>
										{cat.inputSideBottom ? (
											<img
												src={cat.inputSideBottom}
												alt="Side input"
												width="600"
												height="800"
												loading="lazy"
											/>
										) : (
											<Fragment set:html={placeholderSvg} />
										)}
									</div>
								</div>
							</div>
						</div>

						{/* Arrow Bridge */}
						<div class="sc3__arrow">
							<svg width="48" height="24" viewBox="0 0 48 24" fill="none">
								<path
									d="M0 12h44m0 0l-8-8m8 8l-8 8"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</div>

						{/* Right Output Block */}
						<div class="sc3__col sc3__col--right">
							<span class="sc3__label">Output Images</span>
							<div class="sc3__outputs-bento">
								{/* Col 1: outputs[0] (3x4) + outputs[1] (1x1) */}
								<div class="sc3__ob-col sc3__ob-col--1">
									{[cat.outputs[0], cat.outputs[1]].map((slot, si) => (
										<div
											class:list={[
												'sc3__ob-card',
												`sc3__ob-card--${slot.aspect}`,
												`sc3__out-card--${si + 1}`,
												{ sc3__placeholder: !slot.src },
											]}
										>
											{slot.src ? (
												<img
													src={slot.src}
													alt={slot.alt}
													width={aspectDims[slot.aspect].w}
													height={aspectDims[slot.aspect].h}
													loading="lazy"
												/>
											) : (
												<>
													<Fragment set:html={placeholderSvg} />
													<span class="sc3__ph-text">{slot.alt}</span>
												</>
											)}
										</div>
									))}
								</div>
								{/* Col 2: outputs[2] (2x3) */}
								<div class="sc3__ob-col sc3__ob-col--2">
									{(() => {
										const slot = cat.outputs[2];
										return (
											<div
												class:list={[
													'sc3__ob-card',
													`sc3__ob-card--${slot.aspect}`,
													'sc3__out-card--3',
													{ sc3__placeholder: !slot.src },
												]}
											>
												{slot.src ? (
													<img
														src={slot.src}
														alt={slot.alt}
														width={aspectDims[slot.aspect].w}
														height={aspectDims[slot.aspect].h}
														loading="lazy"
													/>
												) : (
													<>
														<Fragment set:html={placeholderSvg} />
														<span class="sc3__ph-text">{slot.alt}</span>
													</>
												)}
											</div>
										);
									})()}
								</div>
								{/* Col 3: outputs[3] (1x1) + outputs[4] (3x4) */}
								<div class="sc3__ob-col sc3__ob-col--3">
									{[cat.outputs[3], cat.outputs[4]].map((slot, si) => (
										<div
											class:list={[
												'sc3__ob-card',
												`sc3__ob-card--${slot.aspect}`,
												`sc3__out-card--${si + 4}`,
												{ sc3__placeholder: !slot.src },
											]}
										>
											{slot.src ? (
												<img
													src={slot.src}
													alt={slot.alt}
													width={aspectDims[slot.aspect].w}
													height={aspectDims[slot.aspect].h}
													loading="lazy"
												/>
											) : (
												<>
													<Fragment set:html={placeholderSvg} />
													<span class="sc3__ph-text">{slot.alt}</span>
												</>
											)}
										</div>
									))}
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style is:global>
	.sc3 {
		padding: clamp(4rem, 8vw, 7rem) 0;
		position: relative;
	}
	.sc3__shell {
		display: flex;
		flex-direction: column;
		gap: clamp(2rem, 4vw, 3rem);
	}

	/* ── Horizontal Top Nav ── */
	.sc3__nav {
		width: 100%;
		margin: 0 auto;
		display: flex;
		justify-content: center;
	}
	.sc3__nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
	}
	.sc3__nav-item {
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 99rem;
		color: rgba(255, 255, 255, 0.5);
		font-family: inherit;
		font-size: 0.95rem;
		font-weight: 500;
		padding: 0.8rem 1.6rem;
		cursor: pointer;
		text-align: center;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
		overflow: hidden;
	}
	.sc3__nav-item::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at center, rgba(78, 201, 180, 0.3) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.sc3__nav-item:hover {
		color: rgba(255, 255, 255, 1);
		border-color: rgba(78, 201, 180, 0.4);
		box-shadow: 0 0 20px rgba(78, 201, 180, 0.15);
	}
	.sc3__nav-item:hover::before {
		opacity: 1;
	}
	.sc3__nav-text {
		position: relative;
		z-index: 1;
	}
	.sc3__nav-item.active {
		color: #fff;
		background: rgba(78, 201, 180, 0.15);
		border-color: var(--color-brand-cyan, #4ec9b4);
		box-shadow: 0 0 24px rgba(78, 201, 180, 0.4);
		font-weight: 600;
	}
	.sc3__nav-item.active::before {
		display: none;
	}

	/* ── Stage ── */
	.sc3__stage {
		position: relative;
		width: 100%;
		min-height: clamp(22rem, 48vw, 34rem);
	}

	/* ── Panel: OVERLAY CROSSFADE ── */
	.sc3__panel {
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: minmax(18rem, 0.95fr) clamp(2.25rem, 4vw, 4rem) minmax(22rem, 1.2fr);
		grid-template-rows: 1fr;
		gap: clamp(1rem, 2vw, 2.25rem);
		align-items: start;
		opacity: 0;
		pointer-events: none;
		transform: scale(0.97);
		transition:
			opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.sc3__panel.active {
		position: relative;
		opacity: 1;
		pointer-events: auto;
		transform: scale(1);
	}
	.sc3__panel.leaving {
		opacity: 0;
		pointer-events: none;
		transform: scale(1.02);
	}

	/* ── Columns ── */
	.sc3__col {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		min-width: 0;
		animation: sc3FadeUp 0.6s ease both;
	}
	.sc3__col--right {
		animation-delay: 0.15s;
	}
	.sc3__label {
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		flex-shrink: 0;
	}

	/* ── Placeholder Styles ── */
	.sc3__placeholder {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		background: rgba(255, 255, 255, 0.02);
	}
	.sc3__ph-icon {
		width: 28px;
		height: auto;
		color: rgba(200, 170, 100, 0.25);
	}
	.sc3__ph-icon--lg {
		width: 44px;
	}
	.sc3__ph-text {
		font-size: 0.58rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.18);
	}

	/* ── Connection UI ── */
	.sc3__arrow {
		position: relative;
		width: clamp(2.5rem, 5vw, 5rem);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(78, 201, 180, 0.6), transparent);
		align-self: center;
		border-radius: 2px;
		opacity: 0;
	}
	.sc3__panel.active .sc3__arrow {
		opacity: 0.5;
		animation: sc3ConnectPulse 2.5s ease-in-out infinite alternate;
	}
	.sc3__arrow svg {
		display: none;
	}
	@keyframes sc3ConnectPulse {
		0% {
			opacity: 0.2;
			transform: scaleX(0.8);
		}
		100% {
			opacity: 0.8;
			transform: scaleX(1.2);
		}
	}

	.sc3__panel.active .sc3__out-card--1 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
	}
	.sc3__panel.active .sc3__out-card--2 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.42s both;
	}
	.sc3__panel.active .sc3__out-card--3 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.54s both;
	}
	.sc3__panel.active .sc3__out-card--4 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.66s both;
	}
	.sc3__panel.active .sc3__out-card--5 {
		animation: sc3CardIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.78s both;
	}

	@keyframes sc3FadeUp {
		0% {
			opacity: 0;
			transform: translateY(16px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes sc3CardIn {
		0% {
			opacity: 0;
			transform: translateY(16px) scale(0.97);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	/* ── Input Group ── */
	.sc3__input-group {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
		gap: 0.5rem;
		max-width: 100%;
		align-items: stretch;
		overflow: hidden;
	}
	.sc3__input-main {
		position: relative;
		display: block;
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid rgba(200, 170, 100, 0.2);
		aspect-ratio: 3 / 4;
	}
	.sc3__input-main img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.sc3__input-side {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.sc3__in-top,
	.sc3__in-bottom {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.06);
		aspect-ratio: 3 / 4;
	}

	.sc3__in-top img,
	.sc3__in-bottom img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* ── Output Bento Grid ── */
	.sc3__outputs-bento {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.92fr) minmax(0, 1fr);
		gap: 0.5rem;
		max-width: 100%;
		align-items: start;
		overflow: hidden;
	}
	.sc3__ob-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		min-width: 0;
	}
	.sc3__ob-card {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid rgba(200, 170, 100, 0.18);
	}
	.sc3__ob-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.sc3__ob-card--3x4 {
		aspect-ratio: 3 / 4;
	}
	.sc3__ob-card--2x3 {
		aspect-ratio: 2 / 3;
	}
	.sc3__ob-card--1x1 {
		aspect-ratio: 1 / 1;
	}

	/* ── Responsive ── */
	@media (max-width: 1100px) {
		.sc3__panel {
			grid-template-columns: minmax(14rem, 0.95fr) clamp(1.5rem, 3vw, 2.25rem) minmax(16rem, 1.05fr);
		}
	}
	@media (max-width: 900px) {
		.sc3__shell {
			display: flex;
			flex-direction: column;
			gap: clamp(2rem, 4vw, 3rem);
		}
		.sc3__nav {
			position: static;
		}
		.sc3__nav-list {
			flex-direction: row;
			flex-wrap: wrap;
			border-left: none;
			gap: 0.5rem;
		}
		.sc3__nav-item {
			width: auto;
			padding: 0.5rem 0.8rem;
			border: 1px solid rgba(255, 255, 255, 0.06);
			border-radius: 2rem;
			font-size: 0.78rem;
		}
		.sc3__nav-item::before {
			display: none;
		}
		.sc3__nav-item.active {
			border-color: rgba(78, 201, 180, 0.4);
			background: rgba(78, 201, 180, 0.1);
			padding-left: 0.8rem;
		}
		.sc3__nav-item.active::before {
			display: none;
		}
		.sc3__panel {
			grid-template-columns: 1fr;
			max-height: none;
		}
		.sc3__panel.active {
			position: relative;
		}
		.sc3__stage {
			min-height: auto;
		}
		.sc3__arrow {
			margin: 0.5rem auto;
			transform: rotate(90deg);
		}
		.sc3__input-group {
			max-width: 100%;
		}
		.sc3__outputs-bento {
			grid-template-columns: repeat(3, 1fr) !important;
			max-width: 100%;
		}
		.sc3__ob-col {
			min-width: 0;
		}

		.sc3__arrow {
			display: none;
		}

		.sc3__panel.active .sc3__col,
		.sc3__panel.active .sc3__arrow {
			display: none;
		}

		.sc3__mobile-stage {
			display: block;
			grid-column: 1;
			grid-row: 1;
			position: relative;
			--sc3-before-x: 0px;
			--sc3-after-x: clamp(3.4rem, 9vw, 5.4rem);
			--sc3-before-scale: 1;
			--sc3-after-scale: 0.62;
			--sc3-before-shadow: 0.34;
			--sc3-after-shadow: 0.2;
			--sc3-before-overlay: 0.02;
			--sc3-after-overlay: 0.18;
			--sc3-before-z: 4;
			--sc3-after-z: 2;
			--sc3-before-tag-opacity: 1;
			--sc3-after-tag-opacity: 0;
			width: min(100%, 22rem);
			min-height: 26rem;
			margin: 0 auto;
			overflow: visible;
			isolation: isolate;
			touch-action: pan-y;
			user-select: none;
			-webkit-user-select: none;
		}

		.sc3__mobile-card {
			position: absolute;
			left: 50%;
			top: 50%;
			width: 76%;
			aspect-ratio: 3 / 4;
			overflow: visible;
			isolation: isolate;
			transform-origin: center center;
			transition: transform 0.58s cubic-bezier(0.22, 1, 0.36, 1);
			will-change: transform;
		}

		.sc3__mobile-bookmark {
			position: absolute;
			top: -1.4rem;
			z-index: 3;
			min-width: 5.6rem;
			padding: 0.46rem 0.78rem 0.64rem;
			background: transparent;
			border: 1px solid rgba(255, 255, 255, 0.96);
			border-bottom: none;
			border-radius: 0.9rem 0.9rem 0 0;
			color: #fff;
			font-size: 0.72rem;
			font-weight: 900;
			letter-spacing: 0.05em;
			line-height: 1;
			text-transform: uppercase;
			text-align: center;
			white-space: nowrap;
			pointer-events: none;
			transition: opacity 0.24s ease;
		}

		.sc3__mobile-bookmark::after {
			content: '';
			position: absolute;
			left: 0;
			right: 0;
			top: 100%;
			height: 0.6rem;
			background: transparent;
			border-left: 1px solid rgba(255, 255, 255, 0.96);
			border-right: 1px solid rgba(255, 255, 255, 0.96);
			border-bottom: none;
		}

		.sc3__mobile-stage[data-dragging='true'] .sc3__mobile-bookmark {
			transition: none;
		}

		.sc3__mobile-bookmark--before {
			left: 0.62rem;
