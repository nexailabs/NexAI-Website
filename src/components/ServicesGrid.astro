---
import type { ServiceCard } from '../types/studio';

interface Props {
	eyebrow: string;
	heading: string;
	subheading: string;
	cards: ServiceCard[];
	class?: string;
}

const { eyebrow, heading, subheading, cards, class: className } = Astro.props;
---

<section class:list={['services-section container', className]} id="services">
	<div class="services-section__heading">
		<p class="services-section__eyebrow">{eyebrow}</p>
		<h2>{heading}</h2>
		<p>{subheading}</p>
	</div>
	<div class="services-section__grid">
		{
			cards.map((card) => (
				<article class="services-section__card">
					<h3>{card.title}</h3>
					<p>{card.description}</p>
				</article>
			))
		}
	</div>
</section>

<style>
	.services-section {
		padding-top: clamp(4rem, 8vw, 6rem);
		padding-bottom: clamp(3rem, 6vw, 4rem);
	}

	:global(.reveal-up) {
		opacity: 0;
		transform: translate3d(0, 22px, 0);
		transition:
			opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
		will-change: opacity, transform;
	}

	:global(.reveal-up.is-visible) {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.services-section__heading {
		text-align: center;
		max-width: 600px;
		margin: 0 auto 3rem;
	}

	.services-section__eyebrow {
		color: var(--color-brand-cyan, #4ec9b4);
		font-size: 0.9rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		margin-bottom: 1rem;
		display: block;
	}

	.services-section__heading h2 {
		font-size: clamp(2rem, 4vw, 2.8rem);
		font-weight: 700;
		line-height: 1.2;
		margin-bottom: 1.5rem;
		color: var(--color-text-main, #fff);
	}

	.services-section__heading p {
		color: var(--color-text-muted, rgba(255, 255, 255, 0.7));
		font-size: 1.1rem;
		line-height: 1.6;
		max-width: 500px;
		margin: 0 auto;
	}

	.services-section__grid {
		display: grid;
		gap: 2rem;
		margin-top: 2rem;
	}

	.services-section__card {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.5rem;
		padding: 2rem;
		text-align: center;
		transition:
			transform 0.3s ease,
			border-color 0.3s ease,
			background 0.3s ease;
	}

	.services-section__card:hover {
		transform: translateY(-5px);
		border-color: rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.05);
	}

	.services-section__card h3 {
		font-size: 1.4rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-text-main, #fff);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.services-section__card h3::before {
		content: '◆';
		color: var(--color-brand-cyan, #4ec9b4);
		font-size: 1.2rem;
	}

	.services-section__card p {
		color: var(--color-text-muted, rgba(255, 255, 255, 0.6));
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (max-width: 720px) {
		.services-section__grid {
			grid-template-columns: 1fr;
		}

		.services-section__heading {
			margin-bottom: 2rem;
		}
	}

	@media (min-width: 721px) {
		.services-section__grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.reveal-up) {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>

<script src="../scripts/services-reveal.ts"></script>
