---
import type { AgentNode } from '../../data/home';
import NeutronStar from '../NeutronStar.astro';

interface Props {
	agents: AgentNode[];
}

const { agents } = Astro.props;
const nodeCount = agents.length;

// Server-side initial state — agent[0] sits at the checkpoint at first paint.
const first = agents[0];
---

<div class="orbit" data-orbit style="--orbit-rotation: 0deg;">
	<!-- Center: neutron star + supernova -->
	<div class="orbit__center">
		<NeutronStar lightTarget=".home-hero" lightClass="home-hero--light" />
	</div>

	<!-- Rotating node track. Rotation is JS-driven via --orbit-rotation. -->
	<div class="orbit__track" data-orbit-track>
		{
			agents.map((agent, i) => {
				// Node 0 starts at the checkpoint (180° = leftmost). Subsequent
				// nodes are placed clockwise around the ring at 60° intervals.
				const angle = 180 + (360 / nodeCount) * i;
				return (
					<button
						class:list={['orbit__node', i === 0 && 'orbit__node--active']}
						data-orbit-node={agent.id}
						data-index={i}
						style={`--node-angle: ${angle}deg; --node-i: ${i};`}
						aria-label={`${agent.title}: ${agent.role}`}
					>
						<div class="orbit__node-icon">
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d={agent.icon} />
							</svg>
						</div>
						<span class="orbit__node-label">{agent.title}</span>
					</button>
				);
			})
		}
	</div>

	<!-- Detail card — permanent. Content cycles as nodes pass the checkpoint.
	     No aria-live: the card is a visual demo of agent state, not a content
	     stream. AT users hear the rotating-word announcer in HomeHero instead. -->
	<div
		class="orbit__detail orbit__detail--visible"
		data-orbit-detail
		role="region"
		aria-labelledby="orbit-detail-title"
	>
		<div class="orbit__detail-head">
			<div class="orbit__detail-id">
				<h3 class="orbit__detail-title" id="orbit-detail-title" data-orbit-detail-title>
					{first.title}
				</h3>
				<span class="orbit__detail-role" data-orbit-detail-role>{first.role}</span>
			</div>
			<span class="orbit__detail-badge" data-orbit-badge data-mode={first.cardState.mode}
				>{first.cardState.badge}</span
			>
		</div>
		<div class="orbit__detail-body" data-orbit-body></div>
	</div>
</div>

<style>
	.orbit {
		position: relative;
		width: 100%;
		aspect-ratio: 1;
		max-width: min(520px, 100%);
		margin: 0 auto;
		overflow: visible;
	}

	/* ── Center star ── */
	.orbit__center {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 2;
	}

	/* ── Rotating track ──
	   Rotation is JS-driven via the --orbit-rotation CSS variable on the
	   .orbit container. CSS still handles the per-node radial layout below. */
	.orbit__track {
		position: absolute;
		inset: 0;
		transform: rotate(var(--orbit-rotation, 0deg));
		will-change: transform;
	}

	/* ── Nodes ──
	   Each node is placed at --node-angle around the ring. The inner counter-
	   rotation cancels both --node-angle (so the node's own axes stay square
	   to the screen) AND --orbit-rotation (so labels stay upright as the
	   track spins). One CSS variable, two transforms, no keyframes. */
	.orbit__node {
		position: absolute;
		top: 50%;
		left: 50%;
		width: clamp(46px, 9vw, 58px);
		height: clamp(46px, 9vw, 58px);
		margin-top: calc(clamp(46px, 9vw, 58px) / -2);
		margin-left: calc(clamp(46px, 9vw, 58px) / -2);
		transform: rotate(var(--node-angle)) translateX(clamp(120px, 20vw, 165px))
			rotate(calc(-1 * (var(--node-angle) + var(--orbit-rotation, 0deg))));
		animation: nodeEntry 0.5s ease forwards;
		animation-delay: calc(0.3s + var(--node-i) * 0.1s);
		opacity: 0;

		/* Icon and label are absolutely positioned inside the button so the
		   button's box center coincides with the icon's visual center. That's
		   what lets the node sit concentric with the checkpoint circle. */
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		color: var(--color-text-muted);
		transition: color 0.3s ease;
	}

	.orbit__node:hover {
		color: var(--color-text-main);
	}

	.orbit__node:focus-visible .orbit__node-icon {
		border-color: rgba(78, 201, 180, 0.6);
		box-shadow: 0 0 0 3px rgba(78, 201, 180, 0.25);
	}

	@keyframes nodeEntry {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	/* ── Node icon ──
	   Absolutely centered inside the node button so the icon's circle is
	   concentric with the button's box (and therefore with the checkpoint
	   circle when the node snaps to it). */
	.orbit__node-icon {
		position: absolute;
		top: 50%;
		left: 50%;
		width: clamp(38px, 7.5vw, 48px);
		height: clamp(38px, 7.5vw, 48px);
		aspect-ratio: 1;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(10, 12, 16, 0.75);
		display: flex;
		align-items: center;
		justify-content: center;
		transform: translate(-50%, -50%) scale(1);
		transition:
			border-color 0.3s ease,
			box-shadow 0.3s ease,
			transform 0.3s ease;
	}

	.orbit__node:hover .orbit__node-icon,
	.orbit__node.orbit__node--active .orbit__node-icon {
		border-color: rgba(78, 201, 180, 0.5);
		transform: translate(-50%, -50%) scale(1.1);
		box-shadow:
			0 0 8px 1px rgba(78, 201, 180, 0.4),
			0 0 20px 4px rgba(78, 201, 180, 0.15),
			0 0 40px 8px rgba(78, 201, 180, 0.06);
	}

	.orbit__node.orbit__node--active .orbit__node-icon::after {
		content: '';
		position: absolute;
		inset: -6px;
		border-radius: 50%;
		border: 1px solid rgba(78, 201, 180, 0.4);
		animation: activeRing 1.8s ease-out infinite;
	}

	@keyframes activeRing {
		0% {
			transform: scale(1);
			opacity: 0.7;
		}
		100% {
			transform: scale(1.6);
			opacity: 0;
		}
	}

	.orbit__node-icon svg {
		width: 20px;
		height: 20px;
	}

	.orbit__node-label {
		position: absolute;
		top: 100%;
		left: 50%;
		margin-top: 6px;
		transform: translateX(-50%);
		font-family: var(--font-main);
		font-size: 0.72rem;
		font-weight: var(--fw-semibold);
		white-space: nowrap;
		letter-spacing: 0.02em;
		text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
	}

	/* ── Detail card ──
	   Pinned to the orbit's leftmost (checkpoint) area. Visibility is gated
	   by node-checkpoint overlap: a node entering the checkpoint zone shows
	   the card; the card hides when no node is in the zone. */
	.orbit__detail {
		position: absolute;
		top: 50%;
		right: calc(100% - clamp(10px, 4vw, 40px));
		transform: translateY(-50%) scale(1);
		opacity: 1;
		transition:
			opacity 0.25s ease,
			transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
		width: clamp(240px, 24vw, 280px);
		min-height: 248px;
		background: linear-gradient(135deg, rgba(12, 14, 18, 0.92) 0%, rgba(10, 12, 15, 0.88) 100%);
		backdrop-filter: blur(20px) saturate(1.4);
		-webkit-backdrop-filter: blur(20px) saturate(1.4);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 1.1rem 1.15rem 1rem;
		z-index: 10;
		box-shadow:
			0 12px 40px rgba(0, 0, 0, 0.6),
			0 2px 8px rgba(0, 0, 0, 0.3),
			0 1px 0 rgba(255, 255, 255, 0.03) inset,
			inset 0 -1px 0 rgba(255, 255, 255, 0.02),
			0 0 30px -6px rgba(78, 201, 180, 0.12);
	}

	/* Card hidden state — applied when no node is overlapping the checkpoint. */
	.orbit__detail--hidden {
		opacity: 0;
		transform: translateY(-50%) scale(0.92);
		pointer-events: none;
	}

	/* When the active agent changes, briefly fade the card body so the swap
	   reads as a transition instead of a flash of new text. */
	.orbit__detail-id,
	.orbit__detail-badge,
	.orbit__detail-body {
		transition: opacity 0.18s ease;
	}
	.orbit__detail--swapping .orbit__detail-id,
	.orbit__detail--swapping .orbit__detail-badge,
	.orbit__detail--swapping .orbit__detail-body {
		opacity: 0;
	}

	/* Top-edge highlight shimmer — permanent now that the card is permanent. */
	.orbit__detail::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(78, 201, 180, 0.25) 30%,
			rgba(78, 201, 180, 0.4) 50%,
			rgba(78, 201, 180, 0.25) 70%,
			transparent 100%
		);
	}

	/* ── Head row: agent icon (left) + status (right) ── */
	.orbit__detail-head {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin-bottom: 0.9rem;
	}

	/* ── Identity column: title + role between icon and badge ── */
	.orbit__detail-id {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.orbit__detail-title {
		font-family: var(--font-main);
		font-size: 1rem;
		font-weight: var(--fw-bold);
		color: var(--color-text-main);
		line-height: 1.15;
		margin: 0;
	}

	.orbit__detail-role {
		font-family: var(--font-main);
		font-size: 0.6rem;
		font-weight: var(--fw-semibold);
		color: var(--color-brand-cyan);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		line-height: 1.3;
		opacity: 0.85;
	}

	/* ── Status badge — text + tint vary per cardState.mode ── */
	.orbit__detail-badge {
		font-family: var(--font-main);
		font-size: 0.5rem;
		font-weight: var(--fw-bold);
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-brand-cyan);
		padding: 3px 8px;
		border: 1px solid rgba(78, 201, 180, 0.35);
		border-radius: 9999px;
		white-space: nowrap;
		background: rgba(78, 201, 180, 0.07);
		flex-shrink: 0;
	}
	.orbit__detail-badge[data-mode='approval'] {
		color: #f5b660;
		border-color: rgba(245, 182, 96, 0.4);
		background: rgba(245, 182, 96, 0.08);
		animation: orbitPulse 1.6s ease-in-out infinite;
	}
	/* Pipeline (Sales) badge: solid dot + label, dot pulses to convey
	 * "agent on a live call right now". Full badge does not pulse — only
	 * the dot, so the label stays legible. */
	.orbit__detail-badge[data-mode='pipeline'] {
		color: #f5b660;
		border-color: rgba(245, 182, 96, 0.4);
		background: rgba(245, 182, 96, 0.08);
		display: inline-flex;
		align-items: center;
		gap: 5px;
	}
	.orbit__detail-badge[data-mode='pipeline']::before {
		content: '';
		display: inline-block;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #f5b660;
		box-shadow: 0 0 4px rgba(245, 182, 96, 0.6);
		animation: orbitPipPulse 1.4s ease-in-out infinite;
	}
	.orbit__detail-badge[data-mode='tool-calls'],
	.orbit__detail-badge[data-mode='batch'] {
		animation: orbitPulse 1.6s ease-in-out infinite;
	}
	@keyframes orbitPulse {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.55;
		}
	}

	/* Body container only — body internals live in the global block below
	   because they're created by JS and Astro scoping wouldn't reach them. */
	.orbit__detail-body {
		font-family: var(--font-main);
		font-size: 0.72rem;
		line-height: 1.4;
		color: var(--color-text-muted);
	}

	/* ── Mobile ── */
	@media (max-width: 900px) {
		.orbit {
			max-width: min(380px, 100%);
		}
	}

	@media (max-width: 720px) {
		.orbit {
			max-width: min(300px, 100%);
		}

		.orbit__node {
			transform: rotate(var(--node-angle)) translateX(clamp(100px, 18vw, 130px))
				rotate(calc(-1 * (var(--node-angle) + var(--orbit-rotation, 0deg))));
		}

		.orbit__node-label {
			font-size: 0.6rem;
		}

		.orbit__node-icon {
			width: clamp(44px, 9vw, 58px);
			height: clamp(44px, 9vw, 58px);
		}

		.orbit__node-icon svg {
			width: 16px;
			height: 16px;
		}
	}

	/* ── Mobile (≤900px): drop the card below the orbit instead of beside it. */
	@media (max-width: 900px) {
		.orbit__detail {
			position: relative;
			top: auto;
			right: auto;
			transform: none;
			width: 100%;
			max-width: clamp(280px, 82vw, 420px);
			margin: clamp(16px, 3vh, 24px) auto 0;
		}

		.orbit__detail--hidden {
			transform: none;
			opacity: 0;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.orbit__track,
		.orbit__node {
			animation: none !important;
		}
		.orbit__node {
			opacity: 1;
			transform: rotate(var(--node-angle)) translateX(clamp(120px, 20vw, 165px))
				rotate(calc(-1 * var(--node-angle)));
		}
		.orbit__node.orbit__node--active .orbit__node-icon::after {
			animation: none;
			opacity: 0.5;
			transform: scale(1.3);
		}
	}
</style>

<!-- Light mode overrides for orbit (scoped won't reach parent .home-hero--light) -->
<style is:global>
	.home-hero--light .orbit__node {
		color: rgba(0, 0, 0, 0.5);
	}
	.home-hero--light .orbit__node:hover {
		color: #111;
	}
	.home-hero--light .orbit__node-label {
		text-shadow: none;
		color: rgba(0, 0, 0, 0.6);
	}
	.home-hero--light .orbit__node-icon {
		border-color: rgba(0, 0, 0, 0.12);
		background: rgba(0, 0, 0, 0.03);
	}
	.home-hero--light .orbit__node:hover .orbit__node-icon,
	.home-hero--light .orbit__node.orbit__node--active .orbit__node-icon {
		border-color: rgba(0, 100, 80, 0.4);
		box-shadow:
			0 0 8px rgba(0, 100, 80, 0.2),
			0 0 20px rgba(0, 100, 80, 0.08);
	}
	.home-hero--light .orbit__node-icon svg {
		stroke: rgba(0, 0, 0, 0.6);
	}
	.home-hero--light .orbit__detail {
		background: rgba(255, 255, 255, 0.92);
		border-color: rgba(0, 0, 0, 0.08);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
	}
	.home-hero--light .orbit__detail-title {
		color: #111;
	}
	.home-hero--light .orbit__detail-role {
		color: #0d7a6e;
	}
	.home-hero--light .orbit__detail-badge {
		color: #0d7a6e;
		border-color: rgba(13, 122, 110, 0.3);
		background: rgba(13, 122, 110, 0.06);
	}
	.home-hero--light .orbit__detail::before {
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(13, 122, 110, 0.2) 30%,
			rgba(13, 122, 110, 0.35) 50%,
			rgba(13, 122, 110, 0.2) 70%,
			transparent 100%
		);
	}
	.home-hero--light .orbit__detail {
		box-shadow:
			0 8px 32px rgba(0, 0, 0, 0.1),
			0 0 20px -4px rgba(13, 122, 110, 0.1);
	}
	/* Node label in light mode — remove dark text-shadow */
	.home-hero--light .orbit__node-label {
		text-shadow: none;
		color: rgba(0, 0, 0, 0.6);
	}
</style>

<script>
	import '../../scripts/agent-orbit';
</script>

<!-- Card body — primitives mounted by JS, styles global. -->
<style is:global>
	/* ── Status pip — used everywhere a state needs a glanceable colour ── */
	.orbit__pip {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.orbit__pip--done {
		background: var(--color-brand-cyan);
		box-shadow: 0 0 4px rgba(78, 201, 180, 0.5);
	}
	.orbit__pip--running {
		background: #f5b660;
		animation: orbitPipPulse 1.4s ease-in-out infinite;
	}
	.orbit__pip--queued {
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.25);
	}
	.orbit__pip--green {
		background: #4ec9b4;
	}
	.orbit__pip--amber {
		background: #f5b660;
	}
	.orbit__pip--red {
		background: #ef6a6a;
	}
	@keyframes orbitPipPulse {
		0%,
		100% {
			opacity: 1;
			transform: scale(1);
		}
		50% {
			opacity: 0.5;
			transform: scale(0.85);
		}
	}

	/* ── Tool-call body ── */
	.orbit__tool-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 8px;
		margin-bottom: 12px;
	}
	.orbit__tool {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		height: 44px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.02);
		color: var(--color-text-muted);
		transition:
			color 0.3s ease,
			border-color 0.3s ease;
	}
	.orbit__tool--done {
		color: var(--color-brand-cyan);
		border-color: rgba(78, 201, 180, 0.25);
	}
	.orbit__tool--running {
		color: #f5b660;
		border-color: rgba(245, 182, 96, 0.35);
		background: rgba(245, 182, 96, 0.06);
	}
	.orbit__tool--running::after {
		content: '';
		position: absolute;
		inset: -2px;
		border-radius: 9px;
		border: 1px solid rgba(245, 182, 96, 0.5);
		animation: orbitToolRing 1.2s ease-out infinite;
	}
	@keyframes orbitToolRing {
		0% {
			transform: scale(1);
			opacity: 0.7;
		}
		100% {
			transform: scale(1.15);
			opacity: 0;
		}
	}
	.orbit__tool .orbit__pip {
		position: absolute;
		top: 4px;
		right: 4px;
	}
	.orbit__tool svg {
		width: 18px;
		height: 18px;
	}
	.orbit__big-stat {
		display: flex;
		align-items: baseline;
		gap: 6px;
		margin-bottom: 8px;
	}
	.orbit__big-stat-value {
		font-family: var(--font-display, var(--font-main));
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--color-text-main);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.orbit__big-stat-unit {
		font-family: var(--font-main);
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-dim);
	}
	.orbit__steps {
		display: flex;
		flex-direction: column;
		gap: 3px;
		margin-bottom: 8px;
	}
	.orbit__step {
		display: grid;
		grid-template-columns: 6px 14px auto 1fr;
		align-items: center;
		gap: 7px;
		padding: 4px 7px;
		border-radius: 5px;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		color: var(--color-text-muted);
		min-width: 0;
		transition:
			background 0.3s ease,
			color 0.3s ease;
	}
	.orbit__step--done {
		color: var(--color-text-main);
	}
	.orbit__step--running {
		background: rgba(245, 182, 96, 0.07);
		border: 1px solid rgba(245, 182, 96, 0.18);
		padding: 3px 6px;
		color: var(--color-text-main);
	}
	.orbit__step-icon {
		width: 12px;
		height: 12px;
		display: inline-flex;
		color: var(--color-brand-cyan);
		flex-shrink: 0;
	}
	.orbit__step--running .orbit__step-icon {
		color: #f5b660;
	}
	.orbit__step-tool {
		color: var(--color-brand-cyan);
		white-space: nowrap;
	}
	.orbit__step--running .orbit__step-tool {
		color: #f5b660;
	}
	.orbit__step-arg {
		color: var(--color-text-main);
		opacity: 0.85;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
	}

	.orbit__bar {
		height: 3px;
		border-radius: 2px;
		background: rgba(255, 255, 255, 0.06);
		overflow: hidden;
	}
	.orbit__bar-fill {
		height: 100%;
		border-radius: 2px;
		background: linear-gradient(90deg, var(--color-brand-teal), var(--color-brand-cyan));
		transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		box-shadow: 0 0 6px rgba(78, 201, 180, 0.3);
		width: var(--progress, 0%);
	}

	/* ── Batch body — circular ring + channel chips ── */
	.orbit__batch-hero {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 10px;
	}
	.orbit__ring-wrap {
		position: relative;
		width: 64px;
		height: 64px;
		flex-shrink: 0;
		color: var(--color-brand-cyan);
	}
	.orbit__ring {
		display: block;
	}
	.orbit__ring-bar {
		transition: stroke-dasharray 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.orbit__ring-center {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
	}
	.orbit__ring-num {
		font-family: var(--font-display, var(--font-main));
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text-main);
		line-height: 1;
	}
	.orbit__ring-tot {
		font-family: var(--font-main);
		font-size: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-dim);
	}
	.orbit__chips {
		display: flex;
		flex-direction: column;
		gap: 4px;
		flex: 1;
		min-width: 0;
	}
	.orbit__chip {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 4px 7px;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.02);
		font-family: var(--font-main);
	}
	.orbit__chip-icon {
		width: 14px;
		height: 14px;
		display: inline-flex;
		color: var(--color-brand-cyan);
	}
	.orbit__chip-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
		flex: 1;
	}
	.orbit__chip-name {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--color-brand-cyan);
		line-height: 1.1;
	}
	.orbit__chip-action {
		font-size: 0.62rem;
		color: var(--color-text-main);
		line-height: 1.2;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.orbit__cap {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--color-text-dim);
	}

	/* ── Thread body — 3-node mini network + decision line ── */
	.orbit__net-wrap {
		display: flex;
		justify-content: center;
		padding: 2px 0 10px;
	}
	.orbit__net {
		display: block;
		width: 100%;
		max-width: 220px;
		height: 50px;
		color: var(--color-brand-cyan);
	}
	.orbit__net-node {
		fill: rgba(10, 12, 16, 0.9);
		stroke: rgba(78, 201, 180, 0.5);
		stroke-width: 1.4;
	}
	.orbit__net-node--self {
		stroke: var(--color-brand-cyan);
		fill: rgba(78, 201, 180, 0.14);
	}
	.orbit__net-letter {
		fill: currentColor;
		font-family: var(--font-display, var(--font-main));
		font-size: 9px;
		font-weight: 700;
		text-anchor: middle;
		dominant-baseline: central;
	}
	.orbit__net-edge {
		stroke: rgba(78, 201, 180, 0.35);
		stroke-width: 1.2;
		stroke-dasharray: 3 3;
		fill: none;
	}
	.orbit__net-pulse {
		fill: var(--color-brand-cyan);
		animation: orbitNetPulse 2s linear infinite;
	}
	.orbit__net-pulse--out {
		animation-delay: 1s;
	}
	@keyframes orbitNetPulse {
		0% {
			opacity: 0;
		}
		15% {
			opacity: 1;
		}
		85% {
			opacity: 1;
		}
		100% {
			opacity: 0;
		}
	}
	.orbit__msg-list {
		display: flex;
		flex-direction: column;
		gap: 3px;
		margin-bottom: 8px;
	}
	.orbit__msg-line {
		display: flex;
		align-items: baseline;
		gap: 6px;
		padding: 3px 6px;
		font-size: 0.64rem;
		font-family: var(--font-main);
		border-radius: 4px;
		min-width: 0;
	}
	.orbit__msg-line--in {
		background: rgba(255, 255, 255, 0.03);
	}
	.orbit__msg-line--out {
		background: rgba(78, 201, 180, 0.06);
	}
	.orbit__msg-arrow {
		color: var(--color-brand-cyan);
		font-weight: 700;
		font-size: 0.72rem;
		flex-shrink: 0;
	}
	.orbit__msg-line--in .orbit__msg-arrow {
		color: var(--color-text-muted);
	}
	.orbit__msg-agent {
		font-size: 0.54rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-dim);
		flex-shrink: 0;
	}
	.orbit__msg-text {
		color: var(--color-text-main);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
		flex: 1;
	}

	.orbit__decision {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 10px;
		border-radius: 6px;
		background: rgba(78, 201, 180, 0.08);
		border: 1px solid rgba(78, 201, 180, 0.22);
		margin-bottom: 8px;
	}
	.orbit__decision--amber {
		background: rgba(245, 182, 96, 0.08);
		border-color: rgba(245, 182, 96, 0.25);
	}
	.orbit__decision--red {
		background: rgba(239, 106, 106, 0.08);
		border-color: rgba(239, 106, 106, 0.25);
	}
	.orbit__decision-text {
		font-family: var(--font-main);
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--color-text-main);
	}
	.orbit__footer {
		font-family: var(--font-main);
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-dim);
	}

	/* ── Approval body — big amount + avatar + continuation button ── */
	.orbit__amount-row {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 10px;
	}
	.orbit__amount {
		font-family: var(--font-display, var(--font-main));
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--color-text-main);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.orbit__amount-meta {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--color-text-dim);
		margin-left: auto;
	}
	.orbit__client-row {
		display: flex;
		align-items: center;
		gap: 9px;
		margin-bottom: 8px;
	}
	.orbit__avatar {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: rgba(78, 201, 180, 0.14);
		border: 1px solid rgba(78, 201, 180, 0.3);
		color: var(--color-brand-cyan);
		font-family: var(--font-display, var(--font-main));
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		flex-shrink: 0;
	}
	.orbit__client-id {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
	}
	.orbit__client-name {
		font-family: var(--font-main);
		font-size: 0.74rem;
		font-weight: 600;
		color: var(--color-text-main);
		line-height: 1.15;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.orbit__client-meta {
		font-family: var(--font-mono);
		font-size: 0.55rem;
		color: var(--color-text-dim);
	}
	.orbit__age {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-family: var(--font-mono);
		font-size: 0.58rem;
		color: var(--color-text-dim);
		margin-bottom: 10px;
	}
	.orbit__age svg {
		width: 11px;
		height: 11px;
	}
	.orbit__cta-row {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 6px;
	}
	.orbit__btn {
		position: relative;
		overflow: hidden;
		padding: 8px 0;
		border-radius: 6px;
		font-family: var(--font-main);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		cursor: pointer;
		border: 1px solid transparent;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease;
	}
	.orbit__btn--primary {
		background: var(--color-brand-cyan);
		color: var(--color-bg);
		border-color: var(--color-brand-cyan);
	}
	.orbit__btn--ghost {
		background: transparent;
		color: var(--color-text-muted);
		border-color: rgba(255, 255, 255, 0.14);
	}
	.orbit__btn--ghost:hover {
		color: var(--color-text-main);
		border-color: rgba(255, 255, 255, 0.3);
	}
	.orbit__btn-label {
		position: relative;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		gap: 4px;
		transition: opacity 0.2s ease;
	}
	.orbit__btn-spinner {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 14px;
		height: 14px;
		margin: -7px 0 0 -7px;
		opacity: 0;
		z-index: 1;
		animation: orbitSpin 0.8s linear infinite;
		pointer-events: none;
	}
	.orbit__btn::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, var(--color-brand-teal), var(--color-brand-cyan));
		transform: translateX(-101%);
		transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
		z-index: 0;
	}
	.orbit__btn--processing::before {
		transform: translateX(0);
	}
	.orbit__btn--processing .orbit__btn-label {
		opacity: 0;
	}
	.orbit__btn--processing .orbit__btn-spinner {
		opacity: 1;
	}
	.orbit__btn--confirmed::before {
		transform: translateX(0);
	}
	.orbit__btn--confirmed .orbit__btn-spinner {
		opacity: 0;
	}
	.orbit__btn--confirmed .orbit__btn-label {
		opacity: 1;
	}
	@keyframes orbitSpin {
		to {
			transform: rotate(360deg);
		}
	}

	/* ── Connectors body — 2x2 channel grid + recent title ── */
	.orbit__channels {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6px;
		margin-bottom: 8px;
	}
	.orbit__channel {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		min-height: 56px;
		padding: 8px 6px 6px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.02);
		color: var(--color-text-muted);
		transition:
			border-color 0.3s ease,
			color 0.3s ease;
	}
	.orbit__channel-cap {
		font-family: var(--font-main);
		font-size: 0.54rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-text-dim);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		max-width: 100%;
	}
	.orbit__channel--done .orbit__channel-cap,
	.orbit__channel--live .orbit__channel-cap {
		color: var(--color-brand-cyan);
		opacity: 0.85;
	}
	.orbit__channel--running .orbit__channel-cap {
		color: #f5b660;
	}
	.orbit__channel--done {
		color: var(--color-brand-cyan);
		border-color: rgba(78, 201, 180, 0.25);
	}
	.orbit__channel--live {
		color: var(--color-brand-cyan);
		border-color: rgba(78, 201, 180, 0.5);
		box-shadow:
			0 0 0 1px rgba(78, 201, 180, 0.18),
			0 0 14px -2px rgba(78, 201, 180, 0.4);
	}
	.orbit__channel--running {
		color: #f5b660;
		border-color: rgba(245, 182, 96, 0.35);
		background: rgba(245, 182, 96, 0.06);
	}
	.orbit__channel--running::after {
		content: '';
		position: absolute;
		inset: -2px;
		border-radius: 9px;
		border: 1px solid rgba(245, 182, 96, 0.5);
		animation: orbitToolRing 1.2s ease-out infinite;
	}
	.orbit__channel .orbit__pip {
		position: absolute;
		top: 5px;
		right: 5px;
	}
	.orbit__channel svg {
		width: 20px;
		height: 20px;
	}
	.orbit__recent {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 6px 9px;
		border-radius: 6px;
		background: rgba(78, 201, 180, 0.06);
		border: 1px solid rgba(78, 201, 180, 0.18);
		margin-bottom: 8px;
	}
	.orbit__recent-icon {
		width: 12px;
		height: 12px;
		display: inline-flex;
		color: var(--color-brand-cyan);
		flex-shrink: 0;
	}
	.orbit__recent-title {
		font-family: var(--font-main);
		font-size: 0.66rem;
		color: var(--color-text-main);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ── Metrics body — 2x2 grid w/ sparklines + featured row ── */
	.orbit__tiles {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6px;
		margin-bottom: 8px;
	}
	.orbit__tile {
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 8px 9px;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.02);
		font-family: var(--font-main);
		min-width: 0;
	}
	.orbit__tile--featured {
		grid-column: 1 / -1;
		flex-direction: row;
		align-items: center;
		gap: 10px;
		padding: 9px 11px;
		background: rgba(78, 201, 180, 0.05);
		border-color: rgba(78, 201, 180, 0.2);
	}
	.orbit__tile-label {
		font-size: 0.52rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-dim);
		line-height: 1;
	}
	.orbit__tile-value-row {
		display: flex;
		align-items: baseline;
		gap: 4px;
	}
	.orbit__tile-value {
		font-family: var(--font-display, var(--font-main));
		font-size: 1.3rem;
		font-weight: 700;
		color: var(--color-text-main);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.orbit__tile--featured .orbit__tile-value {
		font-size: 1.5rem;
	}
	.orbit__tile-arrow {
		width: 10px;
		height: 10px;
		color: var(--color-brand-cyan);
		flex-shrink: 0;
	}
	.orbit__tile-sub {
		font-family: var(--font-main);
		font-size: 0.52rem;
		color: var(--color-text-dim);
		margin-left: auto;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		white-space: nowrap;
	}
	.orbit__tile-arrow--down {
		color: #ef6a6a;
	}
	.orbit__tile-arrow--flat {
		color: var(--color-text-dim);
	}
	.orbit__spark {
		color: var(--color-brand-cyan);
		opacity: 0.85;
	}
	.orbit__tile--featured .orbit__tile-meta {
		margin-left: auto;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 2px;
	}

	/* ── Pipeline body — Sales: tool strip + deal stage + headline ── */
	.orbit__sales-tools {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 4px;
		padding: 8px 4px;
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.02);
		margin-bottom: 8px;
	}
	.orbit__sales-tool {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		min-width: 0;
		color: var(--color-text-dim);
		font-family: var(--font-main);
		text-align: center;
	}
	.orbit__sales-tool-icon {
		width: 14px;
		height: 14px;
		display: inline-flex;
		opacity: 0.7;
	}
	.orbit__sales-tool-count {
		font-family: var(--font-display, var(--font-main));
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text-main);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.orbit__sales-tool-label {
		font-family: var(--font-main);
		font-size: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-dim);
		line-height: 1;
		white-space: nowrap;
		max-width: 100%;
	}
	.orbit__sales-tool--pending {
		color: #f5b660;
	}
	.orbit__sales-tool--pending .orbit__sales-tool-icon {
		opacity: 1;
		color: #f5b660;
	}
	.orbit__sales-tool--pending .orbit__sales-tool-count {
		color: #f5b660;
	}
	.orbit__sales-tool--pending .orbit__sales-tool-label {
		color: #f5b660;
		opacity: 0.9;
	}

	.orbit__deal {
		padding: 8px 10px;
		border: 1px solid #4ec9b4; /* CHANGED */
		background: rgba(78, 201, 180, 0.15); /* CHANGED */
		border-radius: 6px;
		margin-bottom: 9px;
	}
	.orbit__deal-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 8px;
		margin-bottom: 5px;
		min-width: 0;
	}
	.orbit__deal-name {
		font-family: var(--font-main);
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--color-text-main);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
		flex: 1 1 0;
	}
	.orbit__deal-value {
		font-family: var(--font-display, var(--font-main));
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--color-brand-cyan);
		flex: 0 0 auto;
	}
	.orbit__deal-stage {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-main);
		font-size: 0.54rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 6px;
	}
	.orbit__deal-stage-label {
		color: #f5b660;
		font-weight: 700;
	}
	.orbit__deal-stage-counter {
		color: var(--color-text-dim);
	}
	.orbit__stage-bar {
		display: flex;
		align-items: center;
		gap: 2px;
	}
	.orbit__stage-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		flex-shrink: 0;
	}
	.orbit__stage-dot--done {
		background: var(--color-brand-cyan);
		border-color: var(--color-brand-cyan);
		box-shadow: 0 0 4px rgba(78, 201, 180, 0.4);
	}
	.orbit__stage-dot--active {
		background: #f5b660;
		border-color: #f5b660;
		box-shadow: 0 0 6px rgba(245, 182, 96, 0.55);
		animation: orbitPipPulse 1.4s ease-in-out infinite;
	}
	.orbit__stage-line {
		flex: 1;
		height: 2px;
		background: rgba(255, 255, 255, 0.08);
	}
	.orbit__stage-line--done {
		background: rgba(78, 201, 180, 0.5);
	}
	.orbit__deal-subtext {
		margin-top: 8px;
		padding-top: 7px;
		border-top: 1px solid rgba(78, 201, 180, 0.18);
		font-family: var(--font-main);
		font-size: 0.6rem;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.35;
	}

	.orbit__sales-footer {
		display: block;
		padding: 6px 9px;
		border-left: 2px solid var(--color-brand-cyan);
		background: rgba(78, 201, 180, 0.06);
		border-radius: 0 4px 4px 0;
		color: var(--color-text-main);
		font-family: var(--font-main);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.01em;
	}

	.orbit__sales-headline-block {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 2px 2px 9px;
		margin-bottom: 9px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.orbit__sales-headline {
		display: flex;
		align-items: baseline;
		gap: 10px;
	}
	.orbit__sales-spark {
		width: 100%;
		height: 36px;
		display: block;
		color: var(--color-brand-cyan);
		margin-top: 2px;
	}
	.orbit__sales-spark svg.orbit__rich-spark {
		width: 100%;
		height: 100%;
		display: block;
