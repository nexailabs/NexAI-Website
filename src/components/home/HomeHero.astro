---
import {
	heroEyebrow,
	heroHeadlineBefore,
	heroHeadlineAfter,
	heroRotationWords,
	heroSubtext,
	agents,
} from '../../data/home';
import AgentOrbit from './AgentOrbit.astro';
import { site } from '../../config/site';
---

<section id="hero" class="home-hero" aria-label="Hero">
	<div class="home-hero__inner">
		<!-- Left: Text content -->
		<div class="home-hero__text">
			<p class="home-hero__eyebrow">{heroEyebrow}</p>
			<h1 class="home-hero__heading">
				<span class="home-hero__heading-prefix">{heroHeadlineBefore}</span>{' '}<em
					><span
						class="home-hero__rotate"
						aria-hidden="true"
						data-rotate={JSON.stringify(heroRotationWords)}
						data-rotate-after={heroHeadlineAfter}>{heroRotationWords[0]}</span
					></em
				>
				<span class="sr-only" aria-live="polite" data-rotate-announce>{heroRotationWords[0]}</span>
			</h1>
			<p class="home-hero__sub">{heroSubtext}</p>
			<div class="home-hero__ctas">
				<a href={site.bookingUrl} class="home-hero__cta home-hero__cta--primary" data-open-cal>
					Build My Agent
				</a>
				<a href="#how" class="home-hero__cta home-hero__cta--ghost">
					<span class="home-hero__cta-label">See how it works</span>
				</a>
			</div>
		</div>

		<!-- Right: Orbital animation -->
		<div class="home-hero__orbit">
			<div class="home-hero__dot-grid" aria-hidden="true"></div>
			<AgentOrbit agents={agents} />
		</div>
	</div>
</section>

<style>
	.home-hero {
		min-height: 100svh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height, 5.9rem);
		background:
			radial-gradient(ellipse at 70% 40%, rgba(30, 126, 114, 0.12) 0%, transparent 55%),
			radial-gradient(ellipse at 20% 80%, rgba(78, 201, 180, 0.06) 0%, transparent 50%);
		overflow: clip;
		position: relative;
	}

	.home-hero__inner {
		width: 100%;
		max-width: 1400px;
		margin: 0 auto;
		padding: clamp(2rem, 5vh, 4rem) var(--space-sm);
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: clamp(2rem, 4vw, 4rem);
	}

	/* ── Left: Text ── */
	.home-hero__text {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	/* At ≥1100px the orbit card is pinned to the orbit's left edge and
	 * protrudes ~140px left of the orbit container. Reserve a matching
	 * right-padding on the text column so the headline can never collide
	 * with the card under any rotating word. */
	@media (min-width: 1100px) {
		.home-hero__text {
			padding-right: clamp(80px, 9vw, 140px);
		}
	}

	.home-hero__eyebrow {
		font-family: var(--font-accent-jakarta);
		font-size: var(--type-eyebrow-size);
		font-weight: var(--type-eyebrow-weight);
		letter-spacing: var(--tracking-eyebrow);
		text-transform: uppercase;
		color: var(--brand-teal-bright);
	}

	/* ── Hero headline ──
	 * Hero-only h1 size override (documented one-off): the global h1 token
	 * is sized for editorial pages; the hero needs to stay on one line at
	 * desktop without colliding with the orbit card pinned to the right
	 * column. line-height and tracking still inherit from the element
	 * recipe in global.css. */
	.home-hero__heading {
		font-size: clamp(1.85rem, 3.3vw, 2.9rem);
	}

	.home-hero__heading em {
		font-style: italic;
	}

	/* Keep the static prefix together so the wrap break (when it happens
	 * on narrow viewports) falls between "AI Agents for" and the rotating
	 * word — never inside the prefix. */
	.home-hero__heading-prefix {
		white-space: nowrap;
	}

	/* ── Rotating word scramble ──
	 * Per-char `.home-hero__rotate-char { min-width: 0.5ch }` already
	 * prevents collapse during scramble; the parent reserves just enough
	 * for the longest resolved word ("Creatives.") at the current h1 size.
	 * Scales with viewport so it's not over-buffered on narrow screens. */
	.home-hero__rotate {
		display: inline-block;
		min-width: clamp(4em, 8vw, 5em);
	}

	.home-hero__rotate-char {
		display: inline-block;
		min-width: 0.5ch;
		transition:
			color 0.1s ease,
			text-shadow 0.2s ease;
	}

	.home-hero__rotate-char--cycling {
		color: rgba(78, 201, 180, 0.45);
	}

	.home-hero__rotate-char--resolved {
		color: var(--color-text-main);
		text-shadow: 0 0 10px rgba(78, 201, 180, 0.3);
	}

	.home-hero__rotate-char--settled {
		text-shadow: none;
		transition:
			color 0.1s ease,
			text-shadow 0.5s ease 0.2s;
	}

	@media (prefers-reduced-motion: reduce) {
		.home-hero__rotate-char {
			color: var(--color-text-main) !important;
			text-shadow: none !important;
			transition: none !important;
		}
	}

	.home-hero__sub {
		font-size: var(--type-lead-size);
		line-height: var(--type-lead-line);
		color: var(--color-text-muted);
		max-width: 480px;
	}

	.home-hero__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding-top: 0.5rem;
	}

	.home-hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		font-size: var(--text-btn);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-ui);
		text-transform: uppercase;
		text-decoration: none;
		transition:
			background 0.3s var(--ease-out-expo),
			border-color 0.3s var(--ease-out-expo),
			transform 0.3s var(--ease-out-expo);
	}

	.home-hero__cta:active {
		transform: scale(0.97);
	}

	/* Keyboard-only focus ring — runs on top of any hover styling so the focus
	   boundary is unambiguous, including when the ghost CTA's tile reveal fires. */
	.home-hero__cta:focus-visible {
		outline: 2px solid var(--brand-teal-bright);
		outline-offset: 3px;
	}
	.home-hero__cta--ghost:focus-visible {
		outline-offset: 4px;
	}

	.home-hero__cta--primary {
		background: var(--color-text-main);
		color: var(--color-bg);
		border: 1px solid var(--color-text-main);
	}

	.home-hero__cta--primary:hover {
		background: rgba(255, 255, 255, 0.88);
		border-color: rgba(255, 255, 255, 0.88);
		transform: translateY(-1px);
	}

	.home-hero__cta--ghost {
		background: rgba(255, 255, 255, 0.04);
		color: var(--color-text-main);
		border: 1px solid var(--white-a14);
		backdrop-filter: blur(14px) saturate(140%);
		-webkit-backdrop-filter: blur(14px) saturate(140%);
	}

	.home-hero__cta--ghost:hover {
		background: var(--white-a08);
		border-color: var(--brand-teal-bright);
		box-shadow:
			0 0 0 1px var(--teal-a40),
			0 0 28px var(--teal-a25);
		transform: translateY(-1px);
	}

	.home-hero__cta-label {
		position: relative;
	}

	/* ── Right: Orbit ── */
	.home-hero__orbit {
		display: flex;
		align-items: center;
		justify-content: center;
		justify-self: center;
		position: relative;
		width: 100%;
		max-width: 100%;
	}

	/* Wide desktop only — slight bleed of orbit into the text column. The card
	 * to the orbit's left also needs breathing room from the hero copy, so
	 * the previous -11rem yank was too aggressive once the card became
	 * permanent. -5rem keeps some negative space without crowding the text. */
	@media (min-width: 1100px) {
		.home-hero__orbit {
			margin-left: 5rem;
			margin-top: -3rem;
		}
	}

	.home-hero__dot-grid {
		position: absolute;
		inset: -15%;
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 28px 28px;
		mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, black 15%, transparent 75%);
		-webkit-mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, black 15%, transparent 75%);
		pointer-events: none;
		z-index: 0;
	}

	/* ── Mobile ── */
	@media (max-width: 900px) {
		.home-hero__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.home-hero__text {
			align-items: center;
		}

		.home-hero__sub {
			max-width: 520px;
		}

		.home-hero__ctas {
			justify-content: center;
		}

		.home-hero__orbit {
			order: -1;
			padding-bottom: 1rem;
		}
	}

	@media (max-width: 900px) {
		.home-hero__eyebrow {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.home-hero__dot-grid {
			display: none;
		}

		.home-hero {
			min-height: auto;
			padding-top: calc(var(--header-height, 5.9rem) + 1rem);
			padding-bottom: clamp(2rem, 5vh, 3rem);
		}

		.home-hero__heading {
			font-size: clamp(2rem, 8vw, 2.8rem);
		}

		.home-hero__ctas {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			max-width: 320px;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.home-hero__cta {
			transition: none;
		}
	}

	/* ── Light mode (triggered by star click) ── */
	.home-hero--light {
		background: #f5f5f5 !important;
		transition: background 0.6s ease;
	}

	.home-hero--light .home-hero__eyebrow {
		color: #0d7a6e;
	}

	.home-hero--light .home-hero__heading {
		color: #111;
	}

	.home-hero--light .home-hero__heading em {
		color: #111;
	}

	.home-hero--light .home-hero__sub {
		color: #555;
	}

	.home-hero--light .home-hero__cta--primary {
		background: #111;
		color: #fff;
		border-color: #111;
	}

	.home-hero--light .home-hero__cta--ghost {
		color: #111;
		border-color: rgba(0, 0, 0, 0.25);
	}

	.home-hero--light .home-hero__cta--ghost:hover {
		border-color: #111;
		background: rgba(0, 0, 0, 0.04);
	}

	.home-hero--light .home-hero__dot-grid {
		background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 1px, transparent 1px);
	}

	/* Rotate chars in light mode */
	.home-hero--light .home-hero__rotate-char,
	.home-hero--light .home-hero__rotate-char--resolved {
		color: #111 !important;
		text-shadow: none !important;
	}

	.home-hero--light .home-hero__rotate-char--cycling {
		color: rgba(13, 122, 110, 0.5) !important;
	}
</style>

<script>
	{
		let timers: number[] = [];

		function clearAllTimers() {
			timers.forEach((id) => clearInterval(id));
			timers = [];
		}

		document.addEventListener('astro:before-swap', clearAllTimers);

		document.addEventListener('astro:page-load', () => {
			clearAllTimers();

			const rotateEl = document.querySelector<HTMLElement>('[data-rotate]');
			const announceEl = document.querySelector<HTMLElement>('[data-rotate-announce]');
			if (!rotateEl) return;
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

			const CHARSET = 'abcdefghijklmnopqrstuvwxyz';
			const words: string[] = JSON.parse(rotateEl.dataset.rotate || '[]');
			const trailing = rotateEl.dataset.rotateAfter || '';
			if (words.length === 0) return;

			function appendTrailing() {
				if (!rotateEl) return;
				if (!trailing) return;
				const tail = document.createElement('span');
				tail.className = 'home-hero__rotate-tail';
				tail.textContent = trailing;
				rotateEl.appendChild(tail);
			}

			// Auto-cycle is OFF — the AgentOrbit component drives the rotating
			// word via the `orbit:transition-start` custom event. The hero word
			// scrambles in sync with the orbit's snap-and-dwell motion.
			const SCRAMBLE_MS = 600;
			const CYCLE_MS = 30;

			let charSpans: HTMLSpanElement[] = [];

			function track(id: number) {
				timers.push(id);
				return id;
			}

			function renderWord(word: string) {
				if (!rotateEl) return;
				while (rotateEl.firstChild) rotateEl.removeChild(rotateEl.firstChild);
				charSpans = [];
				for (let i = 0; i < word.length; i++) {
					const span = document.createElement('span');
					span.className = 'home-hero__rotate-char home-hero__rotate-char--settled';
					span.textContent = word[i];
					rotateEl.appendChild(span);
					charSpans.push(span);
				}
				appendTrailing();
			}

			function scrambleTo(word: string, onDone: () => void) {
				if (!rotateEl) return;
				while (rotateEl.firstChild) rotateEl.removeChild(rotateEl.firstChild);
				charSpans = [];
				for (let i = 0; i < word.length; i++) {
					const span = document.createElement('span');
					span.className = 'home-hero__rotate-char home-hero__rotate-char--cycling';
					span.textContent = CHARSET[Math.floor(Math.random() * CHARSET.length)];
					rotateEl.appendChild(span);
					charSpans.push(span);
				}
				appendTrailing();

				const stagger = (SCRAMBLE_MS - 5 * CYCLE_MS) / word.length;
				const start = performance.now();

				charSpans.forEach((span, i) => {
					const resolveAt = stagger * i;
					let cycles = 0;
					const iv = track(
						window.setInterval(() => {
							const elapsed = performance.now() - start;
							if (elapsed - resolveAt > 0) cycles++;
							if (cycles >= 5) {
								clearInterval(iv);
								span.textContent = word[i];
								span.className = 'home-hero__rotate-char home-hero__rotate-char--resolved';
								track(
									window.setTimeout(() => {
										span.className = 'home-hero__rotate-char home-hero__rotate-char--settled';
									}, 300),
								);
								if (i === word.length - 1) {
									if (announceEl) announceEl.textContent = word;
									track(window.setTimeout(onDone, 50));
								}
								return;
							}
							span.textContent = CHARSET[Math.floor(Math.random() * CHARSET.length)];
						}, CYCLE_MS),
					);
				});
			}

			renderWord(words[0]);

			// Orbit drives the word. Every transition the orbit announces its
			// target agent title; we scramble to that title.
			const onOrbitTransition = (e: Event) => {
				const detail = (e as CustomEvent<{ title?: string }>).detail;
				if (!detail || !detail.title) return;
				scrambleTo(detail.title, () => {});
			};
			window.addEventListener('orbit:transition-start', onOrbitTransition);
			document.addEventListener(
				'astro:before-swap',
				() => window.removeEventListener('orbit:transition-start', onOrbitTransition),
				{ once: true },
			);
		});
	}
</script>
