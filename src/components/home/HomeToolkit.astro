---
import Eyebrow from '../brand/Eyebrow.astro';

const tiles = [
	{
		title: 'App Vault',
		year: '2024',
		href: '/apps',
		sub: 'The 32 tools we actually use.',
		mark: 'grid',
		accent: 'rgba(78,201,180,0.18)',
		bgPattern: 'mesh',
	},
	{
		title: 'Prompt Hub',
		year: '2025',
		href: '/prompts',
		sub: 'Prompts, SOPs, skills in production.',
		mark: 'cmd',
		accent: 'rgba(192,138,232,0.16)',
		bgPattern: 'rays',
	},
	{
		title: 'Field Notes',
		year: '2025',
		href: '/blog',
		sub: 'What worked. What we got wrong.',
		mark: 'pen',
		accent: 'rgba(232,168,84,0.14)',
		bgPattern: 'topo',
	},
];
---

<section class="toolkit" aria-labelledby="toolkit-h2">
	<div class="toolkit__inner">
		<div class="toolkit__header">
			<div>
				<Eyebrow class="toolkit__eyebrow" number={5}>How we work, in public</Eyebrow>
				<h2 class="toolkit__h2" id="toolkit-h2">
					The toolkit<br />is open.<br />
					<span class="toolkit__h2-em">even the parts we sell.</span>
				</h2>
			</div>
			<p class="toolkit__lede">
				The exact tools we use, the prompts and SOPs in production, and the things we got wrong. All
				published, no email gate.
			</p>
		</div>

		<div class="toolkit__grid">
			{
				tiles.map((t, i) => (
					<a class="toolkit__tile" href={t.href} aria-label={`${t.title} — ${t.sub}`}>
						<div class="toolkit__art">
							{t.bgPattern === 'mesh' && (
								<svg
									class="toolkit__bg"
									viewBox="0 0 400 400"
									preserveAspectRatio="xMidYMid slice"
									aria-hidden="true"
								>
									<defs>
										<radialGradient id={`tk-mesh-${i}`} cx="50%" cy="40%" r="60%">
											<stop offset="0%" stop-color={t.accent} />
											<stop offset="100%" stop-color="transparent" />
										</radialGradient>
									</defs>
									<rect width="400" height="400" fill={`url(#tk-mesh-${i})`} />
									{Array.from({ length: 24 }).map((_, k) => (
										<line
											x1="0"
											y1={k * 18}
											x2="400"
											y2={k * 18}
											stroke="rgba(255,255,255,0.04)"
											stroke-width="1"
										/>
									))}
									{Array.from({ length: 24 }).map((_, k) => (
										<line
											x1={k * 18}
											y1="0"
											x2={k * 18}
											y2="400"
											stroke="rgba(255,255,255,0.04)"
											stroke-width="1"
										/>
									))}
								</svg>
							)}
							{t.bgPattern === 'rays' && (
								<svg
									class="toolkit__bg"
									viewBox="0 0 400 400"
									preserveAspectRatio="xMidYMid slice"
									aria-hidden="true"
								>
									<defs>
										<radialGradient id={`tk-rays-${i}`} cx="50%" cy="50%" r="50%">
											<stop offset="0%" stop-color={t.accent} />
											<stop offset="100%" stop-color="transparent" />
										</radialGradient>
									</defs>
									<rect width="400" height="400" fill={`url(#tk-rays-${i})`} />
									{Array.from({ length: 36 }).map((_, k) => {
										const a = (k / 36) * Math.PI * 2;
										return (
											<line
												x1="200"
												y1="200"
												x2={200 + Math.cos(a) * 280}
												y2={200 + Math.sin(a) * 280}
												stroke="rgba(255,255,255,0.05)"
												stroke-width="1"
											/>
										);
									})}
								</svg>
							)}
							{t.bgPattern === 'topo' && (
								<svg
									class="toolkit__bg"
									viewBox="0 0 400 400"
									preserveAspectRatio="xMidYMid slice"
									aria-hidden="true"
								>
									<defs>
										<radialGradient id={`tk-topo-${i}`} cx="50%" cy="60%" r="55%">
											<stop offset="0%" stop-color={t.accent} />
											<stop offset="100%" stop-color="transparent" />
										</radialGradient>
									</defs>
									<rect width="400" height="400" fill={`url(#tk-topo-${i})`} />
									{[40, 80, 120, 160, 200, 240].map((r) => (
										<ellipse
											cx="200"
											cy="220"
											rx={r * 1.4}
											ry={r * 0.7}
											fill="none"
											stroke="rgba(255,255,255,0.06)"
											stroke-width="1"
										/>
									))}
								</svg>
							)}

							<span class="toolkit__year">{t.year}</span>
							<span class="toolkit__idx">0{i + 1} / 03</span>

							<div class="toolkit__mark">
								{t.mark === 'grid' && (
									<svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
										{[0, 28, 56].map((x) =>
											[0, 28, 56].map((y) => (
												<rect x={x} y={y} width="20" height="20" fill="#fff" />
											)),
										)}
									</svg>
								)}
								{t.mark === 'cmd' && (
									<svg
										viewBox="0 0 80 80"
										width="80"
										height="80"
										fill="none"
										stroke="#fff"
										stroke-width="3"
										stroke-linecap="square"
										stroke-linejoin="miter"
										aria-hidden="true"
									>
										<rect x="22" y="22" width="36" height="36" />
										<path d="M22 22 L10 22 A6 6 0 1 1 22 16 Z" />
										<path d="M58 22 L70 22 A6 6 0 1 0 58 16 Z" />
										<path d="M22 58 L10 58 A6 6 0 1 0 22 64 Z" />
										<path d="M58 58 L70 58 A6 6 0 1 1 58 64 Z" />
									</svg>
								)}
								{t.mark === 'pen' && (
									<svg
										viewBox="0 0 80 80"
										width="80"
										height="80"
										fill="none"
										stroke="#fff"
										stroke-width="3"
										stroke-linecap="square"
										aria-hidden="true"
									>
										<path d="M14 66 L14 50 L50 14 L66 30 L30 66 Z" />
										<line x1="50" y1="14" x2="66" y2="30" />
										<line x1="14" y1="50" x2="30" y2="66" />
									</svg>
								)}
							</div>
						</div>

						<div class="toolkit__band">
							<div>
								<p class="toolkit__title">{t.title}</p>
								<p class="toolkit__sub">{t.sub}</p>
							</div>
							<svg
								class="toolkit__arrow"
								width="22"
								height="14"
								viewBox="0 0 22 14"
								fill="none"
								aria-hidden="true"
							>
								<line x1="0" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" />
								<polyline
									points="14,2 20,7 14,12"
									stroke="currentColor"
									stroke-width="1.5"
									fill="none"
								/>
							</svg>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.toolkit {
		max-width: 1280px;
		margin: 0 auto;
		padding: 120px 40px;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}
	.toolkit__inner {
		width: 100%;
	}
	.toolkit__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-bottom: 56px;
		gap: 40px;
		flex-wrap: wrap;
	}
	.toolkit__eyebrow {
		margin: 0 0 14px;
	}
	.toolkit__h2 {
		margin: 0;
		max-width: 800px;
		font-family: 'Anton', 'Montserrat', 'Inter', sans-serif;
		font-weight: 400;
		font-size: clamp(2.8rem, 5.6vw, 4.6rem);
		line-height: 0.96;
		letter-spacing: 0.005em;
		text-transform: uppercase;
		color: #fff;
	}
	.toolkit__h2-em {
		font-family: var(--font-accent);
		font-style: italic;
		color: var(--color-brand-cyan);
		font-size: 0.62em;
		letter-spacing: -0.02em;
		text-transform: lowercase;
	}
	.toolkit__lede {
		margin: 0;
		max-width: 360px;
		padding-bottom: 12px;
		font-family: var(--font-main);
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.55);
	}

	.toolkit__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}
	.toolkit__tile {
		display: block;
		text-decoration: none;
		position: relative;
		background: #0a0b0c;
		border: 1px solid rgba(255, 255, 255, 0.08);
		transition:
			border-color 0.25s ease,
			background 0.25s ease;
	}
	.toolkit__tile:hover {
		border-color: rgba(78, 201, 180, 0.35);
	}

	.toolkit__art {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
	}
	.toolkit__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.toolkit__year {
		position: absolute;
		top: 16px;
		left: 0;
		right: 0;
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.2em;
		color: rgba(255, 255, 255, 0.6);
		text-align: center;
	}
	.toolkit__idx {
		position: absolute;
		top: 14px;
		right: 18px;
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		color: rgba(255, 255, 255, 0.4);
	}
	.toolkit__mark {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.toolkit__tile:hover .toolkit__mark {
		transform: scale(1.06);
	}

	.toolkit__band {
		padding: 20px 22px;
		background: rgba(255, 255, 255, 0.025);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		display: flex;
		align-items: center;
		justify-content: space-between;
		transition: background 0.25s ease;
	}
	.toolkit__tile:hover .toolkit__band {
		background: rgba(78, 201, 180, 0.06);
	}
	.toolkit__title {
		margin: 0;
		font-family: 'Anton', 'Montserrat', 'Inter', sans-serif;
		font-size: 1.4rem;
		font-weight: 400;
		letter-spacing: 0.005em;
		text-transform: uppercase;
		color: #fff;
	}
	.toolkit__sub {
		margin: 2px 0 0;
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.72rem;
		color: rgba(255, 255, 255, 0.5);
		letter-spacing: 0.04em;
	}
	.toolkit__arrow {
		color: #fff;
		transition:
			transform 0.25s ease,
			color 0.25s ease;
		flex-shrink: 0;
	}
	.toolkit__tile:hover .toolkit__arrow {
		color: var(--color-brand-cyan);
		transform: translateX(4px);
	}

	@media (max-width: 900px) {
		.toolkit {
			padding: 80px 24px;
		}
		.toolkit__grid {
			grid-template-columns: 1fr;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.toolkit__tile:hover .toolkit__mark,
		.toolkit__tile:hover .toolkit__arrow {
			transform: none;
		}
	}
</style>
