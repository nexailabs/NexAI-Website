---
import Eyebrow from '../brand/Eyebrow.astro';

interface Agent {
	slug: string;
	label: string;
	sublabel?: string;
	sub: string;
	capabilities: string[];
}

const agents: Agent[] = [
	{
		slug: 'outreach',
		label: 'Outreach',
		sub: 'Synthesizes signals across the web and writes opening lines a human would actually reply to.',
		capabilities: [
			'Signal-driven cold one-liners',
			'Reply triage & follow-up timing',
			'Trigger-based account list refresh',
		],
	},
	{
		slug: 'strategy',
		label: 'CEO',
		sublabel: 'Strategy & Decisions',
		sub: 'Synthesizes what’s happening across every team and surfaces the one thing that needs your attention.',
		capabilities: [
			'Daily cross-team briefings',
			'Goal vs. reality tracking',
			'Task delegation by department',
		],
	},
	{
		slug: 'marketing',
		label: 'Marketing',
		sub: 'Reads what’s converting, what’s not, and writes the next experiment before the standup.',
		capabilities: [
			'Channel performance synthesis',
			'Ad copy variants from receipts',
			'Landing-page CRO suggestions',
		],
	},
	{
		slug: 'creatives',
		label: 'Creatives',
		sub: 'Turns a brand brief and a flat product photo into a styled editorial shot — at the volume your studio actually needs.',
		capabilities: [
			'Studio shot brief → image',
			'Brand-locked prompt scaffolds',
			'Asset versioning & QA',
		],
	},
	{
		slug: 'research',
		label: 'Research',
		sub: 'A junior analyst that never sleeps, never forgets a source, and writes one-page briefs you trust by month two.',
		capabilities: [
			'Discovery-call → one-page brief',
			'Competitive teardown',
			'Source citations, always',
		],
	},
	{
		slug: 'finance',
		label: 'Finance',
		sub: 'Reads the bank feed, reconciles invoices, and asks the founder one question a week — never twenty.',
		capabilities: ['Invoice reconciliation', 'GST / TDS prep', 'Cash runway projections'],
	},
];

const total = agents.length;
const totalPadded = String(total).padStart(2, '0');
---

<section class="home-roster" aria-labelledby="home-roster-h2">
	<div class="home-roster__inner">
		{/* Header */}
		<div class="home-roster__header">
			<div>
				<Eyebrow class="home-roster__eyebrow" number={4}>The Roster</Eyebrow>
				<h2 class="home-roster__h2" id="home-roster-h2">
					One agent per seat.<br />
					<span class="home-roster__h2-em">built, not bought.</span>
				</h2>
			</div>
			<p class="home-roster__lede">
				Most clients start with one. By month four, three departments run on agents &mdash; and two
				more are scoped.
			</p>
		</div>

		{/* Roster index bar */}
		<div class="home-roster__bar">
			<span class="home-roster__bar-l">Roster &middot; {totalPadded} agents in production</span>
			<span class="home-roster__bar-r">Hover to inspect &rarr;</span>
		</div>

		{/* Grid */}
		<div class="home-roster__grid">
			{
				agents.map((d, i) => {
					const col = i % 3;
					const row = Math.floor(i / 3);
					const isLastCol = col === 2;
					const isLastRow = row === Math.floor((total - 1) / 3);
					return (
						<article
							class:list={[
								'home-roster__card',
								!isLastCol && 'home-roster__card--rb',
								!isLastRow && 'home-roster__card--bb',
							]}
						>
							<span class="home-roster__accent" aria-hidden="true" />

							<div class="home-roster__card-head">
								<span class="home-roster__idx">R/{String(i + 1).padStart(2, '0')}</span>
								<span class="home-roster__dot" aria-hidden="true">
									<svg
										viewBox="0 0 14 14"
										width="14"
										height="14"
										fill="none"
										stroke="currentColor"
										stroke-width="1.4"
										stroke-linecap="square"
										stroke-linejoin="miter"
									>
										<circle cx="7" cy="7" r="2.5" />
										<circle cx="7" cy="7" r="5.5" />
									</svg>
								</span>
							</div>

							<h3 class="home-roster__name">{d.label}</h3>
							{d.sublabel ? (
								<p class="home-roster__sublabel">{d.sublabel.toLowerCase()}.</p>
							) : (
								<div class="home-roster__sublabel-spacer" aria-hidden="true" />
							)}

							<p class="home-roster__sub">{d.sub}</p>

							<div class="home-roster__caps">
								{d.capabilities.slice(0, 3).map((c, ci) => (
									<div class:list={['home-roster__cap', ci < 2 && 'home-roster__cap--bb']}>
										<span class="home-roster__cap-n">0{ci + 1}</span>
										<span class="home-roster__cap-t">{c}</span>
									</div>
								))}
							</div>
						</article>
					);
				})
			}
		</div>

		{/* Footer ledger row */}
		<div class="home-roster__footer">
			<span
				>Outreach &middot; CEO &middot; Marketing &middot; Creatives &middot; Research &middot;
				Finance</span
			>
			<span class="home-roster__footer-r">
				<span class="home-roster__footer-dot" aria-hidden="true"></span>
				More on the way
			</span>
		</div>
	</div>
</section>

<style>
	.home-roster {
		position: relative;
		padding: 120px 40px;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		background: #050607;
	}
	.home-roster__inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.home-roster__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-bottom: 56px;
		gap: 40px;
		flex-wrap: wrap;
	}
	.home-roster__eyebrow {
		margin: 0 0 14px;
	}
	.home-roster__h2 {
		margin: 0;
		max-width: 880px;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(2.8rem, 5.6vw, 4.6rem);
		line-height: 0.96;
		letter-spacing: 0.005em;
		text-transform: uppercase;
		color: #fff;
	}
	.home-roster__h2-em {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--color-brand-cyan);
		font-size: 0.68em;
		letter-spacing: -0.02em;
		text-transform: lowercase;
	}
	.home-roster__lede {
		margin: 0;
		max-width: 360px;
		font-family: var(--font-main), 'Inter', sans-serif;
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.55);
	}

	.home-roster__bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 14px 0;
		margin-bottom: 0;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.home-roster__bar-l {
		font-family: var(--font-mono);
		font-size: 0.66rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.42);
	}
	.home-roster__bar-r {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.32);
	}

	.home-roster__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.home-roster__card {
		position: relative;
		padding: 32px 30px 36px;
		background: transparent;
		transition: background 0.3s ease;
		cursor: default;
	}
	.home-roster__card--rb {
		border-right: 1px solid rgba(255, 255, 255, 0.06);
	}
	.home-roster__card--bb {
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.home-roster__card:hover {
		background: rgba(78, 201, 180, 0.025);
	}

	.home-roster__accent {
		position: absolute;
		top: 0;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--color-brand-cyan);
		transition: width 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);
	}
	.home-roster__card:hover .home-roster__accent {
		width: 100%;
	}

	.home-roster__card-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 26px;
	}
	.home-roster__idx {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.4);
		transition: color 0.25s ease;
	}
	.home-roster__card:hover .home-roster__idx {
		color: var(--color-brand-cyan);
	}
	.home-roster__dot {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: rgba(255, 255, 255, 0.6);
		transition:
			border-color 0.25s ease,
			color 0.25s ease;
	}
	.home-roster__card:hover .home-roster__dot {
		border-color: var(--color-brand-cyan);
		color: var(--color-brand-cyan);
	}

	.home-roster__name {
		margin: 0 0 4px;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 2.1rem;
		line-height: 1;
		letter-spacing: 0.005em;
		text-transform: uppercase;
		color: #fff;
	}
	.home-roster__sublabel {
		margin: 0 0 14px;
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.02rem;
		color: var(--color-brand-cyan);
		font-weight: 400;
	}
	.home-roster__sublabel-spacer {
		height: 14px;
	}
	.home-roster__sub {
		margin: 0 0 22px;
		font-family: var(--font-main), 'Inter', sans-serif;
		font-size: 0.9rem;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.62);
		text-wrap: pretty;
	}

	.home-roster__caps {
		display: flex;
		flex-direction: column;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}
	.home-roster__cap {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 10px 0;
	}
	.home-roster__cap--bb {
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
	}
	.home-roster__cap-n {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.32);
		letter-spacing: 0.05em;
	}
	.home-roster__cap-t {
		font-family: var(--font-main), 'Inter', sans-serif;
		font-size: 0.84rem;
		color: rgba(255, 255, 255, 0.78);
		flex: 1;
	}

	.home-roster__footer {
		margin-top: 18px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.32);
	}
	.home-roster__footer-r {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}
	.home-roster__footer-dot {
		width: 6px;
		height: 6px;
		background: var(--color-brand-cyan);
		display: inline-block;
	}

	@media (max-width: 1100px) {
		.home-roster__grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.home-roster__card--rb {
			border-right: none;
		}
		.home-roster__card:nth-child(odd) {
			border-right: 1px solid rgba(255, 255, 255, 0.06);
		}
	}
	@media (max-width: 900px) {
		.home-roster {
			padding: 80px 24px;
		}
		.home-roster__grid {
			grid-template-columns: 1fr;
		}
		.home-roster__card,
		.home-roster__card--rb,
		.home-roster__card:nth-child(odd) {
			border-right: none;
		}
		.home-roster__card {
			border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		}
		.home-roster__bar,
		.home-roster__footer {
			flex-wrap: wrap;
			gap: 8px;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.home-roster__card,
		.home-roster__accent,
		.home-roster__idx,
		.home-roster__dot {
			transition: none;
		}
	}
</style>
