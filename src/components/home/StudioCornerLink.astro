---
// Floating bottom-right pill linking to the studio service line.
// Lives outside the main hero CTA flow so it doesn't fragment buyer intent —
// but stays discoverable for visitors who arrived looking for AI shoots.
---

<a class="studio-corner" href="/studio" aria-label="NexAI Studio: AI product shoots">
	<svg
		class="studio-corner__icon"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="1.6"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M3 8h3l2-3h8l2 3h3v11H3z"></path>
		<circle cx="12" cy="13" r="3.5"></circle>
	</svg>
	<span class="studio-corner__label">AI shoots?</span>
	<span class="studio-corner__arrow" aria-hidden="true">→</span>
</a>

<style>
	.studio-corner {
		position: fixed;
		bottom: clamp(16px, 3vh, 24px);
		right: clamp(16px, 3vw, 24px);
		z-index: 60;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px 10px 14px;
		border-radius: 999px;
		background: rgba(12, 14, 18, 0.78);
		backdrop-filter: blur(14px) saturate(140%);
		-webkit-backdrop-filter: blur(14px) saturate(140%);
		border: 1px solid rgba(78, 201, 180, 0.28);
		color: var(--color-text-main);
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		box-shadow:
			0 12px 32px rgba(0, 0, 0, 0.45),
			0 0 24px -4px rgba(78, 201, 180, 0.25);
		transition:
			transform 0.3s var(--ease-out-expo, ease),
			border-color 0.3s ease,
			box-shadow 0.3s ease,
			background 0.3s ease;
	}

	.studio-corner:hover {
		transform: translateY(-2px);
		border-color: var(--brand-teal-bright);
		background: rgba(12, 14, 18, 0.92);
		box-shadow:
			0 14px 36px rgba(0, 0, 0, 0.55),
			0 0 0 1px rgba(78, 201, 180, 0.4),
			0 0 32px rgba(78, 201, 180, 0.35);
	}

	.studio-corner:focus-visible {
		outline: 2px solid var(--brand-teal-bright);
		outline-offset: 3px;
	}

	.studio-corner__icon {
		width: 16px;
		height: 16px;
		color: var(--brand-teal-bright);
		flex-shrink: 0;
	}

	.studio-corner__arrow {
		font-family: var(--font-body);
		color: var(--brand-teal-bright);
		opacity: 0.85;
		transition: transform 0.3s var(--ease-out-expo, ease);
	}

	.studio-corner:hover .studio-corner__arrow {
		transform: translateX(2px);
		opacity: 1;
	}

	@media (max-width: 480px) {
		.studio-corner {
			padding: 9px 14px 9px 12px;
			font-size: 0.72rem;
		}
		.studio-corner__icon {
			width: 14px;
			height: 14px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.studio-corner,
		.studio-corner__arrow {
			transition: none;
		}
	}

	/* Light mode (homepage star toggle) */
	:global(.home-hero--light) ~ * .studio-corner,
	:global(body):has(.home-hero--light) .studio-corner {
		background: rgba(255, 255, 255, 0.92);
		border-color: rgba(13, 122, 110, 0.3);
		color: #111;
		box-shadow:
			0 12px 32px rgba(0, 0, 0, 0.12),
			0 0 24px -4px rgba(13, 122, 110, 0.18);
	}
</style>
