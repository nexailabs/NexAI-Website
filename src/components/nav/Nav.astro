  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="NexAI Labs home">
      <span class="nav-logo-main">Nex</span><span class="nav-logo-accent">AI</span><span class="nav-logo-muted"> Labs</span>
    </a>

    <div class="nav-desktop">
      <div class="nav-links">
        <a href="#how-it-works">How It Works</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
      </div>
      <a href="https://cal.com/nexailabs/15min" class="nav-cta" target="_blank" rel="noreferrer">Book a Call</a>
    </div>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open navigation menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav-overlay" id="mobile-menu" data-lenis-prevent>
    <div class="nav-overlay-links">
      <a href="#how-it-works">How It Works</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
    </div>
    <a href="https://cal.com/nexailabs/15min" class="nav-cta nav-overlay-cta" target="_blank" rel="noreferrer">Book a Call</a>
  </div>
</nav>

<script>
  import { gsap } from 'gsap';

  let cleanup = null;

  function initNav() {
    cleanup?.();

    const nav = document.querySelector('.nav');
    const toggle = document.querySelector('.nav-toggle');
    const overlay = document.querySelector('.nav-overlay');
    const overlayLinks = overlay ? Array.from(overlay.querySelectorAll('a')) : [];

    if (!(nav instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement) || !(overlay instanceof HTMLElement)) {
      return;
    }

    const syncScrollState = () => {
      nav.classList.toggle('scrolled', window.scrollY > 50);
    };

    const closeMenu = () => {
      nav.classList.remove('menu-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('nav-menu-open');
    };

    const openMenu = () => {
      nav.classList.add('menu-open');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('nav-menu-open');

      gsap.fromTo(
        overlayLinks,
        { y: 24, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.45, stagger: 0.08, ease: 'power3.out', overwrite: true }
      );
    };

    const handleToggle = () => {
      if (nav.classList.contains('menu-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    };

    const handleOverlayClick = (event) => {
      const target = event.target;
      if (target instanceof HTMLAnchorElement) {
        closeMenu();
      }
    };

    const handleResize = () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    };

    syncScrollState();
    window.addEventListener('scroll', syncScrollState, { passive: true });
    window.addEventListener('resize', handleResize);
    toggle.addEventListener('click', handleToggle);
    overlay.addEventListener('click', handleOverlayClick);

    gsap.from('.nav', { y: -20, opacity: 0, duration: 0.6, ease: 'power3.out', delay: 0.1, clearProps: 'opacity,transform' });

    cleanup = () => {
      window.removeEventListener('scroll', syncScrollState);
      window.removeEventListener('resize', handleResize);
      toggle.removeEventListener('click', handleToggle);
      overlay.removeEventListener('click', handleOverlayClick);
      document.body.classList.remove('nav-menu-open');
    };
  }

  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>

