---
/**
 * Brand-canonical eyebrow chip.
 *
 * Per Brand Guidelines.pdf and audits/06-branding-opus.md: ONE eyebrow style
 * across the site. Plus Jakarta Sans, semibold, uppercase, accent-teal by
 * default. Optional sequential section number renders as `[ 0N ]  ` prefix.
 *
 * Replaces:
 *   - src/components/vault/Eyebrow.astro      (byte-twin, deleted)
 *   - src/components/blog/MonoLabel.astro     (byte-twin, deleted)
 *   - inline `.toolkit__eyebrow` / `.home-pricing__eyebrow` / `.thesis__eyebrow` etc.
 */
interface Props {
	/** Sequential section number, renders as `[ 0N ]  ` prefix when provided. */
	number?: number | null;
	/** Color treatment. */
	tint?: 'accent' | 'muted' | 'dim' | 'ink';
	/** Default true. Set false for sentence-case eyebrows (rare). */
	uppercase?: boolean;
	/** Extra class hook for layout positioning. */
	class?: string;
}

const { number = null, tint = 'accent', uppercase = true, class: className = '' } = Astro.props;

const prefix = number != null ? `[ ${String(number).padStart(2, '0')} ] ` : '';
---

<span class:list={['eyebrow', `eyebrow--${tint}`, { 'eyebrow--upper': uppercase }, className]}>
	{prefix}<slot />
</span>

<style>
	.eyebrow {
		font-family: var(--font-accent-jakarta);
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: 0.18em;
		line-height: 1;
		display: inline-block;
	}
	.eyebrow--upper {
		text-transform: uppercase;
	}
	.eyebrow--accent {
		color: var(--brand-teal-bright);
	}
	.eyebrow--muted {
		color: var(--white-a55);
	}
	.eyebrow--dim {
		color: var(--white-a35);
	}
	.eyebrow--ink {
		color: var(--brand-ink);
	}
</style>
