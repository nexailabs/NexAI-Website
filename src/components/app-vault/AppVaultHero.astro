---
import { tr } from '../../config/imagekit';
import type { AppEntry } from '../../data/app-vault';

interface Props {
	featured: readonly AppEntry[];
	hasAffiliateLinks?: boolean;
}

const { featured, hasAffiliateLinks = false } = Astro.props;
---

<section class="vault-hero" aria-label="App Vault intro">
	<div class="vault-hero__inner">
		<p class="vault-hero__eyebrow">THE VAULT</p>
		<h1><em>The software we actually open every day.</em></h1>
		<p class="vault-hero__sub">
			An opinionated shortlist of AI tools, dev gear, and creative operators we rely on for daily
			execution.
		</p>
		{
			hasAffiliateLinks && (
				<small class="vault-hero__affiliate">
					Some links are affiliate links — they help fund the vault and cost you nothing extra.
				</small>
			)
		}

		{
			featured.length > 0 && (
				<div class="vault-hero__strip" aria-label="Featured tools">
					{featured.map((app) => (
						<a href={app.affiliateUrl ?? app.websiteUrl} rel="noopener nofollow" target="_blank">
							<img
								src={app.logo + tr.appLogo}
								srcset={`${app.logo + tr.appLogo} 1x, ${app.logo + tr.appLogo2x} 2x`}
								alt={`${app.name} logo`}
								width="40"
								height="40"
								loading="eager"
								decoding="async"
								fetchpriority="high"
							/>
							<div>
								<strong>{app.name}</strong>
								<span>{app.tagline}</span>
							</div>
						</a>
					))}
				</div>
			)
		}
	</div>
</section>

<style>
	.vault-hero {
		padding-top: calc(var(--header-height) + var(--space-md));
		padding-inline: var(--space-sm);
		padding-bottom: var(--space-md);
		background:
			radial-gradient(ellipse at 15% 0%, rgba(30, 126, 114, 0.13) 0%, transparent 55%),
			radial-gradient(ellipse at 80% 100%, rgba(78, 201, 180, 0.09) 0%, transparent 50%);
	}

	.vault-hero__inner {
		max-width: 1400px;
		margin: 0 auto;
		display: grid;
		gap: 1rem;
	}

	.vault-hero__eyebrow {
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-brand-cyan);
	}

	h1 {
		font-family: var(--font-accent);
		font-size: clamp(2rem, 4vw, 3.6rem);
		font-weight: var(--fw-semibold);
		line-height: 1.1;
	}

	h1 em {
		font-style: italic;
	}

	.vault-hero__sub {
		max-width: 56ch;
		font-size: 1.05rem;
		line-height: var(--lh-body);
		color: var(--color-text-muted);
	}

	.vault-hero__affiliate {
		font-size: var(--text-sm);
		color: var(--color-text-subtle);
	}

	.vault-hero__strip {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		margin-top: 0.75rem;
	}

	.vault-hero__strip a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.02);
		text-decoration: none;
		color: inherit;
		transition: transform 300ms var(--ease-out-expo);
	}

	.vault-hero__strip a:hover,
	.vault-hero__strip a:focus-visible {
		transform: translateY(-2px);
	}

	.vault-hero__strip a:focus-visible {
		outline: 2px solid var(--color-brand-cyan);
		outline-offset: 3px;
	}

	.vault-hero__strip img {
		border-radius: 8px;
		display: block;
	}

	.vault-hero__strip strong {
		display: block;
		font-size: 0.95rem;
	}

	.vault-hero__strip span {
		display: block;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin-top: 0.15rem;
	}

	@media (min-width: 768px) {
		.vault-hero__strip {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1100px) {
		.vault-hero__strip {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}
</style>
