---
import type { Author } from '../../data/promptHub';
import Eyebrow from '../vault/Eyebrow.astro';

interface Props {
	author: Author;
}

const { author } = Astro.props;
---

<div class="author-card">
	<Eyebrow tint="dim">Author</Eyebrow>
	<div class="author-card__body">
		<span class="author-card__avatar">{author.initials}</span>
		<div>
			<div class="author-card__name">{author.name}</div>
			<div class="author-card__role">{author.role}</div>
		</div>
	</div>
</div>

<style>
	.author-card {
		padding: 20px;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.015);
		margin-bottom: 18px;
	}
	.author-card__body {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-top: 14px;
	}
	.author-card__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: rgba(78, 201, 180, 0.12);
		color: var(--color-brand-cyan);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-main);
		font-size: 0.78rem;
		font-weight: 600;
		border: 1px solid rgba(78, 201, 180, 0.25);
		flex-shrink: 0;
	}
	.author-card__name {
		font-family: var(--font-main);
		font-size: 0.92rem;
		color: var(--color-text-main);
		font-weight: 500;
	}
	.author-card__role {
		font-family: var(--font-main);
		font-size: 0.78rem;
		color: var(--color-text-muted);
	}
</style>
