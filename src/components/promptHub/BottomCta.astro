---
import Italic from './Italic.astro';
---

<section class="ph-bottom-cta">
	<div class="ph-bottom-cta__copy">
		<h3 class="ph-bottom-cta__h3">
			Want this <Italic>running</Italic>, not just sitting in a tab?
		</h3>
		<p class="ph-bottom-cta__p">
			We'll wire any prompt, SOP, or skill into your agents and hand you the running system. Two
			weeks, fixed price.
		</p>
	</div>
	<a href="#" data-open-cal class="ph-bottom-cta__btn">
		Catch us
		<svg
			width="13"
			height="13"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2.2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="5" y1="12" x2="19" y2="12"></line>
			<polyline points="13 6 19 12 13 18"></polyline>
		</svg>
	</a>
</section>

<style>
	.ph-bottom-cta {
		margin-top: 96px;
		margin-bottom: 80px;
		padding: 40px 48px;
		border: 1px solid var(--color-border);
		border-radius: 10px;
		display: flex;
		align-items: center;
		gap: 32px;
		background: rgba(255, 255, 255, 0.012);
	}
	.ph-bottom-cta__copy {
		flex: 1;
	}
	.ph-bottom-cta__h3 {
		margin: 0 0 8px;
		font-family: var(--font-display);
		font-weight: var(--fw-regular);
		font-size: 2rem;
		letter-spacing: -0.015em;
		color: var(--color-text-main);
	}
	.ph-bottom-cta__p {
		margin: 0;
		font-family: var(--font-main);
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--color-text-muted);
		max-width: 560px;
	}
	.ph-bottom-cta__btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 14px 22px;
		background: var(--color-brand-cyan);
		color: #050607;
		border-radius: var(--radius-full);
		font-family: var(--font-main);
		font-size: 0.88rem;
		font-weight: 500;
		text-decoration: none;
		flex-shrink: 0;
	}

	@media (max-width: 720px) {
		.ph-bottom-cta {
			flex-direction: column;
			align-items: flex-start;
			padding: 32px 24px;
			gap: 24px;
		}
		.ph-bottom-cta__h3 {
			font-size: 1.55rem;
		}
	}
</style>
