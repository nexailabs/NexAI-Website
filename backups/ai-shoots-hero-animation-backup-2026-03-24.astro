---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const bookingUrl = 'https://cal.com/nexailabs/15min';
const email = 'hello@nexailabs.com';
const heroNavLinks = [
  {
    label: 'Home',
    href: '#top',
    caption: 'Hero section with the trust badge, primary offer, and main CTA.',
  },
  {
    label: 'Brands',
    href: '#platforms',
    caption: 'Marketplace platforms where your buyers already discover and compare products.',
  },
  {
    label: 'Transformations',
    href: '#transformations',
    caption: 'Before-and-after proof that turns raw product shots into launch-ready visuals.',
  },
  {
    label: 'How It Works',
    href: '#how-it-works',
    caption: 'See how raw mannequin or flat-lay photos become launch-ready visuals in 48 hours.',
  },
  {
    label: 'Pricing',
    href: '#pricing',
    caption: 'Compare pay-per-SKU, growth, and scale plans for your catalog volume.',
  },
  {
    label: 'FAQ',
    href: '#faq',
    caption: 'Get answers on realism, turnaround, ownership, revisions, and minimum order size.',
  },
];
const heroLoopTrackOne = [
  { src: '/assets/ai-shoots/hero-loop/shot-01.jpg', alt: 'AI shoots hero card image one.' },
  { src: '/assets/ai-shoots/hero-loop/shot-02.jpg', alt: 'AI shoots hero card image two.' },
  { src: '/assets/ai-shoots/hero-loop/shot-03.jpg', alt: 'AI shoots hero card image three.' },
  { src: '/assets/ai-shoots/hero-loop/shot-04.jpeg', alt: 'AI shoots hero card image four.' },
  { src: '/assets/ai-shoots/hero-loop/shot-05.jpeg', alt: 'AI shoots hero card image five.' },
];
const heroLoopTrackTwo = [
  { src: '/assets/ai-shoots/hero-loop/loop-06.svg', alt: 'AI shoots placeholder fashion image six.' },
  { src: '/assets/ai-shoots/hero-loop/loop-07.svg', alt: 'AI shoots placeholder fashion image seven.' },
  { src: '/assets/ai-shoots/hero-loop/loop-08.svg', alt: 'AI shoots placeholder fashion image eight.' },
  { src: '/assets/ai-shoots/hero-loop/loop-09.svg', alt: 'AI shoots placeholder fashion image nine.' },
  { src: '/assets/ai-shoots/hero-loop/loop-10.svg', alt: 'AI shoots placeholder fashion image ten.' },
];
const heroStackCards = heroLoopTrackOne;
const platforms = [
  { name: 'Myntra', type: 'myntra' },
  { name: 'Flipkart', type: 'flipkart' },
  { name: 'Amazon', type: 'amazon' },
  { name: 'Shopify', type: 'shopify' },
  { name: 'Instagram', type: 'instagram' },
];
const oldWay = [
  {
    title: '2-4 Week Lead Time',
    copy: 'Booking studios, models, and photographers takes weeks of coordination.',
  },
  {
    title: 'Rs. 5,000+ Per SKU',
    copy: 'High overhead costs for physical locations, equipment, and crew.',
  },
];
const nexaiWay = [
  {
    title: '48-Hour Delivery',
    copy: 'Ready-to-publish assets delivered while your competitors are still planning.',
  },
  {
    title: 'Rs. 400 Per SKU',
    copy: 'Professional high-end quality at a fraction of traditional studio pricing.',
  },
];
const showcaseItems = [
  { before: 'Mannequin shot', after: 'On-model ethnicwear', note: 'Marketplace-ready hero image in 48 hours' },
  { before: 'Flat-lay setup', after: 'Lifestyle westernwear', note: 'Styled campaign frame with brand-safe lighting' },
  { before: 'Plain backdrop', after: 'Studio jewelry setting', note: 'Premium product context without reshoot logistics' },
  { before: 'Ghost mannequin', after: 'Model pose activewear', note: 'Clean fit visualization for catalog listings' },
  { before: 'Phone capture', after: 'Editorial storefront asset', note: 'Launch-ready creative for paid ads and PDPs' },
  { before: 'Basic SKU image', after: 'Polished collection tile', note: 'Consistent outputs across the full catalog' },
];
const steps = [
  { number: '01', title: 'Upload', copy: 'Upload your mannequin or flat-lay product photos to our secure portal.', node: 'upload', reverse: false },
  { number: '02', title: 'Choose Look', copy: 'Select model ethnicity, body type, and background aesthetic from our curated presets.', node: '2', reverse: true },
  { number: '03', title: 'Receive Results', copy: 'Receive high-resolution, ready-to-use editorial shots within 48 hours.', node: 'download', reverse: false },
];
const stats = [
  { target: 5000, suffix: '+', label: 'Images Delivered' },
  { target: 15, suffix: '+', label: 'Brands Trust Us' },
  { target: 80, suffix: '%', label: 'Average Cost Savings' },
  { target: 48, suffix: 'hr', label: 'Avg Delivery' },
];
const testimonials = [
  { quote: 'Cut our photoshoot costs by 80%. We now launch collections in days, not weeks.', brand: 'Saree Mall', role: 'D2C Ethnic Wear Brand' },
  { quote: "The quality looks exactly like real studio shots. Our customers can't tell the difference.", brand: 'Dhwani Bansal Jewelry', role: 'Premium Jewelry Brand' },
  { quote: 'Finally scaled our catalog without scaling our photoshoot budget. Game-changer.', brand: 'BannoSwagger', role: 'Fashion E-commerce' },
  { quote: 'We launched 200 SKUs in one week. Previously that would take us 2 months.', brand: 'IndoEra', role: 'Traditional Wear Brand' },
  { quote: 'The AI models look more consistent than real photoshoots. Every image matches our brand perfectly.', brand: 'Leemboodi', role: "Women's Fashion" },
];
const featuredTestimonials = [
  {
    initials: 'SM',
    brand: 'Saree Mall',
    role: 'Ethnic Fashion',
    quote: '"NexAI transformed our catalog speed. We went from 3 weeks for a shoot to launching new collections in days."',
  },
  {
    initials: 'DB',
    brand: 'Dhwani Bansal',
    role: 'Luxury Jewelry',
    quote: '"The detail in the AI jewelry mapping is insane. It looks as premium as our traditional high-cost shoots."',
  },
  {
    initials: 'BS',
    brand: 'BannoSwagger',
    role: 'Gen-Z Apparel',
    quote: '"Perfect for high-volume drops. We save lakhs every month and our conversion rate has actually increased."',
  },
];
const pricing = [
  { name: 'Pay Per SKU', price: 'Rs. 400/SKU', subtitle: 'Perfect for trying us out', features: ['Minimum 25 SKUs', '5-7 images per SKU', 'Marketplace-ready quality', '48-hour delivery', '2 revision rounds'], cta: 'Get Started' },
  { name: 'Growth', price: 'Rs. 35,000/mo', subtitle: 'For scaling brands', featured: true, badge: 'Most Popular', features: ['100 SKUs included', '5 video reels (8 sec each)', '15 ad creatives', 'Priority 24hr delivery', 'Unlimited revisions', 'Dedicated account manager'], cta: 'Book a Call' },
  { name: 'Scale', price: 'Rs. 75,000/mo', subtitle: 'For high-volume brands', features: ['250 SKUs included', '10 video reels', '30 ad creatives', 'Same-day rush option', 'API access', 'White-label available'], cta: 'Contact Us' },
];
const caseStudies = [
  { brand: 'BannoSwagger', title: 'Cut Production Costs by 80%', copy: 'Reduced production costs by 80%, while maintaining brand-quality visuals for e-commerce and campaigns.' },
  { brand: 'Saree Mall', title: 'Launched 150 SKUs in 5 Days', copy: 'What used to take weeks of planning, photoshoots, and editing now happens in hours.' },
  { brand: 'Dhwani Bansal Jewelry', title: 'Premium Quality at 1/5th the Cost', copy: 'Cut down creative production timelines from weeks to days.' },
];
const faqs = [
  { q: 'Do the AI-generated images look realistic?', a: 'Yes. Our AI creates photorealistic, studio-quality images that meet marketplace standards for Myntra, Amazon, and Flipkart. Most customers cannot distinguish them from traditional photoshoots.' },
  { q: 'What images do I need to provide?', a: 'Mannequin shots, ghost mannequin, or flat-lay photos are enough. Smartphone quality works fine because we handle the processing and production cleanup.' },
  { q: "Can I choose the model's look?", a: 'Absolutely. You can specify body type, skin tone, height, poses, expressions, and backgrounds so the output matches your brand aesthetic.' },
  { q: 'How fast is delivery?', a: 'Standard delivery is 48 hours. Growth and Scale include priority 24-hour delivery, and rush same-day options are available for urgent launches.' },
  { q: 'Do I own the images?', a: 'Yes. Once delivered, the images are fully yours to use across marketplaces, your website, social media, ads, and print.' },
  { q: "What if I don't like the results?", a: "Every plan includes revisions. If you're still not satisfied, we'll refund the order. The process is designed to get to a usable result quickly." },
  { q: 'Is there a minimum order?', a: 'Yes. The pay-per-SKU option starts at 25 SKUs. Monthly plans do not have a per-order minimum.' },
];
---

<Layout title="AI Photoshoots for Fashion Brands | NexAI Labs" description="Premium AI fashion photography for D2C brands. Turn mannequin shots into on-model visuals in 48 hours." showNavbar={false}>
  <main class="shoots-page">
    <Navbar
      navLinks={heroNavLinks}
      topHref="#top"
      brandAriaLabel="NexAI Labs AI Shoots home"
      ctaHref={bookingUrl}
      ctaLabel="Book a Call"
      email={email}
      takeoverMeta="India / Remote"
      panelId="ai-shoots-nav-takeover"
    />

    <section class="shoots-hero" id="top">
      <div class="container shoots-hero__shell">
        <div class="shoots-hero__copy">
          <h1 class="shoots-hero__title reveal-up">
            <span class="shoots-hero__title-line">
              <span class="shoots-hero__title-word shoots-hero__title-word--left" data-hero-word="left">AI</span>
              <span class="shoots-hero__title-word shoots-hero__title-word--right" data-hero-word="right">SHOOTS</span>
            </span>
            <span class="shoots-hero__stack-stage" data-hero-stack-stage aria-hidden="true">
              {heroStackCards.map((item, index) => (
                <span class:list={['shoots-hero__card', `shoots-hero__card--${index + 1}`]}>
                  <img src={item.src} alt={item.alt} loading={index < 2 ? 'eager' : 'lazy'} decoding="async" />
                </span>
              ))}
            </span>
          </h1>
          <div class="shoots-hero__actions reveal-up">
            <a class="btn btn--brand shoots-hero__cta-main" href={bookingUrl} target="_blank" rel="noreferrer">
              <span>Get Free Sample Images</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="platform-strip reveal-up" id="platforms">
      <div class="container platform-strip__inner">
        <p>Powering fashion brands selling on</p>
        <div class="platform-strip__logos">
          {platforms.map((platform) => (
            <span class="platform-logo">
              <span class:list={['platform-logo__mark', `platform-logo__mark--${platform.type}`]} aria-hidden="true">
                {platform.type === 'myntra' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M5 18V7l3 3 4-5 4 5 3-3v11" />
                  </svg>
                )}
                {platform.type === 'flipkart' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 8.5h10l1 10.5H6z" />
                    <path d="M9 8.5a3 3 0 0 1 6 0" />
                    <path d="M11 13h4" />
                    <path d="M11 16h3" />
                  </svg>
                )}
                {platform.type === 'amazon' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M8.5 8.5h3.8c2 0 3.2 1 3.2 2.7 0 2-1.6 3.2-4 3.2H8.5z" />
                    <path d="M7.5 17.2c2.8 1.4 5.9 1.4 8.8 0" />
                    <path d="M14.7 16.6l1.7.8-.7 1.5" />
                  </svg>
                )}
                {platform.type === 'shopify' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 8.2h10l-1.1 11H8.1z" />
                    <path d="M9.2 8.2a2.7 2.7 0 0 1 5.4 0" />
                    <path d="M13.8 11.4c-.5-.3-1.1-.5-1.7-.5-.9 0-1.6.4-1.6 1.1 0 1.6 3.6 1 3.6 3.6 0 1.7-1.4 2.8-3.5 2.8-.9 0-1.9-.2-2.6-.6" />
                  </svg>
                )}
                {platform.type === 'instagram' && (
                  <svg viewBox="0 0 24 24">
                    <rect x="4.5" y="4.5" width="15" height="15" rx="4.2" />
                    <circle cx="12" cy="12" r="3.4" />
                    <circle cx="16.6" cy="7.5" r="1" class="platform-logo__fill" />
                  </svg>
                )}
              </span>
              <span class="platform-logo__text">{platform.name}</span>
            </span>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window section--compare" id="problem-solution">
      <div class="container">
        <div class="section-heading reveal-up">
          <p class="eyebrow">Why teams switch</p>
          <h2>Traditional production slows launches. The AI workflow does not.</h2>
        </div>
        <div class="compare-grid">
          <article class="compare-panel compare-panel--old reveal-up">
            <div class="compare-panel__head">
              <span>The Traditional Process</span>
              <strong>Expensive &amp; Rigid</strong>
            </div>
            <ul>
              {oldWay.map((item) => (
                <li>
                  <span class="compare-panel__icon" aria-hidden="true">x</span>
                  <div>
                    <strong>{item.title}</strong>
                    <p>{item.copy}</p>
                  </div>
                </li>
              ))}
            </ul>
          </article>
          <article class="compare-panel compare-panel--new reveal-up">
            <div class="compare-panel__head">
              <span>The NexAI Workflow</span>
              <strong>Fast, Flexible, Scalable</strong>
            </div>
            <ul>
              {nexaiWay.map((item) => (
                <li>
                  <span class="compare-panel__icon" aria-hidden="true">+</span>
                  <div>
                    <strong>{item.title}</strong>
                    <p>{item.copy}</p>
                  </div>
                </li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-window section--showcase-stitch" id="transformations">
      <div class="container">
        <div class="section-heading reveal-up">
          <p class="eyebrow">Transformation showcase</p>
          <h2>Before-and-after outcomes buyers understand immediately.</h2>
          <p>These are placeholder compositions for the real image set, but the layout is ready for premium visual proof.</p>
        </div>
        <div class="showcase-grid">
          {showcaseItems.map((item) => (
            <article class="showcase-card reveal-up">
              <div class="showcase-card__duo">
                <div class="showcase-card__shot"><span>Before</span><strong>{item.before}</strong></div>
                <div class="showcase-card__shot showcase-card__shot--after"><span>After</span><strong>{item.after}</strong></div>
              </div>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window section--atelier-stitch" id="how-it-works">
      <div class="container">
        <div class="stitch-process__heading reveal-up">
          <p class="eyebrow">How it works</p>
          <h2>How It Works</h2>
          <p>Upload your photos, choose your look, and receive studio-quality results in 48 hours.</p>
        </div>
        <div class="stitch-process">
          <div class="stitch-process__rail" aria-hidden="true"></div>
          <div class="stitch-process__stack">
            {steps.map((step, index) => (
              <article class:list={['stitch-process__step', step.reverse && 'stitch-process__step--reverse', 'reveal-up']}>
                <div class="stitch-process__copy">
                  <h3>{`${step.number}. ${step.title}`}</h3>
                  <p>{step.copy}</p>
                </div>
                <div class:list={['stitch-process__node', `step-node-${index + 1}`]} aria-hidden="true">
                  <span>{step.node === 'upload' ? '↑' : step.node === 'download' ? '↓' : step.node}</span>
                </div>
                <div class="stitch-process__spacer" aria-hidden="true"></div>
                {index < steps.length - 1 && (
                  <div class="stitch-process__line" aria-hidden="true">
                    <div class:list={['stitch-process__line-segment', `line-segment-${index + 1}`]}></div>
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section-window section--atelier" id="how-it-works-legacy" hidden>
      <div class="container">
        <div class="section-heading reveal-up">
          <p class="eyebrow">How it works</p>
          <h2>The atelier process for faster catalog production.</h2>
        </div>
        <div class="atelier-flow">
          <div class="atelier-flow__rail" aria-hidden="true"></div>
          {steps.map((step, index) => (
            <article class:list={['atelier-step', index % 2 === 1 && 'atelier-step--reverse', 'reveal-up']}>
              <div class="atelier-step__copy">
                <span>{`0${index + 1}`}</span>
                <h3>{step.title}</h3>
                <p>{step.copy}</p>
              </div>
              <div class:list={['atelier-step__node', `atelier-step__node--${index + 1}`]} aria-hidden="true">
                <span>{index === 0 ? '↑' : index === 1 ? '02' : '↓'}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window section--stats-stitch">
      <div class="container">
        <div class="stitch-proof">
          <div class="stitch-proof__stats reveal-up">
            {stats.map((stat) => (
              <div class="stitch-proof__stat">
                <strong data-count-target={stat.target} data-count-suffix={stat.suffix}>0</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
          <div class="stitch-proof__testimonials">
            {featuredTestimonials.map((item) => (
              <article class="stitch-proof__card reveal-up">
                <div class="stitch-proof__brand">
                  <div class="stitch-proof__avatar">{item.initials}</div>
                  <div>
                    <strong>{item.brand}</strong>
                    <span>{item.role}</span>
                  </div>
                </div>
                <p>{item.quote}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section-window section--stats" hidden>
      <div class="container">
        <div class="stats-grid reveal-up">
          {stats.map((stat) => (
            <div class="stat-card">
              <strong data-count-target={stat.target} data-count-suffix={stat.suffix}>0</strong>
              <span>{stat.label}</span>
            </div>
          ))}
        </div>
        <div class="section-heading reveal-up">
          <p class="eyebrow">Testimonials</p>
          <h2>Proof that the speed is real and the quality holds up.</h2>
        </div>
        <div class="testimonials-grid">
          {testimonials.map((item) => (
            <article class="testimonial-card reveal-up">
              <div class="stars" aria-hidden="true">★★★★★</div>
              <p>{item.quote}</p>
              <footer>
                <strong>{item.brand}</strong>
                <span>{item.role}</span>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window" id="pricing">
      <div class="container">
        <div class="stitch-pricing__heading reveal-up">
          <h2>Investment Tiers</h2>
          <p>Premium results. Predictable pricing. No hidden studio fees.</p>
        </div>
        <div class="stitch-pricing">
          {pricing.map((tier) => (
            <article class:list={['stitch-pricing__card', tier.featured && 'stitch-pricing__card--featured', 'reveal-up']}>
              {tier.badge && <span class="stitch-pricing__badge">{tier.badge}</span>}
              <h3>{tier.name}</h3>
              <p class="stitch-pricing__subtitle">{tier.subtitle}</p>
              <div class="stitch-pricing__price">
                <strong>{tier.price.split('/')[0]}</strong>
                <span>{` / ${tier.price.includes('/month') ? 'mo' : tier.price.includes('/mo') ? 'mo' : 'sku'}`}</span>
              </div>
              <ul>
                {tier.features.slice(0, 2).map((feature) => <li>{feature}</li>)}
              </ul>
              <a class:list={['stitch-pricing__button', tier.featured && 'stitch-pricing__button--primary']} href={bookingUrl} target="_blank" rel="noreferrer">
                {tier.name === 'Pay Per SKU' ? 'Start Now' : tier.name === 'Scale' ? 'Contact Enterprise' : 'Get Started'}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window section--case-window" id="case-studies">
      <div class="container">
        <div class="section-heading reveal-up">
          <p class="eyebrow">Case studies</p>
          <h2>Selected outcomes for brands that needed speed without losing polish.</h2>
        </div>
        <div class="case-grid">
          {caseStudies.map((item) => (
            <article class="case-card reveal-up">
              <span>{item.brand}</span>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-window" id="faq">
      <div class="container">
        <div class="section-heading reveal-up">
          <p class="eyebrow">FAQ</p>
          <h2>Answer the buying questions before the call.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <article class="faq-item reveal-up">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-band section-window reveal-up">
      <div class="container cta-band__inner">
        <div>
          <p class="eyebrow">Free samples included</p>
          <h2>Ready to Launch Collections Faster?</h2>
          <p>Get free sample images for 3 products. See the quality before you commit.</p>
        </div>
        <div class="cta-band__actions">
          <a class="btn btn--brand" href={bookingUrl} target="_blank" rel="noreferrer">Book Your Free Demo</a>
          <a class="btn btn--ghost" href={`mailto:${email}`}>{email}</a>
        </div>
      </div>
      <div class="container cta-band__trust">
        <span>No credit card required</span>
        <span>15-minute call</span>
        <span>Free samples included</span>
      </div>
    </section>

    <footer class="shoots-footer section-window">
      <div class="container shoots-footer__grid">
        <div class="shoots-footer__brand">
          <img src="/assets/logo/nexai-icon.png" alt="" width="40" height="40" />
          <div>
            <strong>NexAI Labs</strong>
            <p>AI-powered product photography for fashion brands.</p>
            <div class="shoots-footer__socials">
              <a href="https://instagram.com" target="_blank" rel="noreferrer" aria-label="Instagram">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
                  <circle cx="12" cy="12" r="4.1"></circle>
                  <circle cx="17.4" cy="6.7" r="1.1" class="shoots-footer__icon-fill"></circle>
                </svg>
                <span>Instagram</span>
              </a>
              <a href="https://linkedin.com/company/nexailabs" target="_blank" rel="noreferrer" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3.5" y="3.5" width="17" height="17" rx="4"></rect>
                  <path d="M8.2 10.2v5.9"></path>
                  <path d="M8.2 8a.8.8 0 1 0 0 1.6A.8.8 0 0 0 8.2 8Z" class="shoots-footer__icon-fill"></path>
                  <path d="M11.3 10.2v5.9"></path>
                  <path d="M11.3 12.8c0-1.5.9-2.6 2.3-2.6 1.3 0 2.1.9 2.1 2.6v3.3"></path>
                </svg>
                <span>LinkedIn</span>
              </a>
            </div>
          </div>
        </div>
        <div>
          <h3>Product</h3>
          <a href="#how-it-works">How It Works</a>
          <a href="#pricing">Pricing</a>
          <a href="#case-studies">Case Studies</a>
          <a href="#faq">FAQ</a>
        </div>
        <div>
          <h3>Company</h3>
          <a href="#top">About Us</a>
          <a href="#top">Blog</a>
          <a href="#top">Careers</a>
          <a href={`mailto:${email}`}>Contact</a>
        </div>
        <div>
          <h3>Legal</h3>
          <a href="#top">Privacy Policy</a>
          <a href="#top">Terms of Service</a>
        </div>
