<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAiShootsPage() {
    const cleanupKey = '__aiShootsHeroStackCleanup';
    if (Array.isArray(window[cleanupKey])) {
      window[cleanupKey].forEach((cleanup) => cleanup());
    }
    window[cleanupKey] = [];

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const stackStage = document.querySelector('[data-hero-stack-stage]');
    const leftWord = document.querySelector('[data-hero-word="left"]');
    const rightWord = document.querySelector('[data-hero-word="right"]');
    const stackStates = [
      { xPercent: 8, yPercent: 6, rotation: 9, zIndex: 5, opacity: 1 },
      { xPercent: -1, yPercent: 1, rotation: 1, zIndex: 4, opacity: 0.96 },
      { xPercent: -10, yPercent: -3, rotation: -7, zIndex: 3, opacity: 0.92 },
      { xPercent: -18, yPercent: -8, rotation: -13, zIndex: 2, opacity: 0.88 },
      { xPercent: -26, yPercent: -12, rotation: -18, zIndex: 1, opacity: 0.84 },
    ];

    if (stackStage instanceof HTMLElement) {
      const cards = Array.from(stackStage.querySelectorAll('.shoots-hero__card'));
      const count = cards.length;
      let activeIndex = 0;
      let delayedStep;
      let destroyed = false;
      const titleSpread = window.innerWidth <= 720 ? 42 : 112;
      const motion = prefersReducedMotion ? {
        initialDelay: 0.01,
        drop: 0.01,
        fan: 0.01,
        fanStagger: 0,
        settlePause: 0.01,
        collapse: 0.01,
        collapseStagger: 0,
        centerHold: 0.01,
        exit: 0.01,
        loopPause: 9999,
        titleOpen: 0.01,
        titleClose: 0.01,
      } : {
        initialDelay: 0.4,
        drop: 1.05,
        fan: 0.68,
        fanStagger: 0.12,
        settlePause: 0.82,
        collapse: 0.46,
        collapseStagger: 0.1,
        centerHold: 0.42,
        exit: 0.58,
        loopPause: 0.42,
        titleOpen: 0.72,
        titleClose: 0.72,
      };

      const resetCards = () => {
        cards.forEach((card) => {
          gsap.set(card, {
            xPercent: 0,
            yPercent: 0,
            rotation: 0,
            scale: 0.92,
            opacity: 0,
            zIndex: 0,
          });
        });
      };

      const setTitleClosed = () => {
        if (leftWord instanceof HTMLElement && rightWord instanceof HTMLElement) {
          gsap.set(leftWord, { x: 0 });
          gsap.set(rightWord, { x: 0 });
        }
      };

      const addTitleOpen = (timeline, position = 0) => {
        if (!(leftWord instanceof HTMLElement) || !(rightWord instanceof HTMLElement)) return;
        timeline.to(leftWord, {
          x: -titleSpread,
          duration: motion.titleOpen,
          ease: 'power3.inOut',
        }, position);
        timeline.to(rightWord, {
          x: titleSpread,
          duration: motion.titleOpen,
          ease: 'power3.inOut',
        }, position);
      };

      const addTitleClose = (timeline, position) => {
        if (!(leftWord instanceof HTMLElement) || !(rightWord instanceof HTMLElement)) return;
        timeline.to(leftWord, {
          x: 0,
          duration: motion.titleClose,
          ease: 'power3.inOut',
        }, position);
        timeline.to(rightWord, {
          x: 0,
          duration: motion.titleClose,
          ease: 'power3.inOut',
        }, position);
      };

      const orderedCards = (startIndex) => Array.from({ length: count }, (_, offset) => cards[(startIndex + offset) % count]);

      const runLoop = () => {
        if (destroyed || !count) return;

        resetCards();
        setTitleClosed();

        const currentCards = orderedCards(activeIndex);
        const activeCard = currentCards[0];
        if (!(activeCard instanceof HTMLElement)) return;

        gsap.set(activeCard, {
          yPercent: -220,
          opacity: 1,
          scale: 1,
          zIndex: 6,
        });

        const timeline = gsap.timeline({
          onComplete: () => {
            activeIndex = (activeIndex + 1) % count;
            if (!destroyed) {
              delayedStep = gsap.delayedCall(motion.loopPause, runLoop);
            }
          },
        });

        addTitleOpen(timeline, 0);

        timeline.to(activeCard, {
          yPercent: 0,
          duration: motion.drop,
          ease: 'expo.out',
        }, 0.08);

        currentCards.forEach((card, index) => {
          const slot = stackStates[Math.min(index, stackStates.length - 1)];
          timeline.to(card, {
            xPercent: slot.xPercent,
            yPercent: slot.yPercent,
            rotation: slot.rotation,
            scale: 1,
            opacity: slot.opacity,
            zIndex: slot.zIndex,
            duration: motion.fan,
            ease: 'power3.out',
          }, index === 0 ? '<+0.08' : `<+${motion.fanStagger}`);
        });

        timeline.to({}, { duration: motion.settlePause });

        currentCards.slice(1).forEach((card, index) => {
          timeline.to(card, {
            xPercent: 0,
            yPercent: 0,
            rotation: 0,
            scale: 0.92,
            opacity: 0,
            duration: motion.collapse,
            ease: 'power2.inOut',
          }, index === 0 ? '>' : `<+${motion.collapseStagger}`);
        });

        timeline.to(activeCard, {
          xPercent: 0,
          yPercent: 0,
          rotation: 0,
          opacity: 1,
          duration: motion.collapse,
          ease: 'power2.inOut',
        }, '<');

        timeline.to({}, { duration: motion.centerHold });

        addTitleClose(timeline, '>-0.08');

        timeline.to(activeCard, {
          yPercent: -240,
          opacity: 0,
          duration: motion.exit,
          ease: 'power3.in',
        }, '<+0.08');
      };

      if (prefersReducedMotion) {
        resetCards();
        setTitleClosed();
        cards.forEach((card, index) => {
          if (!(card instanceof HTMLElement)) return;
          const slot = stackStates[Math.min(index, stackStates.length - 1)];
          card.style.opacity = String(slot.opacity);
          card.style.zIndex = String(slot.zIndex);
          card.style.transform = `translate(${slot.xPercent}%, ${slot.yPercent}%) rotate(${slot.rotation}deg)`;
        });
      } else {
        delayedStep = gsap.delayedCall(motion.initialDelay, runLoop);
      }

      window[cleanupKey].push(() => {
        destroyed = true;
        delayedStep?.kill();
        gsap.killTweensOf(cards);
      });
    }

    document.querySelectorAll('[data-count-target]').forEach((element) => {
      if (!(element instanceof HTMLElement)) return;

      const target = Number(element.dataset.countTarget || '0');
      const suffix = element.dataset.countSuffix || '';
      const counter = { value: 0 };

      gsap.to(counter, {
        value: target,
        duration: 1.4,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: element,
          start: 'top 88%',
          once: true,
        },
        onUpdate() {
          element.textContent = `${Math.round(counter.value)}${suffix}`;
        },
      });
    });

    gsap.utils.toArray('.reveal-up').forEach((element) => {
      gsap.fromTo(element, { opacity: 0, y: 26 }, {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: { trigger: element, start: 'top 86%', once: true },
      });
    });
  }

  initAiShootsPage();
  document.addEventListener('astro:page-load', initAiShootsPage);
</script>


